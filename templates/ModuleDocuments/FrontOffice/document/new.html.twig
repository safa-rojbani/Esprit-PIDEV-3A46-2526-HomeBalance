{% extends 'base.html.twig' %}

{% block title %}Nouveau document{% endblock %}

{% block content %}
<style>
  .hb-page{max-width:1040px;margin:0 auto;}
  .hb-top{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:14px;}
  .hb-top h3{margin:0;font-weight:1000;letter-spacing:.2px;color:#2b2f36;}
  .hb-top p{margin:6px 0 0;color:#7a8699;}
  .hb-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;}
  .hb-chip{display:inline-flex;align-items:center;gap:8px;padding:.44rem .8rem;border-radius:999px;border:1px solid rgba(67,89,113,.12);background:rgba(255,255,255,.92);color:#566a7f;font-weight:850;backdrop-filter:blur(10px);}
  .hb-chip i{color:#696cff;}
  .hb-hero{background:#fff;border:1px solid rgba(67,89,113,.12);border-radius:20px;padding:16px 18px;box-shadow:0 14px 40px rgba(67,89,113,.10);margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:14px;}
  .hb-hero .title{margin:0;display:flex;align-items:center;gap:10px;font-weight:950;color:#2b2f36;font-size:1.06rem;}
  .hb-hero .title i{color:#696cff;font-size:18px;}
  .hb-hero .sub{margin:6px 0 0;color:#7a8699;line-height:1.35;}
  .hb-card,.hb-side{background:#fff;border:1px solid rgba(67,89,113,.12);border-radius:20px;box-shadow:0 18px 55px rgba(67,89,113,.10);overflow:hidden;transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;}
  .hb-card:hover,.hb-side:hover{transform:translateY(-2px);box-shadow:0 26px 70px rgba(67,89,113,.14);border-color:rgba(105,108,255,.22);}
  .hb-card-header{padding:14px 16px;border-bottom:1px solid rgba(67,89,113,.10);display:flex;align-items:center;justify-content:space-between;gap:10px;}
  .hb-card-header .left{font-weight:950;color:#2b2f36;display:flex;align-items:center;gap:10px;}
  .hb-dot{width:10px;height:10px;border-radius:999px;background:rgba(105,108,255,.85);box-shadow:0 10px 22px rgba(105,108,255,.20);display:inline-block;}
  .hb-card-body{padding:18px;}
  .hb-card-body form{margin:0;}
  .hb-card-body label{display:block!important;font-weight:850;color:#566a7f;margin-bottom:6px;}
  .hb-card-body input,.hb-card-body textarea,.hb-card-body select{width:100%!important;display:block!important;border-radius:14px!important;background:#fff!important;}
  .hb-card-body input:focus,.hb-card-body textarea:focus,.hb-card-body select:focus{box-shadow:0 0 0 .2rem rgba(105,108,255,.16)!important;border-color:rgba(105,108,255,.55)!important;}
  .hb-card-body > form > div{margin-bottom:14px;}
  .hb-submit{margin-top:6px;border-radius:14px!important;padding:.82rem 1.1rem!important;font-weight:1000!important;display:inline-flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 16px 40px rgba(105,108,255,.18);}
  .hb-side .card-body{padding:16px;}
  .hb-side h6{margin:0 0 10px;font-weight:950;color:#2b2f36;display:flex;align-items:center;gap:10px;}
  .hb-side h6 i{color:#696cff;}
  .hb-side ul{margin:0;padding-left:1.1rem;color:#7a8699;}
  .hb-side li{margin:6px 0;}
  .hb-in{animation:hbIn .25s ease both;}
  @keyframes hbIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}


  .hb-cam-overlay{position:fixed; inset:0; z-index:99999; display:none; background:rgba(10,16,28,.72); backdrop-filter:blur(10px); padding:18px;}
  .hb-cam-wrap{height:100%;display:flex;align-items:center;justify-content:center;}
  .hb-cam-modal{width:min(1120px,100%); aspect-ratio:16/9; border-radius:26px; overflow:hidden; background:#000; border:1px solid rgba(255,255,255,.14); box-shadow:0 55px 160px rgba(0,0,0,.55); position:relative;}

  .hb-cam-stage{position:absolute;inset:0;background:#000;}
  #hbVideo{width:100%;height:100%;object-fit:cover;display:block;}
  #hbPreview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
  #hbVidPreview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;background:#000;}

  .hb-cam-topbar{position:absolute; top:0; left:0; right:0; z-index:20; padding:12px 14px; display:flex; align-items:center; justify-content:space-between; gap:12px; background:linear-gradient(180deg, rgba(0,0,0,.70), rgba(0,0,0,.05));}
  .hb-cam-title{display:inline-flex; align-items:center; gap:10px; padding:.46rem .85rem; border-radius:999px; color:#fff; font-weight:950; border:1px solid rgba(255,255,255,.18); background:rgba(255,255,255,.10); backdrop-filter:blur(10px);}
  .hb-cam-top-actions{display:flex;gap:10px;align-items:center;}

  .hb-cam-btn{height:42px; min-width:42px; padding:0 14px; border-radius:999px; border:1px solid rgba(255,255,255,.20); background:rgba(255,255,255,.10); color:#fff; font-weight:950; display:inline-flex; align-items:center; justify-content:center; gap:10px; cursor:pointer; user-select:none; transition:transform .12s ease, background .12s ease, border-color .12s ease, opacity .12s ease;}
  .hb-cam-btn:hover{transform:translateY(-1px);background:rgba(255,255,255,.14);border-color:rgba(105,108,255,.40);}
  .hb-cam-btn i{font-size:18px;}
  .hb-cam-btn.primary{background:linear-gradient(135deg, rgba(105,108,255,1), rgba(105,108,255,.65)); border-color:rgba(105,108,255,.55); box-shadow:0 16px 45px rgba(105,108,255,.25);}
  .hb-cam-btn.icon{width:42px;padding:0;}

  .hb-cam-bottom{position:absolute; left:0; right:0; bottom:0; z-index:25; padding:14px 16px; background:linear-gradient(0deg, rgba(0,0,0,.75), rgba(0,0,0,.08)); display:flex; align-items:center; justify-content:space-between; gap:14px;}
  .hb-cam-msg{color:rgba(255,255,255,.92); font-weight:900; text-shadow:0 10px 25px rgba(0,0,0,.45); max-width:42%; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;}
  .hb-cam-center{display:flex;align-items:center;justify-content:center;flex:1;}
  .hb-cam-right{display:flex;gap:10px;align-items:center;}

  .hb-shutter{width:82px;height:82px;border-radius:999px; border:3px solid rgba(255,255,255,.85); background:rgba(255,255,255,.18); display:grid;place-items:center; box-shadow:0 24px 70px rgba(0,0,0,.45); cursor:pointer; transition:transform .12s ease;}
  .hb-shutter::after{content:""; width:62px;height:62px;border-radius:999px; background:#fff; box-shadow:inset 0 -12px 24px rgba(0,0,0,.16);}
  .hb-shutter:active{transform:scale(.96);}

  .hb-rec{width:82px;height:82px;border-radius:999px; border:3px solid rgba(255,255,255,.85); background:rgba(255,255,255,.12); display:grid;place-items:center; box-shadow:0 24px 70px rgba(0,0,0,.45); cursor:pointer;}
  .hb-rec::after{content:""; width:28px;height:28px;border-radius:999px; background:#ff3b3b; box-shadow:0 10px 24px rgba(255,59,59,.35);}
  .hb-rec.recording::after{animation:hbPulse 1s infinite ease-in-out;}
  @keyframes hbPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.12);opacity:.75}}

  .hb-disabled{opacity:.45!important;pointer-events:none!important;}

  .hb-flash{position:absolute;inset:0;background:#fff;opacity:0;pointer-events:none;z-index:50;}
  .hb-flash.on{animation:hbFlash .22s ease;}
  @keyframes hbFlash{0%{opacity:0;}15%{opacity:.95;}100%{opacity:0;}}

  .hb-cam-x{width:46px;height:46px;border-radius:999px; border:1px solid rgba(255,255,255,.18); background:rgba(0,0,0,.18); color:#fff; display:inline-flex;align-items:center;justify-content:center; cursor:pointer; font-weight:1000; line-height:1; backdrop-filter:blur(10px); transition:transform .12s ease, background .12s ease, border-color .12s ease;}
  .hb-cam-x span{font-size:28px;transform:translateY(-1px);}
  .hb-cam-x:hover{transform:scale(1.05);background:rgba(255,255,255,.10);border-color:rgba(105,108,255,.45);}
  .hb-cam-x:active{transform:scale(.96);}

  .hb-mode{display:inline-flex; border:1px solid rgba(255,255,255,.18); background:rgba(255,255,255,.08); border-radius:999px; overflow:hidden;}
  .hb-mode button{border:none;background:transparent;color:#fff;padding:.45rem .8rem;font-weight:950;cursor:pointer;opacity:.8}
  .hb-mode button.active{opacity:1;background:rgba(105,108,255,.35)}
</style>

<div class="hb-page">
  <div class="hb-top flex-wrap hb-in">
    <div>
      <h3>Nouveau document</h3>
      <p class="mb-0">Ajoutez un fichier a votre galerie.</p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <button type="button" class="btn btn-outline-primary" id="hbOpenCam">
        <i class="bx bx-camera"></i> Ouvrir la camera
      </button>
    </div>

    <div class="hb-actions">
      <a href="{{ path('app_gallery_show', {'id': galleryId}) }}" class="btn btn-outline-secondary">
        <i class="bx bx-left-arrow-alt me-1"></i> Retour a la galerie
      </a>
    </div>
  </div>

  <div id="hbCamOverlay" class="hb-cam-overlay">
    <div class="hb-cam-wrap">
      <div class="hb-cam-modal" role="dialog" aria-modal="true">
        <div class="hb-flash" id="hbFlash"></div>

        <div class="hb-cam-topbar">
          <div class="hb-cam-title">
            <i class="bx bx-camera"></i> Camera
          </div>

          <div class="hb-cam-top-actions">
            <div class="hb-mode" aria-label="mode">
              <button type="button" id="hbModePhoto" class="active">PHOTO</button>
              <button type="button" id="hbModeVideo">VIDEO</button>
            </div>

            <button type="button" class="hb-cam-btn" id="hbRetake" title="Reprendre">
              <i class="bx bx-undo"></i> Reprendre
            </button>

            <button type="button" class="hb-cam-x" id="hbCloseCam2" aria-label="Fermer">
              <span aria-hidden="true">x</span>
            </button>
          </div>
        </div>

        <div class="hb-cam-stage">
          <video id="hbVideo" autoplay playsinline muted></video>
          <canvas id="hbCanvas" style="display:none;"></canvas>
          <img id="hbPreview" alt="apercu"/>
          <video id="hbVidPreview" controls playsinline></video>
        </div>

        <div class="hb-cam-bottom">
          <div class="hb-cam-msg" id="hbApiMsg">Ouvrez la camera</div>

          <div class="hb-cam-center">
            <button type="button" class="hb-shutter" id="hbSnap" title="Prendre une photo"></button>
            <button type="button" class="hb-rec" id="hbRec" title="Enregistrer une video" style="display:none;"></button>
          </div>

          <div class="hb-cam-right">
            <button type="button" class="hb-cam-btn primary" id="hbUploadApi" title="Televerser">
              <i class="bx bx-cloud-upload"></i> Televerser
            </button>
            <button type="button" class="hb-cam-btn icon" id="hbBackToGallery" title="Retour">
              <i class="bx bx-left-arrow-alt"></i>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="hb-hero hb-in">
    <div>
      <p class="title"><i class="bx bx-upload"></i> Televerser un nouveau fichier</p>
      <p class="sub">Choisissez votre document, puis enregistrez-le. Il apparaitra dans la galerie.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap justify-content-end">
      <span class="hb-chip"><i class="bx bx-lock-alt"></i> Espace famille</span>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-12 col-lg-7">
      <div class="hb-card hb-in">
        <div class="hb-card-header">
          <div class="left"><span class="hb-dot"></span> Details du document</div>
        </div>
        <div class="hb-card-body">
          {{ include('ModuleDocuments/FrontOffice/document/_form.html.twig') }}
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-5">
      <div class="card hb-side hb-in">
        <div class="card-body">
          <h6><i class="bx bx-bulb"></i> Conseils</h6>
          <ul>
            <li>Utilisez des noms de fichiers clairs.</li>
            <li>Les images et PDF sont bien previsualises.</li>
            <li>Vous pouvez masquer/supprimer plus tard.</li>
          </ul>

          <hr class="my-3">

          <h6><i class="bx bx-shield-quarter"></i> Confidentialite</h6>
          <ul>
            <li>Seule votre famille peut voir ce document.</li>
            <li>Aucun acces entre familles n'est possible.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  function hbInitCameraNewDoc(){
    const galleryId = {{ galleryId|json_encode|raw }};
    const apiUrl   = `/portal/documents/api/galleries/${galleryId}/camera-upload`;
    const backUrl  = {{ path('app_gallery_show', {'id': galleryId})|json_encode|raw }};

    const openBtn  = document.getElementById('hbOpenCam');
    const overlay  = document.getElementById('hbCamOverlay');
    const closeBtn = document.getElementById('hbCloseCam2');
    const retakeBtn= document.getElementById('hbRetake');
    const snapBtn  = document.getElementById('hbSnap');
    const recBtn   = document.getElementById('hbRec');
    const uploadBtn= document.getElementById('hbUploadApi');
    const backBtn  = document.getElementById('hbBackToGallery');

    const modePhotoBtn = document.getElementById('hbModePhoto');
    const modeVideoBtn = document.getElementById('hbModeVideo');

    const msg    = document.getElementById('hbApiMsg');
    const video  = document.getElementById('hbVideo');
    const canvas = document.getElementById('hbCanvas');
    const preview= document.getElementById('hbPreview');
    const vidPreview = document.getElementById('hbVidPreview');
    const flash  = document.getElementById('hbFlash');

    if(!openBtn || !overlay || !closeBtn || !video || !canvas || !snapBtn || !uploadBtn || !recBtn) return;
    if (openBtn.dataset.hbBound === "1") return;
    openBtn.dataset.hbBound = "1";

    const setMsg = (t) => { if (msg) msg.textContent = t; };
    const setDisabled = (el, disabled) => {
      if (!el) return;
      el.classList.toggle('hb-disabled', !!disabled);
      el.disabled = !!disabled;
    };

    let stream = null;
    let capturedBlob = null;
    let capturedType = null; // "image" | "video"
    let mode = "photo";

    // video recording
    let recorder = null;
    let recChunks = [];
    let isRecording = false;

    function showOverlay(){
      overlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
    }
    function hideOverlay(){
      overlay.style.display = 'none';
      document.body.style.overflow = '';
    }
    function stopCamera(){
      if (recorder && isRecording) {
        try { recorder.stop(); } catch(e) {}
      }
      if(stream){
        stream.getTracks().forEach(t => t.stop());
        stream = null;
      }
      video.srcObject = null;
    }
    function resetPreview(){
      capturedBlob = null;
      capturedType = null;

      if (preview) { preview.src = ""; preview.style.display = 'none'; }
      if (vidPreview) { vidPreview.pause(); vidPreview.src = ""; vidPreview.style.display = 'none'; }

      setDisabled(uploadBtn, true);
      setDisabled(retakeBtn, true);
    }

    function closeCamera(){
      stopCamera();
      resetPreview();
      setMsg('Fermee.');
      hideOverlay();
    }

    async function openCamera(){
      try{
        showOverlay();
        setMsg('Demande de permission camera...');
        resetPreview();

        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          setMsg('API camera indisponible dans ce navigateur.');
          alert('API camera indisponible. Utilisez HTTPS ou localhost sur un navigateur moderne.');
          closeCamera();
          return;
        }

        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'environment' }, width:{ideal:1280}, height:{ideal:720} },
          audio: true // âœ… Ù„Ø§Ø²Ù… Ù„Ù„ÙÙŠØ¯ÙŠÙˆ
        });

        video.srcObject = stream;

        video.onloadedmetadata = async () => {
          try { await video.play(); } catch(e) {}
          setMsg(mode === "photo" ? 'Pret. Appuyez pour capturer.' : 'Pret. Appuyez sur REC.');
        };
      } catch(e){
        console.error(e);
        setMsg(`Erreur camera: ${e?.name || ''} ${e?.message || ''}`);
        alert('Camera bloquee: utilisez localhost ou HTTPS et autorisez les permissions.');
        closeCamera();
      }
    }

    function doFlash(){
      if (!flash) return;
      flash.classList.remove('on');
      void flash.offsetWidth;
      flash.classList.add('on');
    }

    function takePhoto(){
      if(!video.videoWidth){ setMsg('Video non prete...'); return; }
      doFlash();

      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;

      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      ctx.drawImage(video, 0, 0);

      canvas.toBlob((b) => {
        if(!b){ setMsg('Echec de capture.'); return; }

        capturedBlob = b;
        capturedType = "image";

        if (preview) {
          preview.src = URL.createObjectURL(b);
          preview.style.display = 'block';
        }
        if (vidPreview) vidPreview.style.display = 'none';

        setDisabled(uploadBtn, false);
        setDisabled(retakeBtn, false);
        setMsg('Capture terminee. Televersez ou reprenez.');
      }, 'image/jpeg', 0.92);
    }

    function pickBestMime(){
      // prefer mp4 if supported, else webm
      const candidates = [
        'video/mp4;codecs=h264,aac',
        'video/mp4',
        'video/webm;codecs=vp9,opus',
        'video/webm;codecs=vp8,opus',
        'video/webm',
      ];
      for (const c of candidates) {
        if (window.MediaRecorder && MediaRecorder.isTypeSupported(c)) return c;
      }
      return '';
    }

    function startRecording(){
      if (!stream) { setMsg('Ouvrez d abord la camera.'); return; }
      if (!window.MediaRecorder) { setMsg('MediaRecorder n est pas supporte.'); return; }

      resetPreview();

      const mime = pickBestMime();
      recChunks = [];

      try {
        recorder = new MediaRecorder(stream, mime ? { mimeType: mime } : undefined);
      } catch (e) {
        console.error(e);
        setMsg('Echec d initialisation de l enregistreur.');
        return;
      }

      recorder.ondataavailable = (ev) => {
        if (ev.data && ev.data.size > 0) recChunks.push(ev.data);
      };

      recorder.onstop = () => {
        const type = recorder?.mimeType || mime || 'video/webm';
        const blob = new Blob(recChunks, { type });

        capturedBlob = blob;
        capturedType = "video";

        if (vidPreview) {
          vidPreview.src = URL.createObjectURL(blob);
          vidPreview.style.display = 'block';
        }
        if (preview) preview.style.display = 'none';

        setDisabled(uploadBtn, false);
        setDisabled(retakeBtn, false);
        setMsg('Video prete. Televersez ou reprenez.');
      };

      recorder.start();
      isRecording = true;
      recBtn.classList.add('recording');
      setMsg('Enregistrement... cliquez encore sur REC pour arreter.');
    }

    function stopRecording(){
      if (!recorder || !isRecording) return;
      try { recorder.stop(); } catch(e) {}
      isRecording = false;
      recBtn.classList.remove('recording');
      setMsg('Traitement de la video...');
    }

    function toggleRec(){
      if (mode !== "video") return;
      if (!isRecording) startRecording();
      else stopRecording();
    }

    function retake(){
      if (isRecording) stopRecording();
      resetPreview();
      setMsg(mode === "photo" ? 'Pret. Appuyez pour capturer.' : 'Pret. Appuyez sur REC.');
    }

    async function uploadToApi(){
      if(!capturedBlob || !capturedType){
        setMsg('Prenez une photo ou enregistrez une video d abord.');
        return;
      }

      setDisabled(uploadBtn, true);
      setMsg('Televersement...');

      let filename = '';
      let filetype = capturedBlob.type || (capturedType === "image" ? 'image/jpeg' : 'video/webm');

      if (capturedType === "image") {
        filename = `camera_${Date.now()}.jpg`;
      } else {
        // choose extension from mime
        const ext = filetype.includes('mp4') ? 'mp4' : (filetype.includes('quicktime') ? 'mov' : 'webm');
        filename = `video_${Date.now()}.${ext}`;
      }

      const fd = new FormData();
      fd.append('file', new File([capturedBlob], filename, { type: filetype }));

      const res = await fetch(apiUrl, {
        method: 'POST',
        body: fd,
        credentials: 'same-origin',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });

      const data = await res.json().catch(() => ({}));

      if(!res.ok || !data.ok){
        setMsg('Echec du televersement: ' + (data.error || ('HTTP ' + res.status)));
        setDisabled(uploadBtn, false);
        return;
      }

      setMsg('Televerse. Redirection...');
      closeCamera();
      window.location.href = backUrl;
    }

    function setMode(next){
      mode = next;

      // UI
      modePhotoBtn.classList.toggle('active', mode === "photo");
      modeVideoBtn.classList.toggle('active', mode === "video");

      // show correct center button
      snapBtn.style.display = (mode === "photo") ? '' : 'none';
      recBtn.style.display  = (mode === "video") ? '' : 'none';

      // stop recording if switching
      if (isRecording) stopRecording();
      resetPreview();
      setMsg(mode === "photo" ? 'Pret. Appuyez pour capturer.' : 'Pret. Appuyez sur REC.');
    }

    // events
    openBtn.addEventListener('click', openCamera);
    closeBtn.addEventListener('click', closeCamera);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeCamera(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.style.display === 'block') closeCamera();
    });

    snapBtn.addEventListener('click', () => { if (mode === "photo") takePhoto(); });
    recBtn.addEventListener('click', toggleRec);

    retakeBtn.addEventListener('click', retake);
    uploadBtn.addEventListener('click', uploadToApi);
    backBtn?.addEventListener('click', () => window.location.href = backUrl);

    modePhotoBtn.addEventListener('click', () => setMode("photo"));
    modeVideoBtn.addEventListener('click', () => setMode("video"));

    // stop camera when leaving page
    window.addEventListener('pagehide', stopCamera);

    // init
    setDisabled(uploadBtn, true);
    setDisabled(retakeBtn, true);
    setMode("photo");
  }

  document.addEventListener('DOMContentLoaded', hbInitCameraNewDoc);
  document.addEventListener('turbo:load', hbInitCameraNewDoc);
  window.addEventListener('pageshow', hbInitCameraNewDoc);
})();
</script>
{% endblock %}





