{% extends 'base.html.twig' %}

{% block title %}Galerie
{% endblock %}

{% block body %}
	<h1>Galerie</h1>

	<div class="gallery">
		{% for document in documents %}
			{% if document.fileType starts with 'image/' %}
				<div class="gallery-item">
					<img src="{{ asset(document.filePath) }}" alt="{{ document.fileName }}">
				</div>
				<a href="{{ path('app_document_show', {'id': document.id, 'galleryId': document.gallery.id}) }}">afficher</a>
				<a href="{{ path('app_document_edit', {'id': document.id, 'galleryId': document.gallery.id}) }}">modifier</a>
			{% endif %}
		{% else %}
			<p>Aucune image trouvee.</p>
		{% endfor %}
	</div>



	<style>
		/* style simple type galerie tÃ©lÃ©phone */
		.gallery {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
		}

		.gallery-item {
			width: 120px; /* largeur des images */
			height: 120px; /* hauteur fixe */
			overflow: hidden;
			border-radius: 8px;
			box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
		}

		.gallery-item img {
			width: 100%;
			height: 100%;
			object-fit: cover; /* recadre l'image pour remplir la div */
		}
	</style>
{% endblock %}


