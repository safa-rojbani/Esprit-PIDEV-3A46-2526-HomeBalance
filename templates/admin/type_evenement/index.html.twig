{% extends 'base_back.html.twig' %}

{% block title %}Event Types (Admin){% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-semibold m-0">Event Types (Admin)</h4>
  <a href="{{ path('admin_type_evenement_new') }}" class="btn btn-primary">
    + Add Type
  </a>
</div>

<div class="card">
  <div class="table-responsive text-nowrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Color</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
      {% for t in type_evenements %}
        <tr>
          <td>{{ t.id }}</td>
          <td class="fw-semibold">{{ t.nom }}</td>
          <td>{{ t.couleur }}</td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-info"
               href="{{ path('admin_type_evenement_show', { id: t.id }) }}">
              View
            </a>
            <a class="btn btn-sm btn-outline-warning"
               href="{{ path('admin_type_evenement_edit', { id: t.id }) }}">
              Edit
            </a>
            <form method="post"
                  action="{{ path('admin_type_evenement_delete', { id: t.id }) }}"
                  style="display:inline-block"
                  onsubmit="return confirm('Delete this type?');">
              <input type="hidden" name="_token"
                     value="{{ csrf_token('delete' ~ t.id) }}">
              <button class="btn btn-sm btn-outline-danger">
                Delete
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="4" class="text-center text-muted">
            No types found
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
