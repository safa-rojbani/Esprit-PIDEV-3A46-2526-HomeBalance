{% extends 'base_back.html.twig' %}

{% block title %}Event Type{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-semibold m-0">Event Type Details</h4>
  <a href="{{ path('admin_type_evenement_index') }}" class="btn btn-outline-secondary">
    Back
  </a>
</div>

<div class="card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Name</dt>
      <dd class="col-sm-9">{{ type_evenement.nom }}</dd>
      <dt class="col-sm-3">Color</dt>
      <dd class="col-sm-9">{{ type_evenement.couleur }}</dd>
      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9">{{ type_evenement.description }}</dd>
    </dl>
  </div>
</div>
{% endblock %}
