<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{ subject|default('HomeBalance update') }}</title>
    <style>
      body { font-family: Arial, sans-serif; background: #f7f7f7; margin: 0; padding: 0; }
      .container { max-width: 600px; margin: 24px auto; background: #ffffff; border-radius: 8px; padding: 24px; }
      .brand { font-weight: bold; font-size: 20px; margin-bottom: 16px; color: #2d2d2d; }
      .cta { display: inline-block; padding: 12px 18px; background: #0d6efd; color: #ffffff; text-decoration: none; border-radius: 6px; }
      .muted { color: #6c757d; font-size: 13px; }
      .footer { margin-top: 24px; font-size: 12px; color: #8a8a8a; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="brand">HomeBalance</div>
      {% block body %}{% endblock %}
      <div class="footer">If you did not request this, you can ignore this email.</div>
    </div>
  </body>
</html>
