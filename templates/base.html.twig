<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}HomeBalance{% endblock %}</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">

    <style>
      :root{
        --hb-bg:#f5f5f9;
        --hb-surface:#ffffff;
        --hb-border:rgba(67,89,113,.14);
        --hb-text:#2b2f36;
        --hb-muted:#7a8699;
        --hb-accent:#696cff;
        --hb-shadow:0 12px 30px rgba(67,89,113,.12);
      }

      *{box-sizing:border-box}
      body{
        margin:0;
        background:var(--hb-bg);
        color:var(--hb-text);
        font-family:Manrope,system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
      }

      .layout-wrapper{min-height:100vh}
      .layout-container{
        min-height:100vh;
        display:flex;
        align-items:stretch;
      }

      .layout-menu{
        width:280px;
        flex:0 0 280px;
        background:var(--hb-surface);
        border-right:1px solid var(--hb-border);
        box-shadow:var(--hb-shadow);
        overflow-y:auto;
        z-index:1035;
      }

      .app-brand{
        height:74px;
        display:flex;
        align-items:center;
        padding:0 16px;
        border-bottom:1px solid var(--hb-border);
      }
      .app-brand-link{
        display:flex;
        align-items:center;
        gap:10px;
        text-decoration:none;
        color:var(--hb-text);
        min-width:0;
      }
      .app-brand-text{
        white-space:nowrap;
        overflow:hidden;
        text-overflow:ellipsis;
      }

      .menu-inner{
        list-style:none;
        margin:0;
        padding:10px 10px 20px;
      }
      .menu-item{margin:2px 0}
      .menu-header{
        list-style:none;
        color:var(--hb-muted);
        font-size:.74rem;
        font-weight:800;
        letter-spacing:.05em;
        padding:14px 10px 6px;
        text-transform:uppercase;
      }
      .menu-link{
        display:flex;
        align-items:center;
        gap:10px;
        border-radius:12px;
        padding:.62rem .72rem;
        color:#566a7f;
        text-decoration:none;
        transition:.14s ease;
      }
      .menu-link:hover{background:rgba(67,89,113,.08);color:#3e4755}
      .menu-item.active > .menu-link{
        background:linear-gradient(135deg,rgba(105,108,255,.18),rgba(105,108,255,.08));
        color:#2f325f;
        font-weight:700;
      }
      .menu-icon{font-size:1.15rem}
      .menu-toggle::after{
        content:"\ea4a";
        font-family:boxicons!important;
        margin-left:auto;
        opacity:.65;
        transition:transform .16s ease;
      }
      .menu-item.open > .menu-link.menu-toggle::after{transform:rotate(90deg)}
      .menu-sub{
        list-style:none;
        margin:4px 0 6px 0;
        padding:0 0 0 34px;
        display:none;
      }
      .menu-item.open > .menu-sub{display:block}
      .menu-sub .menu-link{padding:.48rem .58rem}
      .menu-sub .menu-item.active > .menu-link{
        background:rgba(105,108,255,.10);
        color:#2f325f;
        font-weight:700;
      }

      .layout-page{
        flex:1 1 auto;
        min-width:0;
        display:flex;
        flex-direction:column;
      }
      .layout-navbar{
        position:sticky;
        top:0;
        z-index:1030;
        margin:12px 16px 0;
        border-radius:14px;
        border:1px solid var(--hb-border);
        background:rgba(255,255,255,.94);
        box-shadow:0 8px 20px rgba(67,89,113,.10);
        backdrop-filter:blur(10px);
      }
      .content-wrapper{flex:1 1 auto;min-height:0}
      .container-p-y{padding-top:1.2rem;padding-bottom:1.2rem}

      .layout-overlay{
        display:none;
        position:fixed;
        inset:0;
        background:rgba(17,21,30,.35);
        z-index:1032;
      }
      .layout-overlay.show{display:block}

      @media (max-width: 1199.98px){
        .layout-menu{
          position:fixed;
          top:0;
          left:0;
          bottom:0;
          transform:translateX(-100%);
          transition:transform .22s ease;
        }
        body.menu-open .layout-menu{transform:translateX(0)}
        body.menu-open .layout-overlay{display:block}
        .layout-navbar{margin:10px}
      }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>

<body>

<div class="layout-wrapper layout-content-navbar">
  <div class="layout-container">

    {% set route = app.request.attributes.get('_route') %}
    {% set active_menu = active_menu|default(
      (route starts with 'app_evenement'
        or route starts with 'app_rappel'
        or route starts with 'app_type_evenement'
        or route starts with 'app_calendar'
        or route starts with 'app_notifications') ? 'module-events'
      : (route starts with 'app_gallery'
        or route starts with 'app_document'
        or route starts with 'app_default_gallery') ? 'module-documents'
      : (route starts with 'app_achat'
        or route starts with 'app_revenu'
        or route starts with 'app_historique_achat'
        or route starts with 'app_categorie_achat') ? 'module-charge'
      : (route starts with 'parent_task'
        or route starts with 'child_task'
        or route starts with 'family_task'
        or route starts with 'parent_validation'
        or route starts with 'admin_task') ? 'module-tasks'
      : 'dashboard'
    ) %}
    {% set module_submenus = module_submenus|default({
      'module-charge': [
        {'label': 'Achats', 'route': 'app_achat_index'},
        {'label': 'Historique', 'route': 'app_historique_achat_index'},
        {'label': 'Revenus', 'route': 'app_revenu_index'},
        {'label': 'Budget', 'route': 'app_revenu_budget'}
      ],
      'module-documents': [
        {'label': 'Galeries', 'route': 'app_gallery_index'},
        {'label': 'Galeries masquées', 'route': 'app_gallery_hidden'},
        {'label': 'Corbeille', 'route': 'app_document_trash'}
      ],
      'module-tasks': [
        {'label': 'Tâches parent', 'route': 'parent_task_index'},
        {'label': 'Tâches enfant', 'route': 'child_task_index'},
        {'label': 'Tâches famille', 'route': 'family_task_list'},
        {'label': 'Validations', 'route': 'parent_validation_index'}
      ],
      'module-events': [
        {'label': 'Événements', 'route': 'app_evenement_index'},
        {'label': 'Types d\'événements', 'route': 'app_type_evenement_index'},
        {'label': 'Rappels', 'route': 'app_rappel_history'},
        {'label': 'Calendrier', 'route': 'app_calendar'}
      ]
    }) %}
    {% if is_granted('ROLE_ADMIN') %}
      {% set module_submenus = module_submenus|merge({
        'module-documents': [
          {'label': 'Default galleries', 'route': 'app_default_gallery_index'}
        ]
      }) %}
    {% endif %}

    {% include 'ui_portal/partials/sidebar.html.twig' with { active_menu: active_menu, module_submenus: module_submenus } %}

    <div class="layout-page">
      <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme">
        <div class="navbar-nav-right d-flex align-items-center w-100">
          <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
            <a class="nav-item nav-link px-0 me-xl-6" href="#layout-menu" aria-label="Toggle navigation">
              <i class="bx bx-menu bx-md"></i>
            </a>
          </div>

          <div class="navbar-nav align-items-center">
            <div class="nav-item d-flex align-items-center">
              <i class="bx bx-search fs-4 lh-0 me-2"></i>
              <input class="form-control border-0 shadow-none" placeholder="Rechercher (placeholder)" />
            </div>
          </div>

          <div class="navbar-nav flex-row align-items-center ms-auto">
            <span class="text-muted small">HomeBalance</span>
          </div>
        </div>
      </nav>

      <div class="content-wrapper">
        <div class="container-xxl flex-grow-1 container-p-y">

          {% block body %}
            {% block content %}{% endblock %}
          {% endblock %}

        </div>
        <div class="content-backdrop fade"></div>
      </div>
    </div>

  </div>
</div>
<div class="layout-overlay layout-menu-toggle"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  (function () {
    document.querySelectorAll('.menu-item.open').forEach(function (item) {
      item.classList.add('open');
    });

    document.addEventListener('click', function (event) {
      var toggle = event.target.closest('.menu-toggle');
      if (toggle) {
        event.preventDefault();
        var item = toggle.closest('.menu-item');
        if (item) {
          item.classList.toggle('open');
        }
      }

      var mobileToggle = event.target.closest('.layout-menu-toggle a[href="#layout-menu"]');
      if (mobileToggle) {
        event.preventDefault();
        document.body.classList.toggle('menu-open');
      }

      if (event.target.classList.contains('layout-overlay')) {
        document.body.classList.remove('menu-open');
      }
    });
  })();
</script>

</body>
</html>
