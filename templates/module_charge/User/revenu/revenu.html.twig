{% extends 'module_charge/layout/base.html.twig' %}

{% block title %}Budget{% endblock %}
{% block page_title %}Budget{% endblock %}

{% block body %}
<div class="container mt-4">
  <div class="row g-3">
    <div class="col-md-4">
      <div class="card p-3">
        <div class="text-muted">Total Revenus</div>
        <div class="fs-3 fw-bold">{{ totalRevenus }} TND</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-3">
        <div class="text-muted">Total Dépenses</div>
        <div class="fs-3 fw-bold">{{ totalDepenses }} TND</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-3">
        <div class="text-muted">Solde</div>
        <div class="fs-3 fw-bold">{{ solde }} TND</div>
      </div>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <a href="{{ path('app_revenu_index') }}" class="btn btn-outline-secondary">← Revenus</a>
    <a href="{{ path('app_revenu_new') }}" class="btn btn-primary">+ Ajouter un revenu</a>
  </div>
</div>
{% endblock %}
