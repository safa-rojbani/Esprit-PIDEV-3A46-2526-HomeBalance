{% extends 'module_charge/layout/base.html.twig' %}
{% block title %}Nouveau revenu{% endblock %}
{% block page_title %}Nouveau revenu{% endblock %}

{% block body %}
<div class="container mt-4">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <a href="{{ path('app_revenu_index') }}" class="text-decoration-none">Revenus</a>
      </li>
      <li class="breadcrumb-item active" aria-current="page">Nouveau revenu</li>
    </ol>
  </nav>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body text-center py-4">
          <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-flex mb-3">
            <i class="bi bi-plus-circle text-primary fs-1"></i>
          </div>
          <h3 class="fw-bold mb-2">Ajouter un nouveau revenu</h3>
          <p class="text-muted mb-0">Enregistrez une nouvelle source de revenu dans votre budget</p>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light border-bottom py-3">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-pencil-square me-2"></i>Informations du revenu
          </h5>
        </div>

        <div class="card-body p-4">
          {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

          {% if form.vars.errors|length %}
            <div class="alert alert-danger">
              {{ form_errors(form) }}
            </div>
          {% endif %}

          <div class="row">
            <div class="col-12 mb-4">
              <label class="form-label fw-semibold">
                <i class="bi bi-tag me-1"></i>Type de revenu <span class="text-danger">*</span>
              </label>

              {{ form_widget(form.typeRevenu, {'attr': {
                'class': 'form-select form-select-lg ' ~ (form.typeRevenu.vars.errors|length ? 'is-invalid' : '')
              }}) }}
              {% if form.typeRevenu.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">
                  {{ form_errors(form.typeRevenu) }}
                </div>
              {% endif %}

              <label class="form-label small fw-semibold mt-3 mb-2">
                <i class="bi bi-plus-circle me-1"></i>Ou creer un nouveau type
              </label>
              {{ form_widget(form.typeRevenuLibre, {'attr': {
                'class': 'form-control form-control-lg ' ~ (form.typeRevenuLibre.vars.errors|length ? 'is-invalid' : ''),
                'placeholder': 'Ex: Freelance, Prime annuelle, Dividendes...'
              }}) }}
              {% if form.typeRevenuLibre.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">
                  {{ form_errors(form.typeRevenuLibre) }}
                </div>
              {% endif %}

              <div class="form-text">
                Choisissez un type existant ou saisissez un nouveau type.
              </div>
            </div>

            <div class="col-md-6 mb-4">
              <label class="form-label fw-semibold">
                <i class="bi bi-cash-stack me-1"></i>Montant <span class="text-danger">*</span>
              </label>

              <div class="input-group input-group-lg">
                {{ form_widget(form.montant, {'attr': {
                  'class': 'form-control ' ~ (form.montant.vars.errors|length ? 'is-invalid' : ''),
                  'placeholder': '0.00',
                  'step': '0.01',
                  'min': '0'
                }}) }}
                <span class="input-group-text bg-light fw-semibold">TND</span>
              </div>

              {% if form.montant.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">
                  {{ form_errors(form.montant) }}
                </div>
              {% endif %}
            </div>

            <div class="col-md-6 mb-4">
              <label class="form-label fw-semibold">
                <i class="bi bi-calendar-event me-1"></i>Date du revenu <span class="text-danger">*</span>
              </label>

              {{ form_widget(form.dateRevenu, {'attr': {
                'class': 'form-control form-control-lg ' ~ (form.dateRevenu.vars.errors|length ? 'is-invalid' : '')
              }}) }}

              {% if form.dateRevenu.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">
                  {{ form_errors(form.dateRevenu) }}
                </div>
              {% endif %}
            </div>
          </div>

          <div class="d-flex gap-2 justify-content-end pt-3 border-top">
            <a href="{{ path('app_revenu_index') }}" class="btn btn-lg btn-light">
              <i class="bi bi-x-circle me-1"></i>Annuler
            </a>
            <button type="submit" class="btn btn-lg btn-primary">
              <i class="bi bi-check-circle me-1"></i>Enregistrer le revenu
            </button>
          </div>

          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .form-control:focus, .form-select:focus {
    border-color: #0d6efd;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
  }
</style>
{% endblock %}
