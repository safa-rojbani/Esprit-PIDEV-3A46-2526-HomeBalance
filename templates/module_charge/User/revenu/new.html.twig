{% extends 'module_charge/layout/base.html.twig' %}
{% block title %}Nouveau revenu{% endblock %}
{% block page_title %}Nouveau revenu{% endblock %}

{% block body %}
<div class="container py-4 revenu-new-page">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item">
        <a href="{{ path('app_revenu_index') }}" class="text-decoration-none">Revenus</a>
      </li>
      <li class="breadcrumb-item active" aria-current="page">Nouveau revenu</li>
    </ol>
  </nav>

  <div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
      <section class="hero-card mb-4">
        <div class="hero-icon">
          <i class="bi bi-wallet2"></i>
        </div>
        <div>
          <h2 class="hero-title mb-1">Ajouter un nouveau revenu</h2>
          <p class="hero-subtitle mb-0">Enregistrez une source de revenu dans votre budget familial.</p>
        </div>
      </section>

      <section class="form-shell">
        <div class="form-shell-head">
          <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis px-3 py-2">
            <i class="bi bi-pencil-square me-1"></i> Informations du revenu
          </span>
        </div>

        <div class="form-shell-body">
          {{ form_start(form, {
            action: path('app_revenu_new'),
            method: 'POST',
            attr: {
              class: 'revenu-form',
              novalidate: 'novalidate',
              'data-turbo': 'false'
            }
          }) }}

          {% if form.vars.errors|length %}
            <div class="alert alert-danger mb-4">
              {{ form_errors(form) }}
            </div>
          {% endif %}

          <div class="row g-4">
            <div class="col-12">
              <label class="field-label">
                <i class="bi bi-tag me-1"></i> Type de revenu <span class="text-danger">*</span>
              </label>
              {{ form_widget(form.typeRevenu, {'attr': {
                'class': 'form-select form-select-lg ' ~ (form.typeRevenu.vars.errors|length ? 'is-invalid' : '')
              }}) }}
              {% if form.typeRevenu.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">{{ form_errors(form.typeRevenu) }}</div>
              {% endif %}
              <div class="mt-3">
                <label class="field-label small mb-2">
                  <i class="bi bi-plus-circle me-1"></i> Nouveau type (si besoin)
                </label>
                {{ form_widget(form.typeRevenuLibre, {'attr': {
                  'class': 'form-control form-control-lg ' ~ (form.typeRevenuLibre.vars.errors|length ? 'is-invalid' : '')
                }}) }}
                {% if form.typeRevenuLibre.vars.errors|length %}
                  <div class="invalid-feedback d-block mt-1">{{ form_errors(form.typeRevenuLibre) }}</div>
                {% endif %}
              </div>
              <div class="form-text">Choisis un type admin dans la liste ou saisis ton propre type.</div>
            </div>

            <div class="col-md-6">
              <label class="field-label">
                <i class="bi bi-cash-coin me-1"></i> Montant <span class="text-danger">*</span>
              </label>
              <div class="input-group input-group-lg money-group">
                {{ form_widget(form.montant, {'attr': {
                  'class': 'form-control ' ~ (form.montant.vars.errors|length ? 'is-invalid' : ''),
                  'placeholder': '0.00',
                  'step': '0.01',
                  'min': '0.01'
                }}) }}
                <span class="input-group-text">TND</span>
              </div>
              {% if form.montant.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">{{ form_errors(form.montant) }}</div>
              {% endif %}
            </div>

            <div class="col-md-6">
              <label class="field-label">
                <i class="bi bi-calendar-event me-1"></i> Date du revenu <span class="text-danger">*</span>
              </label>
              {{ form_widget(form.dateRevenu, {'attr': {
                'class': 'form-control form-control-lg ' ~ (form.dateRevenu.vars.errors|length ? 'is-invalid' : '')
              }}) }}
              {% if form.dateRevenu.vars.errors|length %}
                <div class="invalid-feedback d-block mt-1">{{ form_errors(form.dateRevenu) }}</div>
              {% endif %}
            </div>
          </div>

          <div class="actions mt-4 pt-3">
            <a href="{{ path('app_revenu_index') }}" class="btn btn-cancel">
              <i class="bi bi-arrow-left-circle me-1"></i> Retour
            </a>
            <button type="submit" class="btn btn-save">
              <i class="bi bi-check-circle me-1"></i> Enregistrer le revenu
            </button>
          </div>

          {{ form_end(form) }}
        </div>
      </section>
    </div>
  </div>
</div>

<style>
  .revenu-new-page {
    --hb-primary: #1769e0;
    --hb-ink: #12263a;
    --hb-muted: #66768f;
    --hb-surface: #ffffff;
    --hb-line: #dbe4f0;
  }

  .hero-card {
    display: flex;
    gap: 16px;
    align-items: center;
    padding: 22px;
    border-radius: 20px;
    background:
      radial-gradient(90% 120% at 0% 0%, #e8f1ff 0%, transparent 75%),
      linear-gradient(140deg, #ffffff 0%, #f5f9ff 100%);
    border: 1px solid #d7e5fb;
    box-shadow: 0 12px 30px rgba(17, 78, 153, 0.08);
  }

  .hero-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: linear-gradient(135deg, #1e88e5, #1565c0);
    font-size: 1.4rem;
  }

  .hero-title {
    margin: 0;
    color: var(--hb-ink);
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    color: var(--hb-muted);
  }

  .form-shell {
    border-radius: 20px;
    border: 1px solid var(--hb-line);
    background: var(--hb-surface);
    overflow: hidden;
    box-shadow: 0 16px 36px rgba(10, 35, 66, 0.08);
  }

  .form-shell-head {
    padding: 18px 24px;
    border-bottom: 1px solid #edf2f8;
    background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  }

  .form-shell-body {
    padding: 24px;
  }

  .field-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 700;
    color: #1f334a;
  }

  .revenu-form .form-control,
  .revenu-form .form-select {
    border-radius: 12px;
    border-color: #cfd9e6;
  }

  .revenu-form .form-control:focus,
  .revenu-form .form-select:focus {
    border-color: #74a7f5;
    box-shadow: 0 0 0 0.24rem rgba(23, 105, 224, 0.16);
  }

  .money-group .input-group-text {
    border-radius: 0 12px 12px 0;
    border-color: #cfd9e6;
    background: #f4f8ff;
    font-weight: 700;
    color: #385172;
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    border-top: 1px solid #edf2f8;
  }

  .btn-cancel {
    border: 1px solid #d4deea;
    border-radius: 12px;
    padding: 10px 16px;
    background: #fff;
    color: #304764;
    font-weight: 600;
  }

  .btn-cancel:hover {
    background: #f5f8fc;
    color: #1f334a;
  }

  .btn-save {
    border: 0;
    border-radius: 12px;
    padding: 10px 18px;
    background: linear-gradient(135deg, #1e7ce9 0%, #1462c5 100%);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(20, 98, 197, 0.25);
  }

  .btn-save:hover {
    color: #fff;
    filter: brightness(1.02);
  }

  @media (max-width: 768px) {
    .form-shell-body {
      padding: 18px;
    }

    .actions {
      flex-direction: column-reverse;
    }

    .actions .btn {
      width: 100%;
    }
  }
</style>
{% endblock %}
