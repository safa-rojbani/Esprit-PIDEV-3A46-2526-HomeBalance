{% extends 'module_charge/layout/base.html.twig' %}

{% block title %}Historique des achats{% endblock %}
{% block page_title %}Historique des achats{% endblock %}

{% block body %}
<div class="container mt-4">

  {# Header moderne #}
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
    <div>
      <h2 class="fw-bold mb-1">Historique</h2>
      <div class="text-muted" style="font-size:.95rem;">
        Liste des achats confirmés (montant + quantité + date).
      </div>
    </div>

    <a href="{{ path('app_achat_index') }}" class="btn-modern btn-modern-secondary">
      <i class="bi bi-arrow-left"></i>
      <span>Retour aux achats</span>
    </a>
  </div>

  {# Card #}
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3 px-4">
      <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">

        <div class="d-flex align-items-center gap-2">
          <span class="text-muted" style="font-size:.95rem;">Total</span>
          <span class="badge-modern">{{ historique_achats|length }}</span>
        </div>

        <div class="input-group" style="max-width: 360px;">
          <span class="input-group-text bg-light border-0">
            <i class="bi bi-search"></i>
          </span>
          <input id="histSearch" type="text"
                 class="form-control bg-light border-0"
                 placeholder="Rechercher (article, montant...)"
                 autocomplete="off">
        </div>

      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            {# ✅ ID supprimé #}
            <th>Article</th>
            <th style="width:170px;">Montant</th>
            <th style="width:130px;">Quantité</th>
            <th style="width:190px;">Date</th>
            <th class="text-end pe-4" style="width:260px;">Actions</th>
          </tr>
        </thead>

        <tbody id="histTable">
        {% for historique_achat in historique_achats %}
          <tr class="achat-row">
            <td class="ps-4">
              <div class="d-flex align-items-center gap-3">
                {# Icône #}
                <div class="article-icon article-icon-success">
                  <i class="bi bi-receipt"></i>
                </div>

                <div>
                  <div class="fw-semibold hist-name">
                    {{ historique_achat.achat ? historique_achat.achat.nomArticle : '—' }}
                  </div>

                  <div class="text-muted" style="font-size:.85rem;">
                    <i class="bi bi-credit-card"></i>
                    {% if historique_achat.paidBy %}
                      Payé
                    {% else %}
                      —
                    {% endif %}
                  </div>
                </div>
              </div>
            </td>

            <td>
              <div class="fw-bold">
                {{ historique_achat.montantAchete }} <span class="text-muted fw-normal">TND</span>
              </div>

              {# Bonus : total si quantité > 1 #}
              {% set qte = historique_achat.quantiteAchete ?? 1 %}
              {% if qte > 1 %}
                <div class="text-muted" style="font-size:.85rem;">
                  Total: {{ (historique_achat.montantAchete * qte)|number_format(2, '.', '') }} TND
                </div>
              {% endif %}
            </td>

            <td>
              <span class="status-badge status-badge-pending">
                <i class="bi bi-box"></i>
                {{ historique_achat.quantiteAchete ?? 1 }}
              </span>
            </td>

            <td>
              <div class="text-muted" style="font-size:.9rem;">
                <i class="bi bi-calendar3"></i>
                {{ historique_achat.dateAchat ? historique_achat.dateAchat|date('d/m/Y') : '—' }}
              </div>
              <div class="text-muted" style="font-size:.8rem;">
                {{ historique_achat.dateAchat ? historique_achat.dateAchat|date('H:i') : '' }}
              </div>
            </td>

            <td class="text-end pe-4">
              <div class="d-flex gap-2 justify-content-end flex-wrap">

                <a href="{{ path('app_historique_achat_show', {'id': historique_achat.id}) }}"
                   class="btn-modern btn-modern-info btn-modern-sm"
                   data-bs-toggle="tooltip"
                   title="Voir les détails">
                  <i class="bi bi-eye"></i>
                  <span>Voir</span>
                </a>

                <form method="post"
                      action="{{ path('app_historique_achat_delete', {'id': historique_achat.id}) }}"
                      class="form-delete"
                      data-hist-name="{{ historique_achat.achat ? historique_achat.achat.nomArticle : 'cet achat' }}"
                      style="display:inline-block;">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ historique_achat.id) }}">
                  <button class="btn-modern btn-modern-danger btn-modern-sm"
                          data-bs-toggle="tooltip"
                          title="Supprimer">
                    <i class="bi bi-trash"></i>
                    <span>Supprimer</span>
                  </button>
                </form>

              </div>
            </td>
          </tr>

        {% else %}
          <tr>
            <td colspan="5" class="text-center py-5">
              <div class="d-flex flex-column align-items-center gap-3 py-4">
                <div class="empty-state-icon">
                  <i class="bi bi-receipt"></i>
                </div>
                <div>
                  <div class="fw-bold fs-5 mb-1">Aucun historique trouvé</div>
                  <div class="text-muted" style="max-width: 420px;">
                    Confirme un achat pour qu’il apparaisse ici dans l’historique.
                  </div>
                </div>
                <a href="{{ path('app_achat_index') }}" class="btn-modern btn-modern-primary mt-2">
                  <i class="bi bi-cart"></i>
                  <span>Aller aux achats</span>
                </a>
              </div>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // tooltips
  const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  tooltipTriggerList.map(el => new bootstrap.Tooltip(el));

  // search
  const input = document.getElementById('histSearch');
  const rows = Array.from(document.querySelectorAll('#histTable tr'));
  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      rows.forEach(r => {
        r.style.display = r.innerText.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  }

  // confirm delete
  document.querySelectorAll('.form-delete').forEach(form => {
    form.addEventListener('submit', function(e) {
      const name = this.dataset.histName;
      if (!confirm(`Supprimer l'historique de "${name}" ?\n\nCette action est irréversible.`)) {
        e.preventDefault();
      }
    });
  });
});
</script>

{# Styles (même palette que tes achats) #}
<style>
  .badge-modern {
    display:inline-flex;align-items:center;justify-content:center;
    padding:6px 16px;font-size:14px;font-weight:700;
    background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
    color:#fff;border-radius:20px;
    box-shadow:0 4px 12px rgba(102,126,234,.25);
  }

  .achat-row{transition:all .25s ease;}
  .achat-row:hover{
    background:linear-gradient(90deg, rgba(102,126,234,.03) 0%, rgba(118,75,162,.03) 100%);
    transform:translateX(4px);
  }

  .article-icon{
    width:40px;height:40px;border-radius:10px;
    display:flex;align-items:center;justify-content:center;
    font-size:18px;flex-shrink:0;
  }
  .article-icon-success{
    background:linear-gradient(135deg,#10b981 0%,#059669 100%);
    color:#fff;
  }

  .status-badge{
    display:inline-flex;align-items:center;gap:6px;
    padding:6px 12px;border-radius:12px;
    font-size:13px;font-weight:600;
  }
  .status-badge-pending{background:#fef3c7;color:#92400e;}
  .status-badge i{font-size:12px;}

  .btn-modern{
    display:inline-flex;align-items:center;gap:8px;
    padding:10px 18px;font-size:14px;font-weight:600;
    border:none;border-radius:12px;cursor:pointer;
    transition:all .2s ease;text-decoration:none;
  }
  .btn-modern-sm{padding:8px 14px;font-size:13px;}
  .btn-modern i{font-size:16px;}
  .btn-modern-sm i{font-size:14px;}
  .btn-modern:hover{transform:translateY(-1px);filter:brightness(1.02);}

  .btn-modern-primary{
    background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
    color:#fff; box-shadow:0 4px 15px rgba(102,126,234,.3);
  }
  .btn-modern-primary:hover{color:#fff;}

  .btn-modern-info{
    background:linear-gradient(135deg,#0ea5e9 0%,#06b6d4 100%);
    color:#fff; box-shadow:0 4px 15px rgba(14,165,233,.25);
  }
  .btn-modern-info:hover{color:#fff;}

  .btn-modern-secondary{
    background:#f3f4f6;color:#374151;
  }
  .btn-modern-secondary:hover{background:#e5e7eb;color:#1f2937;}

  .btn-modern-danger{
    background:linear-gradient(135deg,#ef4444 0%,#dc2626 100%);
    color:#fff; box-shadow:0 4px 15px rgba(239,68,68,.25);
  }
  .btn-modern-danger:hover{color:#fff;}

  .empty-state-icon{
    width:80px;height:80px;border-radius:50%;
    background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 8px 24px rgba(102,126,234,.3);
  }
  .empty-state-icon i{font-size:36px;color:#fff;}

  @media (max-width:768px){
    .btn-modern span{display:none;}
    .btn-modern, .btn-modern-sm{padding:10px 14px;}
  }
</style>
{% endblock %}
