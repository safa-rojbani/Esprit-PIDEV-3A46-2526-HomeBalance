{% extends 'module_charge/layout/base.html.twig' %}

{% block title %}Liste des Achats{% endblock %}
{% block page_title %}Liste des Achats{% endblock %}

{% block body %}
<div class="container mt-4">

    {# Header #}
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <h2 class="fw-bold mb-1">Mes Achats</h2>
            <div class="text-muted" style="font-size:.95rem;">
                Gère ta liste de courses et tes achats quotidiens.
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="button" class="btn-modern btn-modern-primary"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#offcanvasNewAchat"
                    aria-controls="offcanvasNewAchat">
                <i class="bi bi-plus-circle"></i>
                <span>Nouvel achat</span>
            </button>
        </div>
    </div>

    {# Card #}
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3 px-4">
            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap achat-header-row">
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted" style="font-size:.95rem;">Total</span>
                    <span class="badge-modern">{{ achats.getTotalItemCount }}</span>
                </div>

                {# Statistiques rapides #}
                <div class="d-flex gap-3">
                    {% set achetes = achats|filter(a => a.estAchete)|length %}
                    {% set nonAchetes = achats|length - achetes %}
                    
                    <div class="stat-pill stat-pill-success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>{{ achetes }} acheté{{ achetes > 1 ? 's' : '' }}</span>
                    </div>
                    
                    <div class="stat-pill stat-pill-warning">
                        <i class="bi bi-clock-fill"></i>
                        <span>{{ nonAchetes }} en attente</span>
                    </div>
                </div>

                <form method="get" action="{{ path('app_achat_index') }}" class="d-flex align-items-center gap-2 flex-wrap achat-filter-form">
                    <div class="input-group" style="min-width: 240px;">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input name="q" type="text" class="form-control border-start-0 bg-light"
                               placeholder="Rechercher un achat..."
                               value="{{ searchQuery|default('') }}"
                               autocomplete="off">
                    </div>

                    <input type="month"
                           name="month"
                           class="form-control bg-light"
                           style="min-width: 150px;"
                           value="{{ selectedMonth|default('') }}">

                    <select name="category" class="form-select bg-light" style="min-width: 170px;">
                        <option value="">Toutes catégories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {{ selectedCategoryId is same as(category.id) ? 'selected' : '' }}>
                                {{ category.nomCategorie }}
                            </option>
                        {% endfor %}
                    </select>

                    <select name="limit" class="form-select bg-light" style="min-width: 110px;">
                        <option value="10" {{ selectedLimit == 10 ? 'selected' : '' }}>10/page</option>
                        <option value="20" {{ selectedLimit == 20 ? 'selected' : '' }}>20/page</option>
                    </select>

                    <button type="submit" class="btn-modern btn-modern-primary btn-modern-sm">
                        <i class="bi bi-funnel"></i>
                        <span>Filtrer</span>
                    </button>
                    <a href="{{ path('app_achat_index') }}" class="btn-modern btn-modern-secondary btn-modern-sm">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        <span>Réinitialiser</span>
                    </a>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Article</th>
                        <th style="width:120px;">Statut</th>
                        <th style="width:180px;">Date</th>
                        <th class="text-end pe-4" style="width:400px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="achatTable">
                {% for achat in achats %}
                    <tr class="achat-row">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                {# Icône de l'article #}
                                <div class="article-icon {% if achat.estAchete %}article-icon-success{% else %}article-icon-pending{% endif %}">
                                    <i class="bi {% if achat.estAchete %}bi-check2{% else %}bi-cart{% endif %}"></i>
                                </div>
                                
                                <div>
                                    <div class="fw-semibold article-name">{{ achat.nomArticle }}</div>
                                    {% if achat.categorie %}
                                        <div class="text-muted" style="font-size:.85rem;">
                                            <i class="bi bi-tag"></i> {{ achat.categorie.nomCategorie }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        
                        <td>
                            {% if achat.estAchete %}
                                <span class="status-badge status-badge-success">
                                    <i class="bi bi-check-circle-fill"></i>
                                    Acheté
                                </span>
                            {% else %}
                                <span class="status-badge status-badge-pending">
                                    <i class="bi bi-clock-fill"></i>
                                    En attente
                                </span>
                            {% endif %}
                        </td>
                        
                        <td>
                            <div class="text-muted" style="font-size:.9rem;">
                                <i class="bi bi-calendar3"></i>
                                {{ achat.createdAt ? achat.createdAt|date('d/m/Y') : '-' }}
                            </div>
                            <div class="text-muted" style="font-size:.8rem;">
                                {{ achat.createdAt ? achat.createdAt|date('H:i') : '' }}
                            </div>
                        </td>
                        
                        <td class="text-end pe-4">
                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                <a href="{{ path('app_achat_show', {'id': achat.id}) }}"
                                   class="btn-modern btn-modern-info btn-modern-sm"
                                   data-bs-toggle="tooltip" 
                                   title="Voir les détails">
                                    <i class="bi bi-eye"></i>
                                    <span>Voir</span>
                                </a>

                                <a href="{{ path('app_achat_edit', {'id': achat.id}) }}"
                                   class="btn-modern btn-modern-warning btn-modern-sm"
                                   data-bs-toggle="tooltip" 
                                   title="Modifier l'achat">
                                    <i class="bi bi-pencil-square"></i>
                                    <span>Modifier</span>
                                </a>

                                {% if not achat.estAchete %}
                                    <a href="{{ path('app_achat_confirmer', {'id': achat.id}) }}"
                                       class="btn-modern btn-modern-success btn-modern-sm"
                                       data-bs-toggle="tooltip" 
                                       title="Marquer comme acheté">
                                        <i class="bi bi-check-circle"></i>
                                        <span>Acheté</span>
                                    </a>
                                {% else %}
                                    <form method="post"
                                          action="{{ path('app_achat_annuler', {'id': achat.id}) }}"
                                          style="display:inline-block;"
                                          class="form-annuler"
                                          data-achat-name="{{ achat.nomArticle }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('annuler' ~ achat.id) }}">
                                        <button class="btn-modern btn-modern-secondary btn-modern-sm"
                                                data-bs-toggle="tooltip" 
                                                title="Annuler l'achat">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                            <span>Annuler</span>
                                        </button>
                                    </form>
                                {% endif %}

                                <form method="post"
                                      action="{{ path('app_achat_delete', {'id': achat.id}) }}"
                                      style="display:inline-block;"
                                      class="form-delete"
                                      data-achat-name="{{ achat.nomArticle }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ achat.id) }}">
                                    <button class="btn-modern btn-modern-danger btn-modern-sm"
                                            data-bs-toggle="tooltip" 
                                            title="Supprimer l'achat">
                                        <i class="bi bi-trash"></i>
                                        <span>Supprimer</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="d-flex flex-column align-items-center gap-3 py-4">
                                <div class="empty-state-icon">
                                    <i class="bi bi-cart"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-5 mb-1">Aucun achat trouvé</div>
                                    <div class="text-muted" style="max-width: 420px;">
                                        Commence par créer ton premier achat pour suivre tes courses.
                                    </div>
                                </div>
                                <button type="button" class="btn-modern btn-modern-primary mt-2"
                                        data-bs-toggle="offcanvas"
                                        data-bs-target="#offcanvasNewAchat">
                                    <i class="bi bi-plus-circle"></i>
                                    <span>Créer un achat</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="px-4 py-3 border-top bg-white pagination-wrap">
            {{ knp_pagination_render(achats) }}
        </div>
    </div>

</div>

{# Offcanvas moderne pour créer un achat #}
<div class="offcanvas offcanvas-end offcanvas-modern" tabindex="-1" id="offcanvasNewAchat" aria-labelledby="offcanvasNewAchatLabel">
    <div class="offcanvas-header-modern">
        <div class="d-flex align-items-center gap-3">
            <div class="offcanvas-icon">
                <i class="bi bi-plus-circle"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-bold" id="offcanvasNewAchatLabel">Nouvel achat</h5>
                <small class="text-muted">Ajoute un article à ta liste de courses</small>
            </div>
        </div>
        <button type="button" class="btn-close-modern" data-bs-dismiss="offcanvas" aria-label="Close">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="offcanvas-divider"></div>

    <div class="offcanvas-body-modern">
        {{ form_start(formNew, {'action': path('app_achat_index'), 'method': 'POST', 'attr': {'class': 'form-modern', novalidate: 'novalidate'}}) }}


        <div class="form-group-modern">
            {{ form_label(formNew.nomArticle, 'Nom de l\'article', {'label_attr': {'class': 'form-label-modern'}}) }}
            <div class="input-icon-wrapper">
                <i class="bi bi-cart input-icon"></i>
                {{ form_widget(formNew.nomArticle, {'attr': {'class': 'form-control-modern', 'placeholder': 'Ex: Lait, Pain, Shampooing...'}}) }}
            </div>
           <div class="text-danger small mt-1">
  {{ form_errors(formNew.nomArticle) }}
</div>
        </div>

        <div class="form-group-modern">
            {{ form_label(formNew.categorie, 'Catégorie', {'label_attr': {'class': 'form-label-modern'}}) }}
            <div class="input-icon-wrapper">
                <i class="bi bi-tag input-icon"></i>
                {{ form_widget(formNew.categorie, {'attr': {'class': 'form-select-modern'}}) }}
            </div>
            {{ form_errors(formNew.categorie) }}
        </div>

        <div class="offcanvas-footer-modern">
            <button type="button" class="btn-modern btn-modern-secondary flex-fill" data-bs-dismiss="offcanvas">
                <i class="bi bi-x-circle"></i>
                <span>Annuler</span>
            </button>
            <button type="submit" class="btn-modern btn-modern-primary flex-fill">
                <i class="bi bi-check-circle"></i>
                <span>Enregistrer</span>
            </button>
        </div>

        {{ form_end(formNew) }}
    </div>
</div>

{# Scripts #}
<script>
document.addEventListener('DOMContentLoaded', () => {
    // Tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Confirmation annulation
    const formsAnnuler = document.querySelectorAll('.form-annuler');
    formsAnnuler.forEach(form => {
        form.addEventListener('submit', function(e) {
            const achatName = this.dataset.achatName;
            if (!confirm(`Annuler l'achat "${achatName}" ?\n\nCela supprimera l'historique associé.`)) {
                e.preventDefault();
            }
        });
    });

    // Confirmation suppression
    const formsDelete = document.querySelectorAll('.form-delete');
    formsDelete.forEach(form => {
        form.addEventListener('submit', function(e) {
            const achatName = this.dataset.achatName;
            if (!confirm(`Supprimer définitivement l'achat "${achatName}" ?\n\nCette action est irréversible.`)) {
                e.preventDefault();
            }
        });
    });
});
</script>

{# Styles modernes #}
