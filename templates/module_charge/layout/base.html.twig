<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Module Charge{% endblock %}</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
  /* demi page */
.offcanvas-half {
  width: 50vw;
  max-width: 620px;
}

/* blur quand offcanvas est ouvert */
body.offcanvas-blur main.content {
  filter: blur(6px);
}

.offcanvas-backdrop.show {
  opacity: .25;
  backdrop-filter: blur(6px);
}

    body { background:#f5f6fa; }
    .sidebar {
      width: 280px; background:#fff; border-right:1px solid #e9ecef;
      position: sticky; top:0; height:100vh;
    }
    .content { flex: 1; }
    .card { border:0; box-shadow:0 6px 18px rgba(0,0,0,.06); border-radius:14px; }
    .nav-link { border-radius: 10px; color:#111827; }
    .nav-link.active { background:#eef2ff; color:#4f46e5; font-weight:600; }
    .brand { font-weight:800; }
  </style>

  {% block stylesheets %}{% endblock %}
</head>
<body>

<div class="d-flex">
  <aside class="sidebar p-3">
    {% include 'module_charge/layout/sidebar.html.twig' %}
  </aside>

  <main class="content">
    <div class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
      <div class="fw-semibold">{% block page_title %}{% endblock %}</div>
      <div class="d-flex gap-2 align-items-center">
        <input class="form-control form-control-sm" style="width:260px" placeholder="Search...">
        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
             style="width:34px;height:34px;">👤</div>
      </div>
    </div>

    <div class="container-fluid p-4">
      {% block body %}{% endblock %}
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
