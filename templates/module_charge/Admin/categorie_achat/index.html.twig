{% extends 'module_charge/layout/base.html.twig' %}

{% block title %}Catégories d'achat{% endblock %}
{% block page_title %}Catégories d'achat{% endblock %}

{% block body %}
<div class="container mt-4">

  {# Header #}
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
    <div>
      <h2 class="fw-bold mb-1">Catégories</h2>
      <div class="text-muted" style="font-size:.95rem;">
        Gère les catégories utilisées pour organiser les achats.
      </div>
    </div>

    <div class="d-flex gap-2">
      <a href="{{ path('app_categorie_achat_new') }}" class="btn-modern btn-modern-primary">
        <i class="bi bi-plus-circle"></i>
        <span>Nouvelle catégorie</span>
      </a>
    </div>
  </div>

  {# Card #}
  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3 px-4">
      <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">

        <div class="d-flex align-items-center gap-2">
          <span class="text-muted" style="font-size:.95rem;">Total</span>
          <span class="badge-modern">{{ categorie_achats|length }}</span>
        </div>

        <div class="search-box">
          <i class="bi bi-search"></i>
          <input id="catSearch" type="text"
                 placeholder="Rechercher une catégorie..."
                 autocomplete="off">
        </div>

      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width:90px;">ID</th>
            <th>Nom</th>
            <th class="text-end pe-4" style="width:340px;">Actions</th>
          </tr>
        </thead>

        <tbody id="catTable">
        {% for categorie_achat in categorie_achats %}
          <tr>
            <td class="text-muted ps-4">#{{ categorie_achat.id }}</td>

            <td>
              <div class="d-flex align-items-center gap-3">
                {# Avatar moderne #}
                <div class="avatar-modern">
                  {{ categorie_achat.nomCategorie|default('C')|slice(0,1)|upper }}
                </div>

                <div>
                  <div class="fw-semibold cat-name" style="font-size:1rem;">{{ categorie_achat.nomCategorie }}</div>
                  <div class="text-muted" style="font-size:.85rem;">
                    Catégorie d'achat
                  </div>
                </div>
              </div>
            </td>

            <td class="text-end pe-4">
              <div class="d-flex gap-2 justify-content-end">
                <a href="{{ path('app_categorie_achat_show', {'id': categorie_achat.id}) }}"
                   class="btn-modern btn-modern-info"
                   data-bs-toggle="tooltip" 
                   title="Voir les détails">
                  <i class="bi bi-eye"></i>
                  <span>Voir</span>
                </a>

                <a href="{{ path('app_categorie_achat_edit', {'id': categorie_achat.id}) }}"
                   class="btn-modern btn-modern-warning"
                   data-bs-toggle="tooltip" 
                   title="Modifier la catégorie">
                  <i class="bi bi-pencil-square"></i>
                  <span>Modifier</span>
                </a>

                <button type="button"
                        class="btn-modern btn-modern-danger btn-delete-cat"
                        data-cat-id="{{ categorie_achat.id }}"
                        data-cat-name="{{ categorie_achat.nomCategorie }}"
                        data-bs-toggle="tooltip" 
                        title="Supprimer la catégorie">
                  <i class="bi bi-trash"></i>
                  <span>Supprimer</span>
                </button>
              </div>

              {# Formulaire de suppression caché #}
              <form method="post" 
                    id="delete-form-{{ categorie_achat.id }}"
                    action="{{ path('app_categorie_achat_delete', {'id': categorie_achat.id}) }}"
                    style="display:none;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ categorie_achat.id) }}">
              </form>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="3" class="text-center py-5">
              <div class="d-flex flex-column align-items-center gap-3 py-4">
                <div class="empty-state-icon">
                  <i class="bi bi-inbox"></i>
                </div>
                <div>
                  <div class="fw-bold fs-5 mb-1">Aucune catégorie trouvée</div>
                  <div class="text-muted" style="max-width: 420px;">
                    Crée une catégorie pour mieux organiser tes achats (Ex: Alimentation, Maison, Santé…).
                  </div>
                </div>
                <a href="{{ path('app_categorie_achat_new') }}" class="btn-modern btn-modern-primary mt-2">
                  <i class="bi bi-plus-circle"></i>
                  <span>Créer une catégorie</span>
                </a>
              </div>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

</div>

{# Recherche front: filtre uniquement le NOM #}
<script>
document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('catSearch');
  const rows = Array.from(document.querySelectorAll('#catTable tr'));

  if (!input) return;

  input.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();

    rows.forEach(row => {
      const nameEl = row.querySelector('.cat-name');
      if (!nameEl) return;
      const name = nameEl.innerText.toLowerCase();
      row.style.display = name.includes(q) ? '' : 'none';
    });
  });

  // Gestion des tooltips Bootstrap
  const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl);
  });

  // Gestion de la suppression avec confirmation moderne
  const deleteButtons = document.querySelectorAll('.btn-delete-cat');
  deleteButtons.forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const catId = this.dataset.catId;
      const catName = this.dataset.catName;
      
      if (confirm(`Voulez-vous vraiment supprimer la catégorie "${catName}" ?\n\nCette action est irréversible.`)) {
        document.getElementById(`delete-form-${catId}`).submit();
      }
    });
  });
});
</script>

{# Design System Moderne #}
<style>
  /* === BOUTONS MODERNES === */
  .btn-modern {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .btn-modern i {
    font-size: 16px;
  }

  .btn-modern::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .btn-modern:hover::before {
    width: 300px;
    height: 300px;
  }

  .btn-modern:active {
    transform: scale(0.95);
  }

  /* Variantes de couleurs */
  .btn-modern-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  }

  .btn-modern-primary:hover {
    box-shadow: 0 6px 25px rgba(102, 126, 234, 0.5);
    transform: translateY(-2px);
    color: white;
  }

  .btn-modern-info {
    background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);
  }

  .btn-modern-info:hover {
    box-shadow: 0 6px 25px rgba(14, 165, 233, 0.5);
    transform: translateY(-2px);
    color: white;
  }

  .btn-modern-warning {
    background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
  }

  .btn-modern-warning:hover {
    box-shadow: 0 6px 25px rgba(245, 158, 11, 0.5);
    transform: translateY(-2px);
    color: white;
  }

  .btn-modern-danger {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
  }

  .btn-modern-danger:hover {
    box-shadow: 0 6px 25px rgba(239, 68, 68, 0.5);
    transform: translateY(-2px);
    color: white;
  }

  /* === BADGE MODERNE === */
  .badge-modern {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 16px;
    font-size: 14px;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 20px;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25);
    transition: transform 0.2s ease;
  }

  .badge-modern:hover {
    transform: scale(1.1);
  }

  /* === SEARCH BOX MODERNE === */
  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 16px;
    transition: all 0.3s ease;
    max-width: 360px;
  }

  .search-box i {
    color: #9ca3af;
    font-size: 16px;
  }

  .search-box input {
    border: none;
    outline: none;
    font-size: 14px;
    width: 100%;
    color: #1f2937;
  }

  .search-box input::placeholder {
    color: #9ca3af;
  }

  .search-box:focus-within {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  }

  /* === AVATAR MODERNE === */
  .avatar-modern {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    font-weight: 700;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25);
    transition: transform 0.3s ease;
  }

  .avatar-modern:hover {
    transform: rotate(5deg) scale(1.05);
  }

  /* === EMPTY STATE ICON === */
  .empty-state-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(240, 147, 251, 0.3);
  }

  .empty-state-icon i {
    font-size: 36px;
    color: white;
  }

  /* === TABLE ROW ANIMATION === */
  #catTable tr {
    transition: all 0.3s ease;
  }

  #catTable tr:hover {
    background: linear-gradient(90deg, rgba(102, 126, 234, 0.03) 0%, rgba(118, 75, 162, 0.03) 100%);
    transform: translateX(4px);
  }

  /* === CARD STYLE === */
  .card {
    transition: all 0.3s ease;
  }

  .card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08) !important;
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .btn-modern span {
      display: none;
    }
    
    .btn-modern {
      padding: 10px 14px;
    }
  }
</style>
{% endblock %}