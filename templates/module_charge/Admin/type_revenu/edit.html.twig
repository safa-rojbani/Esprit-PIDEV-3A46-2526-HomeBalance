{% extends 'base.html.twig' %}

{% block title %}Modifier type de revenu{% endblock %}

{% block body %}
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Modifier le type de revenu</h2>
    <a href="{{ path('app_type_revenu_index') }}" class="btn btn-outline-secondary">Retour</a>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      {{ form_start(form) }}
      <div class="mb-3">
        {{ form_label(form.nomType) }}
        {{ form_widget(form.nomType, {'attr': {'class': 'form-control form-control-lg'}}) }}
        <div class="text-danger small mt-1">{{ form_errors(form.nomType) }}</div>
      </div>
      <button class="btn btn-primary">Mettre a jour</button>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
