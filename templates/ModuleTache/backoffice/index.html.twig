{% extends 'base.html.twig' %}

{% block title %}Gestion des tâches{% endblock %}

{# ================= STYLESHEETS ================= #}
{% block stylesheets %}
    {{ parent() }}

    {# Bootstrap 5 (REQUIRED for DataTables layout) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet">

    {# DataTables Bootstrap 5 CSS #}
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css"
          rel="stylesheet">
{% endblock %}


{# ================= BODY ================= #}
{% block body %}

<div class="layout-wrapper layout-content-navbar">
  <div class="layout-container">
    <div class="layout-page">

      <div class="content-wrapper">
        <div class="container-xxl flex-grow-1 container-p-y">

          <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="mb-0">Gestion des tâches</h5>

              <a href="{{ path('admin_task_create') }}" class="btn btn-primary">
                <i class="bx bx-plus"></i> Add New Record
              </a>
            </div>

            <div class="card-datatable table-responsive">
              <table id="tasksTable" class="table border-top">
                <thead>
                  <tr>
                    <th>Titre</th>
                    <th>Difficulté</th>
                    <th>Récurrence</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>

                <tbody>
                {% for task in tasks %}
                  <tr>
                    <td>{{ task.title }}</td>
                    <td>{{ task.difficulty ? task.difficulty.value : '-' }}</td>
                    <td>{{ task.recurrence ? task.recurrence.value : '-' }}</td>
                    <td>
                      {% if task.isActive %}
                        <span class="badge bg-label-success">Active</span>
                      {% else %}
                        <span class="badge bg-label-secondary">Inactive</span>
                      {% endif %}
                    </td>
                    <td>
                      <a href="{{ path('admin_task_edit', { id: task.id }) }}"
                         class="btn btn-sm btn-icon">
                        <i class="bx bx-edit"></i>
                      </a>

                      <form method="post"
                            action="{{ path('admin_task_delete', { id: task.id }) }}"
                            class="d-inline"
                            onsubmit="return confirm('Supprimer cette tâche ?');">

                        <input type="hidden" name="_token"
                               value="{{ csrf_token('delete_task_' ~ task.id) }}">

                        <button class="btn btn-sm btn-icon text-danger">
                          <i class="bx bx-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                {% endfor %}
                </tbody>
              </table>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</div>

{% endblock %}

{# ================= JAVASCRIPTS ================= #}
{% block javascripts %}
    {{ parent() }}

    {# jQuery (required by DataTables) #}
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    {# DataTables JS #}
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tasksTable').DataTable({
                pageLength: 10,
                lengthChange: true,
                searching: true
            });
        });
    </script>
{% endblock %}

