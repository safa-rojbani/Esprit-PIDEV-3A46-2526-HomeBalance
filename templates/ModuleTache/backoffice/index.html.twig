{% extends 'base.html.twig' %}

{% block title %}Taches globales admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'ModuleTache/partials/_theme.html.twig' %}
{% endblock %}

{% block body %}
<div class="task-module">
    <div class="tm-page-head">
        <div>
            <h1 class="tm-title h3">Taches globales</h1>
            <p class="tm-subtitle">Catalogue de taches disponibles pour toutes les familles.</p>
        </div>
        <div class="tm-actions">
            <a href="{{ path('task_score_rules') }}" class="btn btn-outline-primary">
                <i class="bx bx-slider-alt"></i>
                Regles de points
            </a>
            <a href="{{ path('admin_task_create') }}" class="btn btn-primary">
                <i class="bx bx-plus"></i>
                Nouvelle tache globale
            </a>
        </div>
    </div>

    <div class="card tm-card">
        <div class="card-body p-0">
            {% if tasks is empty %}
                <div class="p-3">
                    <div class="tm-empty">Aucune tache globale pour le moment.</div>
                </div>
            {% else %}
                <div class="px-3 pt-3 small text-muted">
                    {{ tasks.getTotalItemCount|default(tasks|length) }} tache(s)
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th>Difficulte</th>
                                <th>Recurrence</th>
                                <th>Points</th>
                                <th>Etat</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for task in tasks %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ task.title }}</div>
                                    <div class="small text-muted">{{ task.description }}</div>
                                </td>
                                <td>
                                    <span class="tm-badge info">{{ task.difficulty ? task.difficulty.value : '-' }}</span>
                                </td>
                                <td>
                                    <span class="tm-badge info">{{ task.recurrence ? task.recurrence.value : '-' }}</span>
                                </td>
                                <td>
                                    <span class="tm-badge success">{{ taskPoints[task.id]|default(0) }} pts</span>
                                </td>
                                <td>
                                    {% if task.isActive %}
                                        <span class="tm-badge success">Active</span>
                                    {% else %}
                                        <span class="tm-badge warning">Inactive</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="tm-actions justify-content-end">
                                        <a href="{{ path('admin_task_edit', { id: task.id }) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bx bx-edit-alt"></i>
                                            Modifier
                                        </a>
                                        <form method="post"
                                              action="{{ path('admin_task_delete', { id: task.id }) }}"
                                              class="d-inline"
                                              onsubmit="return confirm('Supprimer cette tache ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_task_' ~ task.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">
                                                <i class="bx bx-trash"></i>
                                                Supprimer
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="px-3 py-3 border-top">
                    {{ knp_pagination_render(tasks) }}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
