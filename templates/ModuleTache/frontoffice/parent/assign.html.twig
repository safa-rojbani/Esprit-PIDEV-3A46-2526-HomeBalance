{% extends 'base.html.twig' %}

{% block title %}Assigner une tache{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'ModuleTache/partials/_theme.html.twig' %}
{% endblock %}

{% block body %}
<div class="task-module">
    <div class="tm-page-head">
        <div>
            <h1 class="tm-title h3">Assigner une tache</h1>
            <p class="tm-subtitle">Choisissez une tache familiale et le membre qui doit la realiser.</p>
        </div>
        <a href="{{ path('parent_task_index') }}" class="btn btn-outline-secondary">
            <i class="bx bx-arrow-back"></i>
            Retour
        </a>
    </div>

    <div class="card tm-card tm-form-wrap">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.task) }}</div>
                    <div class="col-12">{{ form_row(form.user) }}</div>
                    <div class="col-md-6">{{ form_row(form.dueDate) }}</div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bx bx-send"></i>
                        Assigner
                    </button>
                    <a href="{{ path('parent_task_index') }}" class="btn btn-label-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
