{% extends 'base.html.twig' %}

{% block title %}Validations parent{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'ModuleTache/partials/_theme.html.twig' %}
{% endblock %}

{% block body %}
<div class="task-module">
    <div class="tm-page-head">
        <div>
            <h1 class="tm-title h3">Taches a valider</h1>
            <p class="tm-subtitle">Validez ou refusez les soumissions en attente.</p>
        </div>
    </div>

    <div class="card tm-card">
        <div class="card-body">
            {% if completions is empty %}
                <div class="tm-empty">Aucune tache en attente de validation.</div>
            {% else %}
                <div class="row g-3">
                    {% for c in completions %}
                        <div class="col-12 col-lg-6">
                            <div class="border rounded-3 p-3 h-100">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="tm-task-name">{{ c.task.title }}</div>
                                        <div class="tm-meta">
                                            Enfant: {{ c.user.firstName }} {{ c.user.lastName }}<br>
                                            Soumis le {{ c.completedAt ? c.completedAt|date('d/m/Y H:i') : '-' }}
                                        </div>
                                    </div>
                                    <span class="tm-badge warning">En attente</span>
                                </div>

                                {% if c.proof %}
                                    <img src="{{ asset('uploads/proofs/' ~ c.proof) }}" class="tm-proof" alt="Preuve">
                                {% endif %}

                                {% set ai = c.aiEvaluation %}
                                <div class="mt-3 p-2 rounded border bg-light">
                                    <div class="fw-semibold mb-1">Suggestion IA</div>
                                    {% if ai %}
                                        <div class="tm-meta">
                                            Provider: {{ ai.provider|upper }}{% if ai.model %} ({{ ai.model }}){% endif %}<br>
                                            Statut: {{ ai.status ? ai.status.value : 'N/A' }}
                                            {% if ai.decision %} / Decision: {{ ai.decision.value }}{% endif %}<br>
                                            Score: {{ ai.tidyScore is not null ? ai.tidyScore : '-' }} / 100
                                            {% if ai.confidence is not null %} - Confiance: {{ (ai.confidence * 100)|round(0) }}%{% endif %}<br>
                                            {% if ai.reasonShort %}Raison: {{ ai.reasonShort }}{% endif %}
                                        </div>
                                    {% else %}
                                        <div class="tm-meta">Aucune analyse encore disponible.</div>
                                    {% endif %}
                                </div>

                                <div class="mt-3 tm-actions">
                                    <a href="{{ path('parent_validation_accept', {id: c.id}) }}" class="btn btn-sm btn-success">
                                        <i class="bx bx-check"></i>
                                        Valider
                                    </a>
                                    <a href="{{ path('parent_validation_refuse', {id: c.id}) }}" class="btn btn-sm btn-outline-danger">
                                        <i class="bx bx-x"></i>
                                        Refuser
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
