{% extends 'base.html.twig' %}

{% block title %}Espace parent - taches{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'ModuleTache/partials/_theme.html.twig' %}
{% endblock %}

{% block body %}
<div class="task-module">
    <div class="tm-page-head">
        <div>
            <h1 class="tm-title h3">Espace parent</h1>
            <p class="tm-subtitle">Ajoutez des taches globales et gerez les taches de votre famille.</p>
        </div>
        <div class="tm-actions">
            <a href="{{ path('task_score_index') }}" class="btn btn-outline-primary">
                <i class="bx bx-trophy"></i>
                Scores
            </a>
            <a href="{{ path('task_score_rules') }}" class="btn btn-outline-primary">
                <i class="bx bx-slider-alt"></i>
                Regles points
            </a>
            <a href="{{ path('parent_task_new') }}" class="btn btn-primary">
                <i class="bx bx-plus"></i>
                Nouvelle tache personnalisee
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-6">
            <div class="card tm-card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Taches admin disponibles</h5>
                </div>
                <div class="card-body">
                    {% if adminTasks is empty %}
                        <div class="tm-empty">Aucune tache globale disponible.</div>
                    {% else %}
                        <ul class="list-group tm-task-list">
                            {% for task in adminTasks %}
                                <li class="list-group-item d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="tm-task-name">{{ task.title }}</div>
                                        <div class="tm-meta">{{ task.description }}</div>
                                        <div class="mt-2 d-flex gap-2">
                                            <span class="tm-badge success">{{ adminTaskPoints[task.id]|default(0) }} pts</span>
                                            <span class="tm-badge info">{{ task.difficulty ? task.difficulty.value : '-' }}</span>
                                            <span class="tm-badge info">{{ task.recurrence ? task.recurrence.value : '-' }}</span>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('parent_task_add', {id: task.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('add_admin_task_' ~ task.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Ajouter</button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                        <div class="mt-3 d-flex justify-content-between align-items-center">
                            <a class="btn btn-sm btn-outline-secondary {{ not adminPagination.hasPrevious ? 'disabled' : '' }}"
                               href="{{ adminPagination.hasPrevious ? path('parent_task_index', {adminPage: adminPagination.page - 1, familyPage: familyPagination.page}) : '#' }}">
                                <i class="bx bx-chevron-left"></i>
                                Precedent
                            </a>
                            <span class="small text-muted">Page {{ adminPagination.page }}</span>
                            <a class="btn btn-sm btn-outline-secondary {{ not adminPagination.hasNext ? 'disabled' : '' }}"
                               href="{{ adminPagination.hasNext ? path('parent_task_index', {adminPage: adminPagination.page + 1, familyPage: familyPagination.page}) : '#' }}">
                                Suivant
                                <i class="bx bx-chevron-right"></i>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card tm-card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Taches de la famille</h5>
                </div>
                <div class="card-body">
                    {% if familyTasks is empty %}
                        <div class="tm-empty">Aucune tache familiale pour le moment.</div>
                    {% else %}
                        <ul class="list-group tm-task-list">
                            {% for task in familyTasks %}
                                <li class="list-group-item d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="tm-task-name">{{ task.title }}</div>
                                        <div class="tm-meta">{{ task.description }}</div>
                                        <div class="mt-2 d-flex gap-2">
                                            <span class="tm-badge success">{{ familyTaskPoints[task.id]|default(0) }} pts</span>
                                            <span class="tm-badge info">{{ task.difficulty ? task.difficulty.value : '-' }}</span>
                                            <span class="tm-badge info">{{ task.recurrence ? task.recurrence.value : '-' }}</span>
                                        </div>
                                    </div>
                                    <div class="tm-actions">
                                        <a href="{{ path('parent_task_edit', {id: task.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bx bx-edit-alt"></i>
                                            Modifier
                                        </a>
                                        <form method="post"
                                              action="{{ path('parent_task_delete', {id: task.id}) }}"
                                              class="d-inline"
                                              onsubmit="return confirm('Supprimer cette tache ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_task_' ~ task.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bx bx-trash"></i>
                                                Supprimer
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                        <div class="mt-3 d-flex justify-content-between align-items-center">
                            <a class="btn btn-sm btn-outline-secondary {{ not familyPagination.hasPrevious ? 'disabled' : '' }}"
                               href="{{ familyPagination.hasPrevious ? path('parent_task_index', {familyPage: familyPagination.page - 1, adminPage: adminPagination.page}) : '#' }}">
                                <i class="bx bx-chevron-left"></i>
                                Precedent
                            </a>
                            <span class="small text-muted">Page {{ familyPagination.page }}</span>
                            <a class="btn btn-sm btn-outline-secondary {{ not familyPagination.hasNext ? 'disabled' : '' }}"
                               href="{{ familyPagination.hasNext ? path('parent_task_index', {familyPage: familyPagination.page + 1, adminPage: adminPagination.page}) : '#' }}">
                                Suivant
                                <i class="bx bx-chevron-right"></i>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
