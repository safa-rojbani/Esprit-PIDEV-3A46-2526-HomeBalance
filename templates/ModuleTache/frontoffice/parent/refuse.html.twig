{% extends 'base.html.twig' %}

{% block title %}Refuser la tache{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'ModuleTache/partials/_theme.html.twig' %}
{% endblock %}

{% block body %}
<div class="task-module">
    <div class="tm-page-head">
        <div>
            <h1 class="tm-title h3">Refuser la tache</h1>
            <p class="tm-subtitle">Ajoutez une raison claire pour permettre une nouvelle soumission.</p>
        </div>
        <a href="{{ path('parent_validation_index') }}" class="btn btn-outline-secondary">
            <i class="bx bx-arrow-back"></i>
            Retour
        </a>
    </div>

    <div class="card tm-card tm-form-wrap">
        <div class="card-body">
            <div class="mb-3">
                <div class="tm-task-name">{{ completion.task.title }}</div>
                <div class="tm-meta">
                    Soumis par {{ completion.user.firstName }} {{ completion.user.lastName }}
                </div>
                {% if completion.proof %}
                    <img src="{{ asset('uploads/proofs/' ~ completion.proof) }}" class="tm-proof" alt="Preuve de tache">
                {% endif %}
            </div>

            {{ form_start(form) }}
                {{ form_row(form.parentComment) }}
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bx bx-x-circle"></i>
                        Confirmer le refus
                    </button>
                    <a href="{{ path('parent_validation_index') }}" class="btn btn-label-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
