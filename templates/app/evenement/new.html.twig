{% extends 'base_front.html.twig' %}

{% block title %}Ajouter un evenement{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/module-evenement-pro.css') }}">
{% endblock %}

{% block body %}
<div class="evt-shell">
  <div class="evt-pagehead d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h3 class="evt-title">Ajouter un evenement</h3>
      <p class="evt-subtitle">Renseignez les informations importantes pour planifier votre evenement.</p>
    </div>
    <a href="{{ path('app_evenement_index') }}" class="btn evt-btn-ghost">Retour</a>
  </div>

  <div class="card evt-card">
    <div class="card-body">
      {{ include('app/evenement/_form.html.twig', { button_label: 'Creer' }) }}
    </div>
  </div>
</div>
{% endblock %}
