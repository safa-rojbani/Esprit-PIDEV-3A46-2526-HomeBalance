{% extends 'base_front.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <div class="d-flex align-items-center gap-3 flex-wrap">
    <h4 class="fw-semibold m-0">Mes événements</h4>
    <form id="eventFilters" class="d-flex gap-2 flex-wrap" method="get" action="{{ path('app_evenement_index') }}">
      <div>
        <select class="form-select" name="type">
          <option value="">Tous</option>
          {% for t in types %}
            <option value="{{ t.id }}" {% if selectedType and t.id == selectedType.id %}selected{% endif %}>
              {{ t.nom }}
            </option>
          {% endfor %}
        </select>
      </div>
      <div>
        <input type="text" class="form-control" name="q" value="{{ search }}" placeholder="Recherche titre...">
      </div>
    </form>
  </div>

  <div>
    <a href="{{ path('app_calendar') }}" class="btn btn-outline-secondary me-2">
      Calendrier
    </a>
    <a href="{{ path('app_evenement_new') }}" class="btn btn-primary">
      + Ajouter un événement
    </a>
  </div>
</div>

<div class="card">
  <div class="table-responsive text-nowrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Titre</th>
          <th>Lieu</th>
          <th>Partagé</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
      {% for e in evenements %}
        <tr>
          <td>{{ e.id }}</td>
          <td class="fw-semibold">{{ e.titre }}</td>
          <td>{{ e.lieu }}</td>
          <td>{{ e.shareWithFamily ? 'Oui' : 'Non' }}</td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-info"
               href="{{ path('app_evenement_show', { id: e.id }) }}">
              Voir
            </a>
            {% if e.createdBy == app.user %}
              <a class="btn btn-sm btn-outline-warning"
                 href="{{ path('app_evenement_edit', { id: e.id }) }}">
                Modifier
              </a>
              <form method="post"
                    action="{{ path('app_evenement_delete', { id: e.id }) }}"
                    style="display:inline-block"
                    onsubmit="return confirm('Supprimer cet événement ?');">
                <input type="hidden" name="_token"
                       value="{{ csrf_token('delete' ~ e.id) }}">
                <button class="btn btn-sm btn-outline-danger">
                  Supprimer
                </button>
              </form>
            {% endif %}
            <a class="btn btn-sm btn-outline-secondary"
               href="{{ path('app_evenement_rappels', { id: e.id }) }}">
              Rappels
            </a>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="5" class="text-center text-muted">
            Aucun événement trouvé
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  <script>
    (function () {
      const form = document.getElementById('eventFilters');
      if (!form) return;
      let debounce;
      const submit = () => form.submit();
      form.querySelectorAll('select').forEach((el) => {
        el.addEventListener('change', submit);
      });
      form.querySelectorAll('input[type="text"]').forEach((el) => {
        el.addEventListener('input', () => {
          clearTimeout(debounce);
          debounce = setTimeout(submit, 300);
        });
      });
    })();
  </script>
{% endblock %}
