{% extends 'base_front.html.twig' %}

{% block title %}Modifier un evenement{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/module-evenement-pro.css') }}">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin="">
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin=""></script>
{% endblock %}

{% block body %}
<div class="evt-shell">
  <div class="evt-pagehead d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h3 class="evt-title">Modifier un evenement</h3>
      <p class="evt-subtitle">Mettez a jour les details sans perdre le suivi des rappels.</p>
    </div>
    <a href="{{ path('app_evenement_index') }}" class="btn evt-btn-ghost">Retour</a>
  </div>

  <div class="card evt-card">
    <div class="card-body">
      {{ include('app/evenement/_form.html.twig', { button_label: 'Mettre a jour' }) }}
    </div>
  </div>
</div>
{% endblock %}
