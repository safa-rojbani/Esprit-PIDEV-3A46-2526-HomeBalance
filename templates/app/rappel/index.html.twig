{% extends 'base_front.html.twig' %}

{% block title %}Rappels{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-semibold m-0">Rappels pour "{{ evenement.titre }}"</h4>
  <div>
    <a href="{{ path('app_evenement_show', { id: evenement.id }) }}" class="btn btn-outline-secondary me-2">
      Retour à l'événement
    </a>
    <a href="{{ path('app_rappel_new', { evenement: evenement.id }) }}" class="btn btn-primary">
      + Ajouter un rappel
    </a>
  </div>
</div>

<div class="card">
  <div class="table-responsive text-nowrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Minutes avant</th>
          <th>Canal</th>
          <th>Actif</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
      {% for r in rappels %}
        <tr>
          <td>{{ r.id }}</td>
          <td>{{ r.offsetMinutes }}</td>
          <td>{{ r.canal ?? '' }}</td>
          <td>{{ r.actif ? 'Oui' : 'Non' }}</td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-warning"
               href="{{ path('app_rappel_edit', { id: r.id }) }}">
              Modifier
            </a>
            <form method="post"
                  action="{{ path('app_rappel_delete', { id: r.id }) }}"
                  style="display:inline-block"
                  onsubmit="return confirm('Supprimer ce rappel ?');">
              <input type="hidden" name="_token"
                     value="{{ csrf_token('delete' ~ r.id) }}">
              <button class="btn btn-sm btn-outline-danger">
                Supprimer
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="5" class="text-center text-muted">
            Aucun rappel trouvé
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
