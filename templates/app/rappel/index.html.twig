{% extends 'base_front.html.twig' %}

{% block title %}Rappels{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/module-evenement-pro.css') }}">
{% endblock %}

{% block body %}
<div class="evt-shell">
  <div class="evt-pagehead d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h3 class="evt-title">Rappels de "{{ evenement.titre }}"</h3>
      <p class="evt-subtitle">Pilotez vos alertes avant le debut de l'evenement.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="{{ path('app_evenement_show', { id: evenement.id }) }}" class="btn evt-btn-ghost">Retour evenement</a>
      <a href="{{ path('app_rappel_new', { evenement: evenement.id }) }}" class="btn evt-btn-primary">+ Ajouter un rappel</a>
    </div>
  </div>

  <div class="card evt-card">
    <div class="table-responsive">
      <table class="table evt-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Minutes avant</th>
            <th>Canal</th>
            <th>Actif</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
        {% for r in rappels %}
          <tr>
            <td>{{ r.id }}</td>
            <td class="evt-title-cell">{{ r.offsetMinutes }}</td>
            <td>{{ r.canal ?? '-' }}</td>
            <td>
              <span class="evt-pill {{ r.actif ? 'is-yes' : 'is-no' }}">{{ r.actif ? 'Oui' : 'Non' }}</span>
            </td>
            <td class="text-end">
              <div class="evt-actions">
                <a class="btn btn-sm btn-outline-warning" href="{{ path('app_rappel_edit', { id: r.id }) }}">Modifier</a>
                <form method="post"
                      action="{{ path('app_rappel_delete', { id: r.id }) }}"
                      style="display:inline-block"
                      onsubmit="return confirm('Supprimer ce rappel ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                  <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5" class="evt-empty">Aucun rappel trouve.</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-3">
    {{ knp_pagination_render(rappels, 'pagination/evt_pagination.html.twig') }}
  </div>
</div>
{% endblock %}
