{% extends 'base_front.html.twig' %}

{% block title %}Historique des rappels{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-semibold m-0">Historique des rappels</h4>
</div>

<div class="card">
  <div class="table-responsive text-nowrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Événement</th>
          <th>Décalage minutes</th>
          <th>Canal</th>
          <th>Actif</th>
          <th>Lu</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
      {% for row in rows %}
        {% set r = row.rappel %}
        <tr>
          <td>{{ r.id }}</td>
          <td>{{ row.eventTitle ?? 'Événement supprimé' }}</td>
          <td>{{ r.offsetMinutes }}</td>
          <td>{{ r.canal ?? '' }}</td>
          <td>{{ r.actif ? 'Oui' : 'Non' }}</td>
          <td>{{ r.estLu ? 'Oui' : 'Non' }}</td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-warning"
               href="{{ path('app_rappel_edit', { id: r.id }) }}">
              Modifier
            </a>
            <form method="post"
                  action="{{ path('app_rappel_delete', { id: r.id }) }}"
                  style="display:inline-block"
                  onsubmit="return confirm('Supprimer ce rappel ?');">
              <input type="hidden" name="_token"
                     value="{{ csrf_token('delete' ~ r.id) }}">
              <button class="btn btn-sm btn-outline-danger">
                Supprimer
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="7" class="text-center text-muted">
            Aucun rappel trouvé
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
