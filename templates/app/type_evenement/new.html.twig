{% extends 'base_front.html.twig' %}

{% block title %}Ajouter type evenement{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/module-evenement-pro.css') }}">
{% endblock %}

{% block body %}
<div class="evt-shell">
  <div class="evt-pagehead d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h3 class="evt-title">Ajouter un type d'evenement</h3>
      <p class="evt-subtitle">Donnez un style propre a vos categories d'evenement.</p>
    </div>
    <a href="{{ path('app_type_evenement_index') }}" class="btn evt-btn-ghost">Retour</a>
  </div>

  <div class="card evt-card">
    <div class="card-body">
      {{ form_start(form, { attr: { novalidate: 'novalidate', class: 'evt-form' } }) }}
        {% if form.vars.errors|length > 0 %}
          <div class="evt-form-errors">{{ form_errors(form) }}</div>
        {% endif %}
        <div class="row g-3">
          <div class="col-md-6">
            {{ form_row(form.nom) }}
          </div>
          <div class="col-md-6">
            {{ form_row(form.couleur) }}
          </div>
          <div class="col-12">
            {{ form_row(form.description) }}
          </div>
        </div>
        <div class="mt-3">
          <button class="btn evt-btn-primary">Creer</button>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
