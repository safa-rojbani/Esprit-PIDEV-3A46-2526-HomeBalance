{% extends 'base_front.html.twig' %}

{% block title %}Ajouter un type d'événement{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-semibold m-0">Ajouter un type d'événement</h4>
  <a href="{{ path('app_type_evenement_index') }}" class="btn btn-outline-secondary">
    Retour
  </a>
</div>

<div class="card">
  <div class="card-body">
    {{ form_start(form) }}
      <div class="row g-3">
        <div class="col-md-6">
          {{ form_row(form.nom) }}
        </div>
        <div class="col-md-6">
          {{ form_row(form.couleur) }}
        </div>
        <div class="col-12">
          {{ form_row(form.description) }}
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary">Créer</button>
      </div>
    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
