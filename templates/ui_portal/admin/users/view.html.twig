{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · {{ user.username }}{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">{{ user.firstName }} {{ user.lastName }}</h4>
      <p class="text-muted mb-0">Inscrit le {{ user.createdAt|date('d/m/Y') }}</p>
    </div>
    <div class="d-flex gap-3 flex-wrap">
      <a href="{{ path('portal_admin_users_edit', { id: user.id }) }}" class="btn btn-outline-secondary">Modifier</a>
      <form method="post" action="{{ path('portal_admin_users_toggle_status', { id: user.id }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('toggle_status_' ~ user.id) }}" />
        <button class="btn btn-outline-warning" type="submit">
          {{ user.statusLabel == 'Active' ? 'Suspendre' : 'Activer' }}
        </button>
      </form>
      <form method="post" action="{{ path('portal_admin_users_reset_password', { id: user.id }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('reset_password_' ~ user.id) }}" />
        <button class="btn btn-outline-primary" type="submit">Envoyer le lien</button>
      </form>
      {% if familyContext.current %}
        <form method="post" action="{{ path('portal_admin_users_detach_family', { id: user.id }) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('detach_family_' ~ user.id) }}" />
          <button class="btn btn-outline-danger" type="submit">Détacher la famille</button>
        </form>
      {% elseif familyContext.previous %}
        <form method="post" action="{{ path('portal_admin_users_reinvite_family', { id: user.id }) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('reinvite_family_' ~ user.id) }}" />
          <button class="btn btn-outline-info" type="submit">Envoyer l’invitation</button>
        </form>
      {% endif %}
      <form method="post" action="{{ path('portal_admin_users_delete', { id: user.id }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}" />
        <button class="btn btn-outline-danger" type="submit">Supprimer</button>
      </form>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-xl-4 d-flex flex-column gap-4">
      <div class="card">
        <div class="card-header pb-0">
          <h5 class="card-title mb-0">Résumé du compte</h5>
        </div>
        <div class="card-body">
          <ul class="list-unstyled mb-0">
            <li class="mb-3">
              <span class="text-muted small d-block">Identifiant</span>
              <span class="fw-semibold">{{ user.username }}</span>
            </li>
            <li class="mb-3">
              <span class="text-muted small d-block">E-mail</span>
              <span class="fw-semibold">{{ user.email }}</span>
            </li>
            <li class="mb-3">
              <span class="text-muted small d-block">Rôle système</span>
              <span class="badge bg-label-primary">{{ user.systemRoleLabel }}</span>
            </li>
            <li class="mb-3">
              <span class="text-muted small d-block">Rôle famille</span>
              <span class="badge bg-label-info">{{ user.familyRoleLabel ?? '—' }}</span>
            </li>
            <li class="mb-3">
              <span class="text-muted small d-block">Statut</span>
              <span class="badge {{ user.statusBadgeClass }}">{{ user.statusLabel }}</span>
            </li>
            <li>
              <span class="text-muted small d-block">Dernière connexion</span>
              <span class="fw-semibold">{{ user.lastLogin ? user.lastLogin|date('d/m/Y H:i') : '—' }}</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="card">
        <div class="card-header pb-0">
          <h5 class="card-title mb-0">Contexte familial</h5>
        </div>
        <div class="card-body">
          {% if familyContext.current %}
            <ul class="list-unstyled mb-0">
              <li class="mb-3">
                <span class="text-muted small d-block">Foyer</span>
                <span class="fw-semibold">{{ familyContext.current.name }}</span>
              </li>
              <li class="mb-3">
                <span class="text-muted small d-block">Code d’accès</span>
                <span class="fw-semibold">{{ familyContext.current.joinCode ?? 'Non défini' }}</span>
              </li>
              <li class="mb-3">
                <span class="text-muted small d-block">Expiration du code</span>
                <span class="fw-semibold">
                  {{ familyContext.current.codeExpiresAt ? familyContext.current.codeExpiresAt|date('d/m/Y H:i') : '—' }}
                </span>
              </li>
              <li>
                <span class="text-muted small d-block">Rejoint le</span>
                <span class="fw-semibold">
                  {{ familyContext.current.joinedAt ? familyContext.current.joinedAt|date('d/m/Y H:i') : '—' }}
                </span>
              </li>
            </ul>
          {% elseif familyContext.previous %}
            <p class="text-muted mb-3">Aucune famille active associée.</p>
            <ul class="list-unstyled mb-0">
              <li class="mb-3">
                <span class="text-muted small d-block">Dernier foyer</span>
                <span class="fw-semibold">{{ familyContext.previous.name }}</span>
              </li>
              <li class="mb-3">
                <span class="text-muted small d-block">Rejoint le</span>
                <span class="fw-semibold">
                  {{ familyContext.previous.joinedAt ? familyContext.previous.joinedAt|date('d/m/Y H:i') : '—' }}
                </span>
              </li>
              <li>
                <span class="text-muted small d-block">Quitté le</span>
                <span class="fw-semibold">
                  {{ familyContext.previous.leftAt ? familyContext.previous.leftAt|date('d/m/Y H:i') : '—' }}
                </span>
              </li>
            </ul>
          {% else %}
            <p class="text-muted mb-0">Aucun historique familial.</p>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="col-xl-8">
      <div class="card h-100">
        <div class="card-header pb-0 d-flex justify-content-between align-items-center">
          <div>
            <h5 class="card-title mb-0">Activité récente</h5>
            <p class="text-muted mb-0">Entrées du journal d’audit pour cet utilisateur.</p>
          </div>
          <a href="{{ path('portal_admin_audit_trails_index') }}" class="btn btn-sm btn-outline-secondary">Voir l’historique</a>
        </div>
        <div class="card-body">
          {% if activity is empty %}
            <p class="text-muted mb-0">Aucun événement d’audit.</p>
          {% else %}
            <ul class="timeline timeline-center mt-3">
              {% for event in activity %}
                <li class="timeline-item ps-4">
                  <span class="timeline-point-{{ event.type }}"></span>
                  <div class="timeline-event">
                    <div class="timeline-header">
                      <h6 class="mb-0">{{ event.title }}</h6>
                      <small class="text-muted">{{ event.occurredAt|date('d/m/Y H:i') }}</small>
                    </div>
                    <p class="mb-0 text-muted">{{ event.description }}</p>
                  </div>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}
