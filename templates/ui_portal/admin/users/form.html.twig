{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · {{ title }}{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">{{ title }}</h4>
      <p class="text-muted mb-0">Manage user details safely from the back office.</p>
    </div>
    <a href="{{ path('portal_admin_users') }}" class="btn btn-outline-secondary">Back to list</a>
  </div>

  {% if formErrors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0 ps-3">
        {% for error in formErrors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="card">
    <div class="card-body">
      {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
      <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.email) }}</div>
        <div class="col-md-6">{{ form_row(form.username) }}</div>
        <div class="col-md-6">{{ form_row(form.firstName) }}</div>
        <div class="col-md-6">{{ form_row(form.lastName) }}</div>
        <div class="col-md-4">{{ form_row(form.systemRole) }}</div>
        <div class="col-md-4">{{ form_row(form.status) }}</div>
        <div class="col-md-4">{{ form_row(form.familyRole) }}</div>
        <div class="col-md-4">{{ form_row(form.birthDate) }}</div>
        <div class="col-md-6">{{ form_row(form.family) }}</div>
        <div class="col-md-3">{{ form_row(form.locale) }}</div>
        <div class="col-md-3">{{ form_row(form.timeZone) }}</div>
        {% if form.password is defined %}
          <div class="col-md-6">{{ form_row(form.password) }}</div>
        {% endif %}
      </div>
      <div class="mt-4 d-flex justify-content-end gap-2">
        <a href="{{ path('portal_admin_users') }}" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary" type="submit">Save</button>
      </div>
      {{ form_end(form) }}
    </div>
  </div>
{% endblock %}
