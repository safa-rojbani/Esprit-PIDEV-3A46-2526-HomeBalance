{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Utilisateurs{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Tous les utilisateurs</h4>
      <p class="text-muted mb-0">Recherchez, filtrez et gérez chaque compte.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-primary" href="{{ path('portal_admin_users_new') }}">Nouvel utilisateur</a>
      <form class="d-flex" method="get" action="{{ path('portal_admin_users') }}">
        <input type="search" class="form-control me-3" placeholder="Nom, identifiant ou e-mail" name="q" value="{{ filters.query }}" />
        <select class="form-select me-3" name="systemRole">
        <option value="">Tous les rôles</option>
        {% for key, label in filters.systemRoleChoices %}
          <option value="{{ key }}" {{ filters.systemRole == key ? 'selected' }}>{{ label }}</option>
        {% endfor %}
      </select>
        <select class="form-select me-3" name="status">
        <option value="">Tous les statuts</option>
        {% for key, label in filters.statusChoices %}
          <option value="{{ key }}" {{ filters.status == key ? 'selected' }}>{{ label }}</option>
        {% endfor %}
      </select>
        <select class="form-select me-3" name="sort">
          <option value="createdAt" {{ filters.sort == 'createdAt' ? 'selected' }}>Plus récents</option>
          <option value="lastLogin" {{ filters.sort == 'lastLogin' ? 'selected' }}>Dernière connexion</option>
          <option value="email" {{ filters.sort == 'email' ? 'selected' }}>E-mail</option>
          <option value="username" {{ filters.sort == 'username' ? 'selected' }}>Identifiant</option>
        </select>
        <select class="form-select me-3" name="dir">
          <option value="DESC" {{ filters.direction == 'DESC' ? 'selected' }}>Desc</option>
          <option value="ASC" {{ filters.direction == 'ASC' ? 'selected' }}>Asc</option>
        </select>
        <button class="btn btn-primary" type="submit">Appliquer</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Identifiant</th>
            <th>Rôle</th>
            <th>Statut</th>
            <th>Dernière connexion</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% if users is empty %}
            <tr>
              <td colspan="6" class="text-center text-muted py-6">Aucun utilisateur ne correspond aux filtres.</td>
            </tr>
          {% else %}
            {% for user in users %}
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-3">
                    <img src="{{ asset('materio/img/avatars/1.png') }}" class="rounded-circle" width="40" height="40" alt="avatar" />
                    <div>
                      <div class="fw-semibold">{{ user.firstName }} {{ user.lastName }}</div>
                      <div class="small text-muted">{{ user.email }}</div>
                    </div>
                  </div>
                </td>
                <td>{{ user.username }}</td>
                <td>
                  <span class="badge bg-label-primary">{{ user.systemRoleLabel }}</span>
                  {% if user.familyRoleLabel %}
                    <span class="badge bg-label-info ms-1">{{ user.familyRoleLabel }}</span>
                  {% endif %}
                </td>
                <td>
                  <span class="badge {{ user.statusBadgeClass }}">{{ user.statusLabel }}</span>
                </td>
                <td>{{ user.lastLogin ? user.lastLogin|date('d/m/Y H:i') : '—' }}</td>
                <td class="text-end">
                  <div class="btn-group">
                    <a href="{{ path('portal_admin_users_view', { id: user.id }) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                    <a href="{{ path('portal_admin_users_edit', { id: user.id }) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                  </div>
                </td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>

    <div class="card-footer d-flex justify-content-between align-items-center">
      <div class="text-muted">Affichage {{ paginationMeta.first }}-{{ paginationMeta.last }} sur {{ paginationMeta.total }} utilisateurs</div>
      <div>{{ knp_pagination_render(pagination) }}</div>
    </div>
  </div>
{% endblock %}
