{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Familles{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Familles</h4>
      <p class="text-muted mb-0">Gérez les dossiers et codes d’accès.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-primary" href="{{ path('portal_admin_families_new') }}">Nouvelle famille</a>
      <form class="d-flex" method="get" action="{{ path('portal_admin_families_index') }}">
        <input type="search" class="form-control me-3" placeholder="Nom ou code" name="q" value="{{ filters.query }}" />
        <select class="form-select me-3" name="sort">
          <option value="createdAt" {{ filters.sort == 'createdAt' ? 'selected' }}>Plus récents</option>
          <option value="name" {{ filters.sort == 'name' ? 'selected' }}>Nom</option>
          <option value="joinCode" {{ filters.sort == 'joinCode' ? 'selected' }}>Code d’accès</option>
        </select>
        <select class="form-select me-3" name="dir">
          <option value="DESC" {{ filters.direction == 'DESC' ? 'selected' }}>Desc</option>
          <option value="ASC" {{ filters.direction == 'ASC' ? 'selected' }}>Asc</option>
        </select>
        <button class="btn btn-primary" type="submit">Appliquer</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>Famille</th>
            <th>Code d’accès</th>
            <th>Expiration</th>
            <th>Création</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% if families is empty %}
            <tr>
              <td colspan="5" class="text-center text-muted py-6">Aucune famille trouvée.</td>
            </tr>
          {% else %}
            {% for family in families %}
              <tr>
                <td>
                  <div class="fw-semibold">{{ family.name }}</div>
                  <div class="text-muted small">#{{ family.id }}</div>
                </td>
                <td>{{ family.joinCode ?? '—' }}</td>
                <td>{{ family.codeExpiresAt ? family.codeExpiresAt|date('d/m/Y H:i') : '—' }}</td>
                <td>{{ family.createdAt ? family.createdAt|date('d/m/Y') : '—' }}</td>
                <td class="text-end">
                  <div class="btn-group">
                    <a href="{{ path('portal_admin_families_edit', { id: family.id }) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    <form method="post" action="{{ path('portal_admin_families_delete', { id: family.id }) }}">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_family_' ~ family.id) }}" />
                      <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
