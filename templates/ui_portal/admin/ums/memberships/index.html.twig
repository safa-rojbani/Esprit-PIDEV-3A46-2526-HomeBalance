{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Adhésions{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Adhésions familiales</h4>
      <p class="text-muted mb-0">Consultez les adhésions actives et passées.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-primary" href="{{ path('portal_admin_memberships_new') }}">Nouvelle adhésion</a>
      <form class="d-flex" method="get" action="{{ path('portal_admin_memberships_index') }}">
        <input type="search" class="form-control me-3" placeholder="Utilisateur ou famille" name="q" value="{{ filters.query }}" />
        <select class="form-select me-3" name="sort">
          <option value="joinedAt" {{ filters.sort == 'joinedAt' ? 'selected' }}>Rejoint</option>
          <option value="role" {{ filters.sort == 'role' ? 'selected' }}>Rôle</option>
        </select>
        <select class="form-select me-3" name="dir">
          <option value="DESC" {{ filters.direction == 'DESC' ? 'selected' }}>Desc</option>
          <option value="ASC" {{ filters.direction == 'ASC' ? 'selected' }}>Asc</option>
        </select>
        <button class="btn btn-primary" type="submit">Appliquer</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Famille</th>
            <th>Rôle</th>
            <th>Rejoint</th>
            <th>Sorti</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% if memberships is empty %}
            <tr>
              <td colspan="6" class="text-center text-muted py-6">Aucune adhésion trouvée.</td>
            </tr>
          {% else %}
            {% for group in groupedMemberships %}
              <tr class="table-light">
                <td colspan="6">
                  <strong>{{ group.family ? group.family.getName() : 'Famille non assignée' }}</strong>
                  {% if group.family %}
                    <small class="text-muted ms-2">#{{ group.family.getId() }}</small>
                  {% endif %}
                </td>
              </tr>
              {% for membership in group.memberships %}
                <tr>
                  <td>{{ membership.user ? membership.user.getUserIdentifier() : '—' }}</td>
                  <td>{{ membership.family ? membership.family.getName() : '—' }}</td>
                  <td>{{ membership.getRole().name|title }}</td>
                  <td>{{ membership.getJoinedAt() ? membership.getJoinedAt()|date('d/m/Y H:i') : '—' }}</td>
                  <td>{{ membership.getLeftAt() ? membership.getLeftAt()|date('d/m/Y H:i') : '—' }}</td>
                  <td class="text-end">
                    <div class="btn-group">
                      <a href="{{ path('portal_admin_memberships_edit', { id: membership.id }) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                      <form method="post" action="{{ path('portal_admin_memberships_delete', { id: membership.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_membership_' ~ membership.getFamily().getId() ~ '_' ~ membership.getUser().getId()) }}" />
                        <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                      </form>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
