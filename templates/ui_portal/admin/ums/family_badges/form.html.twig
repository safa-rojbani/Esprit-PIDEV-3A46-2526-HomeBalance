{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · {{ title }}{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">{{ title }}</h4>
      <p class="text-muted mb-0">Manage family badge awards.</p>
    </div>
    <a href="{{ path('portal_admin_family_badges_index') }}" class="btn btn-outline-secondary">Back to list</a>
  </div>

  {% if formErrors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0 ps-3">
        {% for error in formErrors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="card">
    <div class="card-body">
      {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
      <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.family) }}</div>
        <div class="col-md-6">{{ form_row(form.badge) }}</div>
        <div class="col-md-6">{{ form_row(form.awardedAt) }}</div>
      </div>
      <div class="mt-4 d-flex justify-content-end gap-2">
        <a href="{{ path('portal_admin_family_badges_index') }}" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary" type="submit">Save</button>
      </div>
      {{ form_end(form) }}
    </div>
  </div>
{% endblock %}
