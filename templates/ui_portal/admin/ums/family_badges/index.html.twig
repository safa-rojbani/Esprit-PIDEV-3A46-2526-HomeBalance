{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Family Badges{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Family Badges</h4>
      <p class="text-muted mb-0">Track awarded badges tied to families.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-primary" href="{{ path('portal_admin_family_badges_new') }}">New family badge</a>
      <form class="d-flex" method="get" action="{{ path('portal_admin_family_badges_index') }}">
        <input type="search" class="form-control me-3" placeholder="Search by family or badge" name="q" value="{{ filters.query }}" />
        <select class="form-select me-3" name="sort">
          <option value="awardedAt" {{ filters.sort == 'awardedAt' ? 'selected' }}>Awarded</option>
        </select>
        <select class="form-select me-3" name="dir">
          <option value="DESC" {{ filters.direction == 'DESC' ? 'selected' }}>Desc</option>
          <option value="ASC" {{ filters.direction == 'ASC' ? 'selected' }}>Asc</option>
        </select>
        <button class="btn btn-primary" type="submit">Apply</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>Family</th>
            <th>Badge</th>
            <th>Awarded</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% if records is empty %}
            <tr>
              <td colspan="4" class="text-center text-muted py-6">No family badges found.</td>
            </tr>
          {% else %}
            {% for record in records %}
              <tr>
                <td>{{ record.family ? record.family.name : '—' }}</td>
                <td>{{ record.badge ? record.badge.name : '—' }}</td>
                <td>{{ record.awardedAt ? record.awardedAt|date('Y-m-d H:i') : '—' }}</td>
                <td class="text-end">
                  <div class="btn-group">
                    <a href="{{ path('portal_admin_family_badges_edit', { id: record.id }) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form method="post" action="{{ path('portal_admin_family_badges_delete', { id: record.id }) }}">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_family_badge_' ~ record.id) }}" />
                      <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
