{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Notifications{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Account Notifications</h4>
      <p class="text-muted mb-0">Review delivery attempts and failure states.</p>
    </div>
    <form class="d-flex" method="get" action="{{ path('portal_admin_notifications_index') }}">
      <select class="form-select me-3" name="status">
        <option value="" {{ status is null ? 'selected' }}>All statuses</option>
        {% for value in ['PENDING', 'SENT', 'FAILED', 'SKIPPED'] %}
          <option value="{{ value }}" {{ status == value ? 'selected' }}>{{ value|title }}</option>
        {% endfor %}
      </select>
      <button class="btn btn-primary" type="submit">Filter</button>
    </form>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>User</th>
            <th>Key</th>
            <th>Channel</th>
            <th>Status</th>
            <th>Attempts</th>
            <th>Created</th>
            <th>Sent</th>
            <th>Last Error</th>
          </tr>
        </thead>
        <tbody>
          {% if notifications is empty %}
            <tr>
              <td colspan="8" class="text-center text-muted py-6">No notifications found.</td>
            </tr>
          {% else %}
            {% for notification in notifications %}
              <tr>
                <td>
                  <div class="fw-semibold">{{ notification.user.email }}</div>
                  <small class="text-muted">{{ notification.user.username }}</small>
                </td>
                <td>{{ notification.key }}</td>
                <td>{{ notification.channel }}</td>
                <td>
                  <span class="badge bg-label-{{ notification.status == 'FAILED' ? 'danger' : (notification.status == 'SENT' ? 'success' : 'secondary') }}">
                    {{ notification.status|title }}
                  </span>
                </td>
                <td>{{ notification.attempts }}</td>
                <td>{{ notification.createdAt|date('Y-m-d H:i') }}</td>
                <td>{{ notification.sentAt ? notification.sentAt|date('Y-m-d H:i') : '—' }}</td>
                <td>{{ notification.lastError ?? '—' }}</td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
