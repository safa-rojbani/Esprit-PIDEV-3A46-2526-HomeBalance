{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Admin · Support Tickets{% endblock %}

{% block content %}
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
      <h4 class="mb-0">Support Tickets</h4>
      <p class="text-muted mb-0">View and manage all user support requests.</p>
    </div>
    <form class="d-flex gap-2" method="get" action="{{ path('portal_admin_support_index') }}">
      <select class="form-select" name="status" onchange="this.form.submit()">
        {% for value, label in filters.statusChoices %}
          <option value="{{ value }}" {{ filters.status == value ? 'selected' }}>{{ label }}</option>
        {% endfor %}
      </select>
    </form>
  </div>

  <div class="card">
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Subject</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Created</th>
            <th>Replies</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% if tickets is empty %}
            <tr>
              <td colspan="8" class="text-center text-muted py-6">No tickets found.</td>
            </tr>
          {% else %}
            {% for ticket in tickets %}
              <tr>
                <td><strong>#{{ ticket.id }}</strong></td>
                <td>
                  {% if ticket.user %}
                    {{ ticket.user.firstName }} {{ ticket.user.lastName }}
                    <br><small class="text-muted">{{ ticket.user.email }}</small>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>
                <td>{{ ticket.subject|length > 40 ? ticket.subject|slice(0, 40) ~ '…' : ticket.subject }}</td>
                <td>
                  <span class="badge {{ ticket.statusBadgeClass }}">
                    {{ ticket.status ? ticket.status.value|replace({'_': ' '})|upper : '—' }}
                  </span>
                </td>
                <td>
                  <span class="badge {{ ticket.priorityBadgeClass }}">
                    {{ ticket.priority ? ticket.priority.value|upper : '—' }}
                  </span>
                </td>
                <td>{{ ticket.createdAt ? ticket.createdAt|date('M d, Y H:i') : '—' }}</td>
                <td>
                  <span class="badge bg-label-secondary">{{ ticket.messages|length }}</span>
                </td>
                <td class="text-end">
                  <a href="{{ path('portal_admin_support_show', { id: ticket.id }) }}" class="btn btn-sm btn-outline-primary">
                    <i class="bx bx-show me-1"></i> View
                  </a>
                </td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
