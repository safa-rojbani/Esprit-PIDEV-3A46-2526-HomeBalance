{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Connexion · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Votre foyer, en un seul endroit</p>
  <h1>Heureux de vous revoir sur HomeBalance.</h1>
  <h2 class="visually-hidden">Connexion HomeBalance</h2>
  <p class="lead">
    Chaque tâche compte. Connectez-vous pour voir comment votre foyer avance aujourd’hui.
  </p>
  <div class="hero-insight" data-controller="clock-pill">
    <span data-clock-pill-target="label">{{ 'now'|date('H:i') }}</span>
    <small>Heure locale</small>
  </div>
{% endblock %}

{% block panel_subtitle %}Retrouvons votre espace familial{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Connexion à votre espace</h2>
    <p class="text-muted">Gérez les tâches, suivez le budget et gardez un foyer serein, sans pression.</p>
  </div>

  {% if error %}
    <div class="alert alert-danger" role="alert">
      {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
  {% endif %}

  <form
    id="formAuthentication"
    class="stack-lg"
    method="post"
    action="{{ path('portal_auth_login') }}"
    data-controller="login-form"
    data-login-form-last-value="{{ last_username }}"
    data-turbo="false"
    novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="username"
        name="_username"
        placeholder="E-mail ou identifiant"
        value="{{ last_username }}"
        autocomplete="username"
        data-login-form-target="username" />
      <span>E-mail ou identifiant</span>
    </label>
    <small class="field-hint text-muted">L’e-mail utilisé pour créer votre compte HomeBalance.</small>

    <div class="form-password-toggle" data-controller="password-visibility">
      <label class="form-floating">
        <input
          type="password"
          id="password"
          class="form-control"
          name="_password"
          placeholder="Mot de passe"
          autocomplete="current-password"
          data-password-visibility-target="input" />
        <span>Mot de passe</span>
        <button
          class="password-toggle"
          type="button"
          aria-label="Afficher ou masquer le mot de passe"
          data-action="password-visibility#toggle"
          data-password-visibility-target="toggle">
          <i class="icon-base bx bx-hide"></i>
        </button>
      </label>
      <small class="field-hint text-muted">Votre clé privée pour l’espace familial.</small>
    </div>

    <div class="d-flex justify-content-between align-items-center">
      <label class="form-check">
        <input class="form-check-input" type="checkbox" id="remember-me" name="_remember_me" />
        <span class="form-check-label">Rester connecté sur cet appareil</span>
      </label>
      <div class="text-end">
        <a class="link-muted" href="{{ path('portal_auth_forgot_password') }}">Mot de passe oublié ?</a>
        <small class="text-muted d-block">Ça arrive. On vous aide à revenir.</small>
        <small class="text-muted d-block mt-1">
          Besoin d’un nouvel e-mail de vérification ?
          <a class="link-underline" href="{{ path('portal_auth_resend_verification') }}">Le renvoyer</a>
        </small>
      </div>
    </div>

    <button class="btn btn-primary w-100" type="submit">Entrer</button>
  </form>

  <p class="text-center mb-0">
    <span class="text-muted">Nouveau ici ?</span>
    <a href="{{ path('portal_auth_register') }}" class="link-underline">Créer un compte et commencer</a>
  </p>
{% endblock %}
