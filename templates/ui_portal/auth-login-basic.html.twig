{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Sign in · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Your household, all in one place</p>
  <h1>Welcome back to HomeBalance.</h1>
  <h2 class="visually-hidden">HomeBalance sign in</h2>
  <p class="lead">
    Every task, every contribution, every small effort matters. Log in to see how your household is moving forward today.
  </p>
  <div class="hero-insight" data-controller="clock-pill">
    <span data-clock-pill-target="label">{{ 'now'|date('g:i a') }}</span>
    <small>Local time</small>
  </div>
{% endblock %}

{% block panel_subtitle %}Let's check in on your home{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Sign in to your space</h2>
    <p class="text-muted">Log in to manage chores, track expenses, and keep your household balanced without the pressure.</p>
  </div>

  {% if error %}
    <div class="alert alert-danger" role="alert">
      {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
  {% endif %}

  <form
    id="formAuthentication"
    class="stack-lg"
    method="post"
    action="{{ path('portal_auth_login') }}"
    data-controller="login-form"
    data-login-form-last-value="{{ last_username }}"
    data-turbo="false"
    novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="username"
        name="_username"
        placeholder="Email or username"
        value="{{ last_username }}"
        autocomplete="username"
        data-login-form-target="username" />
      <span>Email or username</span>
    </label>
    <small class="field-hint text-muted">The email you used to create your HomeBalance account.</small>

    <div class="form-password-toggle" data-controller="password-visibility">
      <label class="form-floating">
        <input
          type="password"
          id="password"
          class="form-control"
          name="_password"
          placeholder="Password"
          autocomplete="current-password"
          data-password-visibility-target="input" />
        <span>Password</span>
        <button
          class="password-toggle"
          type="button"
          aria-label="Toggle password visibility"
          data-action="password-visibility#toggle"
          data-password-visibility-target="toggle">
          <i class="icon-base bx bx-hide"></i>
        </button>
      </label>
      <small class="field-hint text-muted">Your private key to your household space.</small>
    </div>

    <div class="d-flex justify-content-between align-items-center">
      <label class="form-check">
        <input class="form-check-input" type="checkbox" id="remember-me" name="_remember_me" />
        <span class="form-check-label">Keep me signed in on this device</span>
      </label>
      <div class="text-end">
        <a class="link-muted" href="{{ path('portal_auth_forgot_password') }}">Forgot password?</a>
        <small class="text-muted d-block">It happens. Let's get you back in.</small>
        <small class="text-muted d-block mt-1">
          Need a new verification email?
          <a class="link-underline" href="{{ path('portal_auth_resend_verification') }}">Send it again</a>
        </small>
      </div>
    </div>

    <button class="btn btn-primary w-100" type="submit">Head home</button>
  </form>

  <p class="text-center mb-0">
    <span class="text-muted">New here?</span>
    <a href="{{ path('portal_auth_register') }}" class="link-underline">Create an account and start building balance</a>
  </p>
{% endblock %}
