{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Créer un compte · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Démarrage centré sur la famille</p>
  <h1>Organisez votre foyer à votre façon.</h1>
  <p class="lead">
    HomeBalance vous aide à partager les responsabilités, gérer le budget et garder un foyer clair — seul ou à plusieurs.
    Vous pouvez rejoindre un foyer existant avec un code, ou démarrer de votre côté.
  </p>
  <div class="hero-metrics">
    <div>
      <span class="metric">Compte d’abord</span>
      <small>Ce compte vous appartient. Vous choisirez plus tard si vous rejoignez un foyer.</small>
    </div>
    <div>
      <span class="metric">Flexible</span>
      <small>Sans pression. Vous pouvez ajuster votre organisation à tout moment.</small>
    </div>
  </div>
{% endblock %}

{% block panel_subtitle %}Créez votre compte HomeBalance{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Parlez-nous un peu de vous</h2>
    <p class="text-muted">Cela aide HomeBalance à adapter tâches, rappels et suggestions. Vous pourrez modifier plus tard.</p>
  </div>

  {% if registrationErrors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0 ps-3">
        {% for error in registrationErrors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <form
    id="formAuthentication"
    class="stack-lg"
    method="post"
    action="{{ path('portal_auth_register') }}"
    data-controller="registration-form"
    data-turbo="false"
    novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('register_user') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="username"
        name="username"
        placeholder="Identifiant"
        value="{{ registration.username }}"
        autocomplete="username"
        data-registration-form-target="username" />
      <span>Identifiant</span>
    </label>

    <div class="row g-3">
      <div class="col-sm-6">
        <label class="form-floating">
          <input
            type="text"
            class="form-control"
            id="first_name"
            name="first_name"
            placeholder="Prénom"
            value="{{ registration.first_name }}"
            autocomplete="given-name"
            data-registration-form-target="firstName" />
          <span>Prénom</span>
        </label>
      </div>
      <div class="col-sm-6">
        <label class="form-floating">
          <input
            type="text"
            class="form-control"
            id="last_name"
            name="last_name"
            placeholder="Nom"
            value="{{ registration.last_name }}"
            autocomplete="family-name"
            data-registration-form-target="lastName" />
          <span>Nom</span>
        </label>
      </div>
    </div>

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="email"
        name="email"
        placeholder="E-mail"
        value="{{ registration.email }}"
        autocomplete="email" />
      <span>E-mail</span>
    </label>
    <small class="field-hint text-muted mb-3 d-block">Utilisez l’e-mail où vous souhaitez recevoir les infos HomeBalance.</small>

    <div class="form-password-toggle" data-controller="password-visibility">
      <label class="form-floating">
        <input
          type="password"
          id="password"
          class="form-control"
          name="password"
          placeholder="Mot de passe"
          autocomplete="new-password"
          data-password-visibility-target="input" />
        <span>Mot de passe</span>
        <button
          class="password-toggle"
          type="button"
          aria-label="Afficher ou masquer le mot de passe"
          data-action="password-visibility#toggle"
          data-password-visibility-target="toggle">
          <i class="icon-base bx bx-hide"></i>
        </button>
      </label>
      <small class="field-hint text-muted">Choisissez un mot de passe simple à retenir — votre foyer compte sur vous.</small>
    </div>

    <label class="form-check align-items-start">
      <input class="form-check-input" type="checkbox" id="terms" name="terms" {{ registration.terms ? 'checked' }} />
      <span class="form-check-label">
        J’accepte la
        <a class="link-underline" href="https://homebalance.app/legal" target="_blank" rel="noreferrer">politique de confidentialité et les conditions</a>.
      </span>
    </label>
    <small class="text-muted d-block mb-3">Vous recevrez un lien de vérification par e-mail juste après.</small>

    <button class="btn btn-primary w-100">Créer mon compte</button>
    <small class="d-block text-center text-muted mt-3">Sans pression — vous pourrez revenir dessus plus tard.</small>
  </form>

  <p class="text-center mb-0">
    <span class="text-muted">Déjà membre de HomeBalance ?</span>
    <a href="{{ path('portal_auth_login') }}" class="link-underline">Se connecter</a>
  </p>
{% endblock %}
