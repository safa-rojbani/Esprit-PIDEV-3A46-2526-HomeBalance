{% set account_menus = ['account', 'notifications', 'preferences'] %}
{% set admin_menus = ['admin-console', 'admin-users', 'admin-badges', 'admin-notifications', 'admin-families', 'admin-invitations', 'admin-memberships', 'admin-ums-badges', 'admin-family-badges', 'admin-account-notifications', 'admin-audit-trails', 'admin-security-ai'] %}
{% set current_route = app.request.attributes.get('_route') %}
{% set is_portal_admin = is_granted('ROLE_ADMIN') %}
{% set family_role_value = (app.user and app.user.familyRole) ? app.user.familyRole.value : null %}
{% set is_child_member = family_role_value == 'CHILD' %}
{% set module_submenus = module_submenus|default({}) %}
{% set documents_main_route = is_portal_admin ? 'app_default_gallery_index' : 'app_gallery_index' %}
{% set module_items = [
  {
    key: 'module-charge',
    route: is_portal_admin ? 'app_categorie_achat_index' : 'app_achat_index',
    label: 'Budget',
    icon: 'bx bx-wallet'
  },
  {
    key: 'module-documents',
    route: documents_main_route,
    label: 'Documents',
    icon: 'bx bx-folder'
  },
  {
    key: 'module-tasks',
    route: is_portal_admin ? 'admin_task_index' : (is_child_member ? 'child_task_index' : 'parent_task_index'),
    label: 'Taches',
    icon: 'bx bx-task'
  },
  {
    key: 'module-events',
    route: is_portal_admin ? 'admin_calendar' : 'app_calendar',
    label: 'Evenements',
    icon: 'bx bx-calendar'
  },
  {
    key: 'module-messaging',
    route: 'portal_messaging_index',
    label: 'Messagerie',
    icon: 'bx bx-chat'
  },
  {
    key: 'module-support',
    route: is_portal_admin ? 'portal_admin_support_index' : 'portal_support_index',
    label: 'Support',
    icon: 'bx bx-support'
  }
] %}
{% set default_module_keys = ['module-charge', 'module-documents', 'module-tasks', 'module-events', 'module-messaging', 'module-support'] %}
{% set selected_module_keys = default_module_keys %}
{% if app.user and app.user.preferences is defined and app.user.preferences.communication is defined and app.user.preferences.communication.modules is defined and app.user.preferences.communication.modules is iterable and app.user.preferences.communication.modules|length > 0 %}
  {% set selected_module_keys = app.user.preferences.communication.modules %}
{% endif %}

<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
  <div class="app-brand demo">
    <a href="{{ path('portal_account') }}" class="app-brand-link">
      <span class="app-brand-logo demo">
        <span class="text-primary">
          {% include 'ui_portal/partials/logo.svg.twig' %}
        </span>
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2">HomeBalance</span>
    </a>

    <a href="#layout-menu" class="layout-menu-toggle menu-link text-large ms-auto" aria-label="Collapse menu">
      <i class="bx bx-chevron-left d-block d-xl-none align-middle"></i>
    </a>
  </div>

  <div class="menu-divider mt-0"></div>
  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">
    <li class="menu-item {{ active_menu == 'dashboard' ? 'active' }}">
      <a href="{{ path('portal_dashboard') }}" class="menu-link">
        <i class="menu-icon tf-icons bx bx-home-circle"></i>
        <div class="text-truncate">Accueil</div>
      </a>
    </li>

    <li class="menu-header small text-uppercase"><span class="menu-header-text">Votre foyer</span></li>
    <li class="menu-item {{ active_menu in account_menus ? 'active open' }}">
      <a href="{{ path('portal_account') }}" class="menu-link">
        <i class="menu-icon tf-icons bx bx-dock-top"></i>
        <div class="text-truncate">Compte et profil</div>
      </a>
      <ul class="menu-sub" id="account-settings-menu">
        <li class="menu-item {{ active_menu == 'account' ? 'active' }}">
          <a href="{{ path('portal_account') }}" class="menu-link">
            <div class="text-truncate">Informations personnelles</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'notifications' ? 'active' }}">
          <a href="{{ path('portal_account_notifications') }}" class="menu-link">
            <div class="text-truncate">Notifications</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'preferences' ? 'active' }}">
          <a href="{{ path('portal_account_preferences') }}" class="menu-link">
            <div class="text-truncate">Preferences</div>
          </a>
        </li>
      </ul>
    </li>

    <li class="menu-header small text-uppercase"><span class="menu-header-text">Modules</span></li>
    {% for module in module_items %}
      {% if module.key in selected_module_keys %}
        {% set subitems = module_submenus[module.key]|default([]) %}
        {% set sub_active = false %}
        {% for item in subitems %}
          {% if current_route == item.route %}
            {% set sub_active = true %}
          {% endif %}
        {% endfor %}
        {% set is_open = active_menu == module.key or sub_active %}

        <li class="menu-item {{ is_open ? 'active open' }}">
          <a href="{{ path(module.route) }}" class="menu-link">
            <i class="menu-icon tf-icons {{ module.icon }}"></i>
            <div class="text-truncate">{{ module.label }}</div>
          </a>

          {% if subitems|length and is_open %}
            <ul class="menu-sub" style="display:block;">
              {% for item in subitems %}
                <li class="menu-item {{ current_route == item.route ? 'active' }}">
                  <a href="{{ path(item.route) }}" class="menu-link">
                    <div class="text-truncate">{{ item.label }}</div>
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}

    {% if is_portal_admin %}
      <li class="menu-header small text-uppercase"><span class="menu-header-text">Administration</span></li>
      {% set console_open = active_menu in admin_menus %}
      <li class="menu-item {{ console_open ? 'active open' }}">
        <a href="javascript:void(0);" class="menu-link menu-toggle">
          <i class="menu-icon tf-icons bx bx-grid-alt"></i>
          <div class="text-truncate">Console UMS</div>
        </a>
        <ul class="menu-sub">
          <li class="menu-item {{ active_menu == 'admin-users' ? 'active' }}">
            <a href="{{ path('portal_admin_users') }}" class="menu-link">
              <div class="text-truncate">Users</div>
            </a>
          </li>
          <li class="menu-item {{ active_menu == 'admin-families' ? 'active' }}">
            <a href="{{ path('portal_admin_console_families') }}" class="menu-link">
              <div class="text-truncate">Families</div>
            </a>
          </li>
          <li class="menu-item {{ active_menu == 'admin-badges' ? 'active' }}">
            <a href="{{ path('portal_admin_console_badges') }}" class="menu-link">
              <div class="text-truncate">Badges</div>
            </a>
          </li>
          <li class="menu-item {{ active_menu == 'admin-notifications' ? 'active' }}">
            <a href="{{ path('portal_admin_console_notifications') }}" class="menu-link">
              <div class="text-truncate">Notifications</div>
            </a>
          </li>
          <li class="menu-item {{ active_menu == 'admin-security-ai' ? 'active' }}">
            <a href="{{ path('portal_admin_console_security_ai') }}" class="menu-link">
              <div class="text-truncate">Security & AI</div>
            </a>
          </li>
        </ul>
      </li>
    {% endif %}
  </ul>
</aside>
