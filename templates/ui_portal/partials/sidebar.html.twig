{% set account_menus = ['account', 'notifications', 'preferences'] %}
{% set auth_menus = ['auth-login', 'auth-register', 'auth-forgot-password'] %}
{% set admin_menus = ['admin-users', 'admin-badges', 'admin-notifications', 'admin-families', 'admin-invitations', 'admin-memberships', 'admin-ums-badges', 'admin-family-badges', 'admin-account-notifications', 'admin-audit-trails', 'admin-support'] %}

<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
  <div class="app-brand demo">
    <a href="{{ path('portal_account') }}" class="app-brand-link">
      <span class="app-brand-logo demo">
        <span class="text-primary">
          {% include 'ui_portal/partials/logo.svg.twig' %}
        </span>
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2">HomeBalance</span>
    </a>

    <a href="#layout-menu" class="layout-menu-toggle menu-link text-large ms-auto" aria-label="Collapse menu">
      <i class="bx bx-chevron-left d-block d-xl-none align-middle"></i>
    </a>
  </div>

  <div class="menu-divider mt-0"></div>
  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">
    <li class="menu-item {{ active_menu == 'dashboard' ? 'active' }}">
      <a href="{{ path('portal_dashboard') }}" class="menu-link">
        <i class="menu-icon tf-icons bx bx-home-circle"></i>
        <div class="text-truncate">Home</div>
      </a>
    </li>

    <li class="menu-header small text-uppercase"><span class="menu-header-text">Your household</span></li>
    <li class="menu-item {{ active_menu in account_menus ? 'active open' }}">
      <a
        href="{{ path('portal_account') }}"
        class="menu-link">
        <i class="menu-icon tf-icons bx bx-dock-top"></i>
        <div class="text-truncate">Account &amp; profile</div>
      </a>
      <ul class="menu-sub" id="account-settings-menu">
        <li class="menu-item {{ active_menu == 'account' ? 'active' }}">
          <a href="{{ path('portal_account') }}" class="menu-link">
            <div class="text-truncate">Personal info</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'notifications' ? 'active' }}">
          <a href="{{ path('portal_account_notifications') }}" class="menu-link">
            <div class="text-truncate">Notifications</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'preferences' ? 'active' }}">
          <a href="{{ path('portal_account_preferences') }}" class="menu-link">
            <div class="text-truncate">Preferences</div>
          </a>
        </li>
      </ul>
    </li>

    <li class="menu-item {{ active_menu == 'support' ? 'active' }}">
      <a href="{{ path('portal_support_index') }}" class="menu-link">
        <i class="menu-icon tf-icons bx bx-support"></i>
        <div class="text-truncate">Support</div>
      </a>
    </li>

    {% if not is_granted('ROLE_ADMIN') %}
    <li class="menu-item {{ active_menu == 'messaging' ? 'active' }}">
      <a href="{{ path('portal_messaging_index') }}" class="menu-link">
        <i class="menu-icon tf-icons bx bx-message-square-detail"></i>
        <div class="text-truncate">Messages</div>
      </a>
    </li>
    {% endif %}

    <li class="menu-header small text-uppercase"><span class="menu-header-text">Access pages</span></li>
    <li class="menu-item {{ active_menu in auth_menus ? 'active open' }}">
      <a
        href="#auth-pages-menu"
        class="menu-link menu-toggle"
        aria-controls="auth-pages-menu"
        aria-expanded="{{ active_menu in auth_menus ? 'true' : 'false' }}">
        <i class="menu-icon tf-icons bx bx-lock-open-alt"></i>
        <div class="text-truncate">Household access</div>
      </a>
      <ul class="menu-sub" id="auth-pages-menu">
        <li class="menu-item {{ active_menu == 'auth-login' ? 'active' }}">
          <a href="{{ path('portal_auth_login') }}" class="menu-link">
            <div class="text-truncate">Login</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'auth-register' ? 'active' }}">
          <a href="{{ path('portal_auth_register') }}" class="menu-link">
            <div class="text-truncate">Register</div>
          </a>
        </li>
        <li class="menu-item {{ active_menu == 'auth-forgot-password' ? 'active' }}">
          <a href="{{ path('portal_auth_forgot_password') }}" class="menu-link">
            <div class="text-truncate">Forgot Password</div>
          </a>
        </li>
      </ul>
    </li>

    {% if is_granted('ROLE_ADMIN') %}
      <li class="menu-header small text-uppercase"><span class="menu-header-text">Admin</span></li>
      <li class="menu-item {{ active_menu == 'admin-users' ? 'active' }}">
        <a href="{{ path('portal_admin_users') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-shield-quarter"></i>
          <div class="text-truncate">Manage users</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-families' ? 'active' }}">
        <a href="{{ path('portal_admin_families_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-home-heart"></i>
          <div class="text-truncate">Families</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-invitations' ? 'active' }}">
        <a href="{{ path('portal_admin_invitations_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-envelope"></i>
          <div class="text-truncate">Invitations</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-memberships' ? 'active' }}">
        <a href="{{ path('portal_admin_memberships_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-group"></i>
          <div class="text-truncate">Memberships</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-ums-badges' ? 'active' }}">
        <a href="{{ path('portal_admin_badges_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-medal"></i>
          <div class="text-truncate">Badges (CRUD)</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-family-badges' ? 'active' }}">
        <a href="{{ path('portal_admin_family_badges_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-medal"></i>
          <div class="text-truncate">Family Badges</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-account-notifications' ? 'active' }}">
        <a href="{{ path('portal_admin_account_notifications_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-bell"></i>
          <div class="text-truncate">Account Notifications</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-audit-trails' ? 'active' }}">
        <a href="{{ path('portal_admin_audit_trails_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-list-check"></i>
          <div class="text-truncate">Audit Trails</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-badges' ? 'active' }}">
        <a href="{{ path('portal_admin_gamification_badges') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-medal"></i>
          <div class="text-truncate">Gamification</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-notifications' ? 'active' }}">
        <a href="{{ path('portal_admin_notifications_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-bell"></i>
          <div class="text-truncate">Notifications</div>
        </a>
      </li>
      <li class="menu-item {{ active_menu == 'admin-support' ? 'active' }}">
        <a href="{{ path('portal_admin_support_index') }}" class="menu-link">
          <i class="menu-icon tf-icons bx bx-support"></i>
          <div class="text-truncate">Support Tickets</div>
        </a>
      </li>
    {% endif %}
  </ul>
</aside>
