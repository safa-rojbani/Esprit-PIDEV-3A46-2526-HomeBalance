          <li class="dropdown-menu-list" id="notifList" style="max-height: 320px; overflow-y: auto;"></li>
          <li class="dropdown-menu-footer border-top">
            <a class="dropdown-item text-center py-2" href="{{ path('app_notifications') }}">Voir tout</a>
          </li>
        </ul>
      </li>
