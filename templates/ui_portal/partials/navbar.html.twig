<nav
  class="layout-navbar container-xxl navbar-detached navbar navbar-expand-xl align-items-center bg-navbar-theme"
  id="layout-navbar">
  <div class="layout-menu-toggle navbar-nav align-items-xl-center me-4 me-xl-0 d-xl-none">
    <a class="nav-item nav-link px-0 me-xl-6" href="#layout-menu" aria-label="Toggle navigation">
      <i class="icon-base bx bx-menu icon-md"></i>
    </a>
  </div>

  <div class="navbar-nav-right d-flex align-items-center justify-content-end w-100" id="navbar-collapse">
    <div class="navbar-nav align-items-center me-auto">
      <form class="nav-item d-flex align-items-center" method="get" action="{{ path('portal_search') }}">
        <span class="w-px-22 h-px-22"><i class="icon-base bx bx-search icon-md"></i></span>
        <input
          type="text"
          name="q"
          class="form-control border-0 shadow-none ps-1 ps-sm-2 d-md-block d-none"
          placeholder="Rechercher dans votre foyer..."
          aria-label="Recherche"
          value="{{ app.request.query.get('q') }}" />
      </form>
    </div>

    <ul class="navbar-nav flex-row align-items-center ms-auto">
      {% if is_granted('ROLE_ADMIN') %}
        <li class="nav-item me-3 d-none d-md-inline-flex">
          <a class="btn btn-outline-primary d-flex align-items-center gap-2" href="{{ path('portal_admin_users') }}">
            <i class="icon-base bx bx-user-circle"></i>
            <span>Administration</span>
          </a>
        </li>
      {% endif %}
      <li class="nav-item navbar-dropdown dropdown-user dropdown">
        <a class="nav-link dropdown-toggle hide-arrow p-0" href="#accountMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
          <div class="avatar avatar-online" style="width: 3.25rem; height: 3.25rem;">
            {% set navbarAvatarPath = app.user ? app.user.avatarPath : null %}
            {% set navbarAvatarFallback = 'https://api.dicebear.com/9.x/adventurer/svg?seed=' ~ (app.user ? app.user.id : 'homebalance') %}
            {% set navbarAvatarHasUsablePath = navbarAvatarPath and ((navbarAvatarPath starts with 'http://') or (navbarAvatarPath starts with 'https://') or ('/' in navbarAvatarPath)) %}
            {% set navbarAvatarSrc = navbarAvatarHasUsablePath
              ? ((navbarAvatarPath starts with 'http://') or (navbarAvatarPath starts with 'https://') ? navbarAvatarPath : asset(navbarAvatarPath))
              : navbarAvatarFallback
            %}
            <img
              src="{{ navbarAvatarSrc }}"
              alt="User avatar"
              class="w-px-52 h-px-52 rounded-circle object-fit-cover"
              onerror="this.onerror=null;this.src='{{ navbarAvatarFallback }}';" />
          </div>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <a class="dropdown-item" href="{{ path('portal_account') }}">
              <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                  <h6 class="mb-0">{{ app.user ? (app.user.firstName ~ ' ' ~ app.user.lastName) : 'Utilisateur' }}</h6>
                  <small class="text-body-secondary">{{ app.user and is_granted('ROLE_ADMIN') ? 'Administrateur du foyer' : 'Membre' }}</small>
                </div>
              </div>
            </a>
          </li>
          <li><div class="dropdown-divider my-1"></div></li>
          <li>
            <a class="dropdown-item" href="{{ path('portal_account') }}">
              <i class="icon-base bx bx-user icon-md me-3"></i><span>Mon espace</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item" href="{{ path('portal_account_notifications') }}">
              <i class="icon-base bx bx-cog icon-md me-3"></i><span>Notifications</span>
            </a>
          </li>
          <li><div class="dropdown-divider my-1"></div></li>
          {% if is_granted('ROLE_ADMIN') %}
            <li>
              <a class="dropdown-item" href="{{ path('portal_admin_users') }}">
                <i class="icon-base bx bx-shield icon-md me-3"></i><span>Admin : utilisateurs</span>
              </a>
            </li>
            <li>
              <a class="dropdown-item" href="{{ path('portal_admin_console_families') }}">
                <i class="icon-base bx bx-grid-alt icon-md me-3"></i><span>Admin : console UMS</span>
              </a>
            </li>
            <li><div class="dropdown-divider my-1"></div></li>
          {% endif %}
          <li>
            <a class="dropdown-item" href="{{ path('portal_auth_logout') }}">
              <i class="icon-base bx bx-power-off icon-md me-3"></i><span>Se déconnecter</span>
            </a>
          </li>
        </ul>
      </li>
    </ul>
  </div>
</nav>
