{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Account Settings · Connections{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'connections' } %}

  <div class="card">
    <div class="row">
      <div class="col-md-6 col-12">
        <div class="card-header">
          <h5 class="mb-1">Apps you rely on</h5>
          <p class="my-0 card-subtitle">Choose which tools share info with HomeBalance so everyone stays in sync.</p>
        </div>
        <div class="card-body">
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/google.png') }}" alt="Google" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
              <div class="mb-sm-0 mb-2">
                <h6 class="mb-0">Google</h6>
                <small>Calendar &amp; contacts</small>
              </div>
              <div class="text-end">
                <div class="form-check form-switch mb-0">
                  <input type="checkbox" class="form-check-input" checked />
                </div>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/slack.png') }}" alt="Slack" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
              <div class="mb-sm-0 mb-2">
                <h6 class="mb-0">Slack</h6>
                <small>Household chat</small>
              </div>
              <div class="text-end">
                <div class="form-check form-switch mb-0">
                  <input type="checkbox" class="form-check-input" />
                </div>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/github.png') }}" alt="GitHub" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
              <div class="mb-sm-0 mb-2">
                <h6 class="mb-0">GitHub</h6>
                <small>Project notes &amp; lists</small>
              </div>
              <div class="text-end">
                <div class="form-check form-switch mb-0">
                  <input type="checkbox" class="form-check-input" checked />
                </div>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img
                src="{{ asset('img/icons/brands/mailchimp.png') }}"
                alt="Mailchimp"
                class="me-4"
                height="32" />
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
              <div class="mb-sm-0 mb-2">
                <h6 class="mb-0">Mailchimp</h6>
                <small>Family newsletters</small>
              </div>
              <div class="text-end">
                <div class="form-check form-switch mb-0">
                  <input type="checkbox" class="form-check-input" checked />
                </div>
              </div>
            </div>
          </div>
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/asana.png') }}" alt="Asana" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
              <div class="mb-sm-0 mb-2">
                <h6 class="mb-0">Asana</h6>
                <small>Task boards</small>
              </div>
              <div class="text-end">
                <div class="form-check form-switch mb-0">
                  <input type="checkbox" class="form-check-input" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-12">
        <div class="card-header">
          <h5 class="mb-1">Social circles</h5>
          <p class="my-0 card-subtitle">Link the spaces where your family already shares updates.</p>
        </div>
        <div class="card-body">
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/facebook.png') }}" alt="Facebook" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 row">
              <div class="col-7">
                <h6 class="mb-0">Facebook</h6>
                <small>Not connected</small>
              </div>
              <div class="col-5 text-end mt-sm-0 mt-2">
                <button class="btn btn-icon btn-outline-secondary">
                  <i class="icon-base bx bx-link icon-md"></i>
                </button>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/twitter.png') }}" alt="Twitter" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 row">
              <div class="col-7">
                <h6 class="mb-0">Twitter</h6>
                <a href="https://x.com/Theme_Selection" target="_blank" class="small">@ThemeSelection</a>
              </div>
              <div class="col-5 text-end mt-sm-0 mt-2">
                <button class="btn btn-icon btn-outline-danger">
                  <i class="icon-base bx bx-trash icon-md"></i>
                </button>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/instagram.png') }}" alt="Instagram" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 row">
              <div class="col-7">
                <h6 class="mb-0">Instagram</h6>
                <a href="https://www.instagram.com/themeselection/" target="_blank" class="small">@ThemeSelection</a>
              </div>
              <div class="col-5 text-end mt-sm-0 mt-2">
                <button class="btn btn-icon btn-outline-danger">
                  <i class="icon-base bx bx-trash icon-md"></i>
                </button>
              </div>
            </div>
          </div>
          <div class="d-flex mb-4 align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/dribbble.png') }}" alt="Dribbble" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 row">
              <div class="col-7">
                <h6 class="mb-0">Dribbble</h6>
                <small>Not connected</small>
              </div>
              <div class="col-5 text-end mt-sm-0 mt-2">
                <button class="btn btn-icon btn-outline-secondary">
                  <i class="icon-base bx bx-link icon-md"></i>
                </button>
              </div>
            </div>
          </div>
          <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
              <img src="{{ asset('img/icons/brands/behance.png') }}" alt="Behance" class="me-4" height="32" />
            </div>
            <div class="flex-grow-1 row align-items-center">
              <div class="col-7">
                <h6 class="mb-0">Behance</h6>
                <small>Not connected</small>
              </div>
              <div class="col-5 text-end">
                <button class="btn btn-icon btn-outline-secondary">
                  <i class="icon-base bx bx-link icon-md"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
