{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Account Settings · Personal Info{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'account' } %}

  <p class="text-muted mb-4">Keep these details up to date so HomeBalance can tailor reminders, finances, and gentle nudges for your household.</p>

  {% if accountErrors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0 ps-3">
        {% for error in accountErrors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <div class="card mb-6">
    <form id="formAccountSettings" method="post" action="{{ path('portal_account') }}" enctype="multipart/form-data" novalidate>
      <input type="hidden" name="_token" value="{{ csrf_token('account_update') }}" />
      <input type="hidden" name="section" value="profile" />
      <div class="card-body">
      <div class="d-flex align-items-start align-items-sm-center gap-6 pb-4 border-bottom">
        <img
          src="{{ accountForm.avatarPath ? asset(accountForm.avatarPath) : asset('img/avatars/1.png') }}"
          alt="User avatar"
          class="d-block w-px-100 h-px-100 rounded"
          id="uploadedAvatar" />
        <div class="button-wrapper">
          <label for="upload" class="btn btn-primary me-3 mb-4" tabindex="0">
            <span class="d-none d-sm-block">Update photo</span>
            <i class="icon-base bx bx-upload d-block d-sm-none"></i>
            <input
              type="file"
              id="upload"
              class="account-file-input"
              hidden
              accept="image/png, image/jpeg, image/gif, image/webp"
              name="avatar"
              onchange="this.form.submit()" />
          </label>
          <button type="submit" class="btn btn-outline-secondary account-image-reset mb-4" name="avatar_remove" value="1">
            <i class="icon-base bx bx-reset d-block d-sm-none"></i>
            <span class="d-none d-sm-block">Reset</span>
          </button>
          <div>Use JPG, PNG, GIF, or WebP up to 2 MB. Family photos welcome.</div>
        </div>
      </div>
      </div>
      <div class="card-body pt-4">
        <div class="row g-6">
          <div class="col-md-6">
            <label for="firstName" class="form-label">First Name</label>
            <input class="form-control" type="text" id="firstName" name="firstName" value="{{ accountForm.firstName }}" autofocus />
          </div>
          <div class="col-md-6">
            <label for="lastName" class="form-label">Last Name</label>
            <input class="form-control" type="text" name="lastName" id="lastName" value="{{ accountForm.lastName }}" />
          </div>
          <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center">
              <label for="email" class="form-label mb-0">E-mail</label>
              {% if app.user and app.user.emailVerifiedAt %}
                <span class="badge bg-label-success">Verified</span>
              {% else %}
                <a href="{{ path('portal_auth_resend_verification') }}" class="small">Verify now</a>
              {% endif %}
            </div>
            <input
              class="form-control"
              type="text"
              id="email"
              name="email"
              value="{{ accountForm.email }}"
              placeholder="you@example.com" />
          </div>
          <div class="col-md-6">
            <label for="organization" class="form-label">Household or organization</label>
            <input type="text" class="form-control" id="organization" name="organization" value="{{ accountForm.organization }}" />
          </div>
          <div class="col-md-6">
            <label class="form-label" for="phoneNumber">Phone Number</label>
            <div class="input-group input-group-merge">
              <span class="input-group-text">US (+1)</span>
              <input
                type="text"
                id="phoneNumber"
                name="phoneNumber"
                class="form-control"
                placeholder="202 555 0111"
                value="{{ accountForm.phoneNumber }}" />
            </div>
          </div>
          <div class="col-md-6">
            <label for="address" class="form-label">Address</label>
            <input type="text" class="form-control" id="address" name="address" placeholder="Address" value="{{ accountForm.address }}" />
          </div>
          <div class="col-md-6">
            <label for="state" class="form-label">State</label>
            <input class="form-control" type="text" id="state" name="state" placeholder="California" value="{{ accountForm.state }}" />
          </div>
          <div class="col-md-6">
            <label for="zipCode" class="form-label">Zip Code</label>
            <input
              type="text"
              class="form-control"
              id="zipCode"
              name="zipCode"
              placeholder="231465"
              maxlength="6"
              value="{{ accountForm.zipCode }}" />
          </div>
          <div class="col-md-6">
            <label class="form-label" for="country">Country</label>
            <select id="country" class="select2 form-select" name="country">
              <option value="">Select</option>
              <option value="Australia" {{ accountForm.country == 'Australia' ? 'selected' }}>Australia</option>
              <option value="Bangladesh">Bangladesh</option>
              <option value="Belarus">Belarus</option>
              <option value="Brazil">Brazil</option>
              <option value="Canada">Canada</option>
              <option value="China">China</option>
              <option value="France">France</option>
              <option value="Germany">Germany</option>
              <option value="India">India</option>
              <option value="Indonesia">Indonesia</option>
              <option value="Israel">Israel</option>
              <option value="Italy">Italy</option>
              <option value="Japan">Japan</option>
              <option value="Korea">Korea, Republic of</option>
              <option value="Mexico">Mexico</option>
              <option value="Philippines">Philippines</option>
              <option value="Russia">Russian Federation</option>
              <option value="South Africa">South Africa</option>
              <option value="Thailand">Thailand</option>
              <option value="Turkey">Turkey</option>
              <option value="Ukraine">Ukraine</option>
              <option value="United Arab Emirates">United Arab Emirates</option>
              <option value="United Kingdom" {{ accountForm.country == 'United Kingdom' ? 'selected' }}>United Kingdom</option>
              <option value="United States" {{ accountForm.country == 'United States' ? 'selected' }}>United States</option>
            </select>
          </div>
          <div class="col-md-6">
            <label for="language" class="form-label">Language</label>
            <select id="language" class="select2 form-select" name="language">
              <option value="">Select Language</option>
              <option value="en" {{ accountForm.language == 'en' ? 'selected' }}>English</option>
              <option value="fr" {{ accountForm.language == 'fr' ? 'selected' }}>French</option>
              <option value="de" {{ accountForm.language == 'de' ? 'selected' }}>German</option>
              <option value="pt" {{ accountForm.language == 'pt' ? 'selected' }}>Portuguese</option>
            </select>
          </div>
          <div class="col-md-6">
            <label for="timeZones" class="form-label">Timezone</label>
            <select id="timeZones" class="select2 form-select" name="timeZones">
              <option value="">Select Timezone</option>
              <option value="-12" {{ accountForm.timeZones == '-12' ? 'selected' }}>(GMT-12:00) International Date Line West</option>
              <option value="-11" {{ accountForm.timeZones == '-11' ? 'selected' }}>(GMT-11:00) Midway Island, Samoa</option>
              <option value="-10" {{ accountForm.timeZones == '-10' ? 'selected' }}>(GMT-10:00) Hawaii</option>
              <option value="-9" {{ accountForm.timeZones == '-9' ? 'selected' }}>(GMT-09:00) Alaska</option>
              <option value="-8" {{ accountForm.timeZones == '-8' ? 'selected' }}>(GMT-08:00) Pacific Time (US &amp; Canada)</option>
              <option value="-8">(GMT-08:00) Tijuana, Baja California</option>
              <option value="-7">(GMT-07:00) Arizona</option>
              <option value="-7">(GMT-07:00) Chihuahua, La Paz, Mazatlan</option>
              <option value="-7">(GMT-07:00) Mountain Time (US &amp; Canada)</option>
              <option value="-6">(GMT-06:00) Central America</option>
              <option value="-6">(GMT-06:00) Central Time (US &amp; Canada)</option>
              <option value="-6">(GMT-06:00) Guadalajara, Mexico City, Monterrey</option>
              <option value="-6">(GMT-06:00) Saskatchewan</option>
              <option value="-5">(GMT-05:00) Bogota, Lima, Quito, Rio Branco</option>
              <option value="-5">(GMT-05:00) Eastern Time (US &amp; Canada)</option>
              <option value="-5">(GMT-05:00) Indiana (East)</option>
              <option value="-4">(GMT-04:00) Atlantic Time (Canada)</option>
              <option value="-4">(GMT-04:00) Caracas, La Paz</option>
            </select>
          </div>
          <div class="col-md-6">
            <label for="currency" class="form-label">Currency</label>
            <select id="currency" class="select2 form-select" name="currency">
              <option value="">Select Currency</option>
              <option value="usd" {{ accountForm.currency == 'usd' ? 'selected' }}>USD</option>
              <option value="euro" {{ accountForm.currency == 'euro' ? 'selected' }}>Euro</option>
              <option value="pound" {{ accountForm.currency == 'pound' ? 'selected' }}>Pound</option>
              <option value="bitcoin" {{ accountForm.currency == 'bitcoin' ? 'selected' }}>Bitcoin</option>
            </select>
          </div>
        </div>
        <div class="mt-6">
          <button type="submit" class="btn btn-primary me-3">Save my details</button>
          <button type="reset" class="btn btn-outline-secondary">Reset</button>
        </div>
      </div>
    </form>
  </div>

  <div class="card mb-6">
    <div class="card-header">
      <h5 class="mb-0">Password &amp; security</h5>
      <small class="text-muted">Change your password whenever something feels off.</small>
    </div>
    <div class="card-body">
      <form method="post" action="{{ path('portal_account') }}" class="row g-6" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('account_password') }}" />
        <input type="hidden" name="section" value="password" />
        <div class="col-md-4">
          <label for="currentPassword" class="form-label">Current password</label>
          <input type="password" class="form-control" id="currentPassword" name="currentPassword" autocomplete="current-password" />
        </div>
        <div class="col-md-4">
          <label for="newPassword" class="form-label">New password</label>
          <input type="password" class="form-control" id="newPassword" name="newPassword" autocomplete="new-password" />
        </div>
        <div class="col-md-4">
          <label for="confirmPassword" class="form-label">Confirm password</label>
          <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" autocomplete="new-password" />
        </div>
        <div class="col-12 d-flex align-items-center">
          <button type="submit" class="btn btn-primary me-3">Update password</button>
          <small class="text-muted">At least 8 characters, ideally with a symbol or number.</small>
        </div>
      </form>
    </div>
  </div>

  <div class="card">
    <h5 class="card-header">Need a break?</h5>
    <div class="card-body">
      <div class="mb-6 col-12 mb-0">
        <div class="alert alert-warning">
          <h5 class="alert-heading mb-1">Deleting your account removes your household history.</h5>
          <p class="mb-0">Take a moment to be sure — once removed, we can&apos;t restore your past contributions.</p>
        </div>
      </div>
      <form id="formAccountDeactivation" method="post" action="{{ path('portal_account_delete') }}" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('account_delete') }}" />
        <div class="form-check my-8 ms-2">
          <input class="form-check-input" type="checkbox" name="accountActivation" id="accountActivation" />
          <label class="form-check-label" for="accountActivation">I understand my account will be removed</label>
        </div>
        <button type="submit" class="btn btn-danger deactivate-account">Delete my account</button>
      </form>
    </div>
  </div>

  <div class="card mt-6">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <h5 class="mb-0">Badges &amp; recognitions</h5>
        <small class="text-muted">A quick look at personal and family achievements.</small>
      </div>
    </div>
    <div class="card-body">
      <div class="row g-4">
        <div class="col-lg-6">
          <h6 class="fw-semibold mb-2">Your badges</h6>
          {% if metrics.badges is empty %}
            <p class="text-muted">No badges yet. Stay consistent with your routines to unlock them.</p>
          {% else %}
            <ul class="list-unstyled mb-0">
              {% for badge in metrics.badges %}
                <li class="mb-3">
                  <div class="fw-semibold">{{ badge.name }}</div>
                  <small class="text-muted">{{ badge.description ?? 'Earned through steady progress.' }}</small>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
        <div class="col-lg-6">
          <h6 class="fw-semibold mb-2">Family badges</h6>
          {% if metrics.familyBadges is empty %}
            <p class="text-muted">Invite someone to your household to start unlocking team badges.</p>
          {% else %}
            <ul class="list-unstyled mb-0">
              {% for badge in metrics.familyBadges %}
                <li class="mb-3">
                  <div class="fw-semibold">{{ badge.name }}</div>
                  <small class="text-muted">
                    {{ badge.description ?? 'Shared recognition for everyone' }}
                    {% if badge.awardedAt %}
                      · awarded {{ badge.awardedAt|date('M d') }}
                    {% endif %}
                  </small>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block extra_javascripts %}
  {{ parent() }}
  <script src="{{ asset('js/pages-account-settings-account.js') }}"></script>
{% endblock %}
