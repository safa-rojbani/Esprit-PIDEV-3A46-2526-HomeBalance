<!doctype html>
<html
  lang="en"
  class="layout-wide customizer-hide"
  data-assets-path="{{ asset('') }}"
  data-template="vertical-menu-template-free">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>{% block title %}HomeBalance · Reset Password{% endblock %}</title>

    <meta name="description" content="" />

    <link rel="icon" type="image/svg+xml" href="{{ asset('img/favicon/favicon.svg') }}" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet" />

    <link rel="stylesheet" href="{{ asset('vendor/fonts/iconify-icons.css') }}" />

    <link rel="stylesheet" href="{{ asset('vendor/css/core.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/demo.css') }}" />
    <link rel="stylesheet" href="{{ asset('vendor/libs/perfect-scrollbar/perfect-scrollbar.css') }}" />
    <link rel="stylesheet" href="{{ asset('vendor/css/pages/page-auth.css') }}" />

    <script src="{{ asset('vendor/js/helpers.js') }}"></script>
    <script src="{{ asset('js/config.js') }}"></script>
  </head>

  <body>
    <div class="container-xxl">
      <div class="authentication-wrapper authentication-basic container-p-y">
        <div class="authentication-inner">
          <div class="card px-sm-6 px-0">
            <div class="card-body">
              <div class="app-brand justify-content-center mb-6">
                <a href="{{ path('portal_account') }}" class="app-brand-link gap-2">
                  <span class="app-brand-logo demo">
                    <span class="text-primary">
                      {% include 'ui_portal/partials/logo.svg.twig' %}
                    </span>
                  </span>
                  <span class="app-brand-text demo text-heading fw-bold">HomeBalance</span>
                </a>
              </div>
              <h4 class="mb-1">Need a fresh start?</h4>
              <p class="mb-6">It happens. Enter the email tied to your household and we&apos;ll guide you back in.</p>

              {% for message in app.flashes('success') %}
                <div class="alert alert-success" role="alert">{{ message }}</div>
              {% endfor %}
              {% for message in app.flashes('error') %}
                <div class="alert alert-danger" role="alert">{{ message }}</div>
              {% endfor %}

              <form id="formAuthentication" class="mb-6" method="post" action="{{ path('portal_auth_forgot_password') }}" data-turbo="false" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}" />
                <div class="mb-6">
                  <label for="email" class="form-label">Email</label>
                  <input
                    type="text"
                    class="form-control"
                    id="email"
                    name="email"
                    placeholder="The email you used for HomeBalance"
                    autofocus
                    value="{{ forgot.email }}" />
                </div>
                <button class="btn btn-primary d-grid w-100">Send Reset Link</button>
              </form>
              <div class="text-center">
                <a href="{{ path('portal_auth_login') }}" class="d-flex justify-content-center">
                  <i class="icon-base bx bx-chevron-left me-1"></i>
                  Back to sign in
                </a>
                <small class="text-muted d-block mt-1">Take your time — your household will be here.</small>
                <small class="text-muted d-block mt-2">
                  Need to verify your email instead?
                  <a class="link-underline" href="{{ path('portal_auth_resend_verification') }}">Resend verification link</a>
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="{{ asset('vendor/libs/jquery/jquery.js') }}"></script>
    <script src="{{ asset('vendor/libs/popper/popper.js') }}"></script>
    <script src="{{ asset('vendor/js/bootstrap.js') }}"></script>
    <script src="{{ asset('vendor/libs/perfect-scrollbar/perfect-scrollbar.js') }}"></script>
    <script src="{{ asset('vendor/js/menu.js') }}"></script>
    <script src="{{ asset('js/main.js') }}"></script>
  </body>
</html>
