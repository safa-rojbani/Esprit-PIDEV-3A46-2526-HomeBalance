{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}HomeBalance · Accueil{% endblock %}

{% block content %}
  {% set familyCount = metrics.familyMembers|default(1) %}
  {% set soloAccount = familyCount <= 1 %}
  {% set moduleStats = moduleStats|default({
    tasksActive: 0,
    upcomingEvents: 0,
    pendingPurchases: 0,
    documentsStored: 0,
    unreadReminders: 0
  }) %}
  <div class="row g-4 mb-4">
    <div class="col-xl-7">
      <div class="card gradient-card orbit-card h-100" data-controller="orbit-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="text-uppercase fw-medium text-white-50 mb-1">Votre foyer aujourd’hui</p>
              <h4 class="text-white mb-1">Ravi de vous revoir, {{ user.firstName ?? user.username }}.</h4>
              <p class="text-white-75 mb-0">
                {% if soloAccount %}
                  Voici un aperçu de votre journée pour garder le cap.
                {% else %}
                  Voici ce qui se passe aujourd’hui dans votre foyer pour que tout le monde reste aligné.
                {% endif %}
              </p>
            </div>
            <span class="orbit-chip">
              <small>Aujourd’hui</small>
              <strong>{{ "now"|date('d M') }}</strong>
            </span>
          </div>
          <div class="orbit-strip mt-4" data-controller="streak-meter" data-streak-meter-count-value="{{ metrics.badgeCount }}">
            <div>
              <h5 class="text-white mb-0">{{ metrics.badgeCount }}</h5>
              <small class="text-white-50">Vos contributions</small>
            </div>
            <div>
              <h5 class="text-white mb-0">{{ metrics.familyMembers }}</h5>
              <small class="text-white-50">Personnes dans le foyer</small>
            </div>
            <div>
              <h5 class="text-white mb-0">{{ recentActivity|length }}</h5>
              <small class="text-white-50">Moments enregistrés</small>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-5">
      <div class="card pulse-card h-100" data-controller="pulse-card" data-pulse-card-score-value="{{ engagement.score }}">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <p class="text-uppercase text-muted mb-1">Vos contributions</p>
              <h4 class="mb-0">{{ engagement.score }}%</h4>
            </div>
            <span class="badge bg-label-primary">Canal {{ engagement.delivery|title }}</span>
          </div>
          <div class="pulse-ring" data-pulse-card-target="ring">
            <div class="pulse-ring__value" data-pulse-card-target="value">{{ engagement.score }}%</div>
          </div>
          <ul class="pulse-meta list-unstyled mb-0 mt-4">
            <li>
              <span class="text-muted">Famille</span>
              <strong>{{ engagement.familyName ?? 'Compte solo' }}</strong>
            </li>
            <li>
              <span class="text-muted">Dernière activité</span>
              <strong>{{ engagement.lastLogin ? engagement.lastLogin|date('d M, H:i') : 'Pas encore enregistré' }}</strong>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  {% if metrics.badges is not empty or metrics.familyBadges is not empty %}
    <div class="row g-4 mb-4">
      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">Vos badges</h5>
              <small class="text-muted">Des repères personnels obtenus grâce à vos actions.</small>
            </div>
          </div>
          <div class="card-body">
            {% if metrics.badges is empty %}
              <p class="text-muted mb-0">Pas encore de badge. Continuez à avancer pour les débloquer.</p>
            {% else %}
              <div class="d-flex flex-wrap gap-3">
                {% for badge in metrics.badges %}
                  <div class="badge-tile border rounded p-3 flex-grow-1" style="min-width: 180px;">
                    <div class="d-flex align-items-center gap-2 mb-1">
                      <i class="icon-base bx bx-award text-primary"></i>
                      <strong>{{ badge.name }}</strong>
                    </div>
                    <small class="text-muted">{{ badge.description ?? 'Débloqué grâce aux actions du foyer.' }}</small>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">Badges de la famille</h5>
              <small class="text-muted">Des réussites partagées par tout le foyer.</small>
            </div>
          </div>
          <div class="card-body">
            {% if metrics.familyBadges is empty %}
              <p class="text-muted mb-0">Lorsque le foyer avance ensemble, les badges apparaissent ici.</p>
            {% else %}
              <div class="d-flex flex-column gap-3">
                {% for badge in metrics.familyBadges %}
                  <div class="d-flex align-items-center justify-content-between border rounded px-3 py-2">
                    <div>
                      <div class="fw-semibold">{{ badge.name }}</div>
                      <small class="text-muted">{{ badge.description ?? 'Réussite collective du foyer.' }}</small>
                    </div>
                    {% if badge.awardedAt %}
                      <small class="text-muted">{{ badge.awardedAt|date('d M') }}</small>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="row g-4 mb-4">
    <div class="col-xl-6">
      <div
        class="card heatmap-card h-100"
        data-controller="notification-heatmap"
        data-notification-heatmap-matrix-value="{{ notificationMatrix|json_encode|e('html_attr') }}"
        data-notification-heatmap-endpoint-value="{{ path('portal_account_notifications_quick') }}"
        data-notification-heatmap-csrf-value="{{ csrf_token('notifications_quick') }}">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div>
              <h5 class="mb-0">Notifications du foyer</h5>
              <small class="text-muted">Les petits gestes comptent. Voici ce qui mérite votre attention.</small>
            </div>
            <a href="{{ path('portal_account_notifications') }}" class="btn btn-sm btn-outline-primary">Gérer les alertes</a>
          </div>
          <div class="card-body">
            <div class="heatmap-grid">
            <div class="heatmap-grid__corner">Canal</div>
            {% for channel, channelMeta in notificationChannels %}
              <div class="heatmap-grid__column">
                <i class="icon-base bx {{ channelMeta.icon }}"></i>
                <span>{{ channelMeta.label }}</span>
              </div>
            {% endfor %}

            {% for row in notificationRows %}
              <div class="heatmap-grid__row-label">
                <strong>{{ row.label }}</strong>
                <small>{{ row.key|replace({'_': ' '})|title }}</small>
              </div>
              {% for channel, channelMeta in notificationChannels %}
                {% set active = notificationMatrix[row.key][channel]|default(false) %}
                <button
                  class="heatmap-cell {{ active ? 'is-active' : '' }}"
                  type="button"
                  data-notification-heatmap-target="cell"
                  data-channel="{{ channel }}"
                  data-type="{{ row.key }}"
                  data-enabled="{{ active ? 'true' : 'false' }}">
                  <span>{{ active ? 'Activé' : 'Désactivé' }}</span>
                </button>
              {% endfor %}
            {% endfor %}
          </div>
          <div class="heatmap-legend mt-3">
            <span class="dot dot--on"></span>
            <small>Actif</small>
            <span class="dot dot--off ms-4"></span>
            <small>En pause</small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-6">
            <div class="card h-100">
        <div class="card-header d-flex justify-content-between align-items-center">
          <div>
            <h5 class="mb-0">Activite des modules</h5>
            <small class="text-muted">Chiffres reels collectes depuis les modules connectes.</small>
          </div>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-6">
              <div class="border rounded p-3 h-100">
                <small class="text-muted d-block mb-1">Taches actives</small>
                <h5 class="mb-0">{{ moduleStats.tasksActive }}</h5>
              </div>
            </div>
            <div class="col-6">
              <div class="border rounded p-3 h-100">
                <small class="text-muted d-block mb-1">Evenements a venir</small>
                <h5 class="mb-0">{{ moduleStats.upcomingEvents }}</h5>
              </div>
            </div>
            <div class="col-6">
              <div class="border rounded p-3 h-100">
                <small class="text-muted d-block mb-1">Achats en attente</small>
                <h5 class="mb-0">{{ moduleStats.pendingPurchases }}</h5>
              </div>
            </div>
            <div class="col-6">
              <div class="border rounded p-3 h-100">
                <small class="text-muted d-block mb-1">Documents stockes</small>
                <h5 class="mb-0">{{ moduleStats.documentsStored }}</h5>
              </div>
            </div>
            <div class="col-12">
              <div class="border rounded p-3">
                <small class="text-muted d-block mb-1">Rappels non lus</small>
                <h5 class="mb-0">{{ moduleStats.unreadReminders }}</h5>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card" data-controller="timeline-peek">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <h5 class="mb-0">Moments du foyer</h5>
        <small class="text-muted">Un fil doux pour suivre les contributions de chacun.</small>
      </div>
      <a href="{{ path('portal_account') }}" class="btn btn-sm btn-outline-secondary">Voir l’historique</a>
    </div>
    <div class="card-body">
      {% if recentActivity is empty %}
        <p class="text-muted mb-0">Aucune activité pour l’instant. Tout foyer organisé commence quelque part.</p>
      {% else %}
        <ul class="timeline timeline-center mt-3" data-timeline-peek-target="timeline">
          {% for event in recentActivity %}
            <li class="timeline-item ps-4">
              <span class="timeline-point-{{ event.type }}"></span>
              <div class="timeline-event">
                <div class="timeline-header">
                  <h6 class="mb-0">{{ event.title }}</h6>
                  <small class="text-muted">{{ event.occurredAt|date('d M, H:i') }}</small>
                </div>
                <p class="mb-0 text-muted">{{ event.description }}</p>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
{% endblock %}

