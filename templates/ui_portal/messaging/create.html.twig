{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}New Conversation · HomeBalance{% endblock %}

{% block content %}
<div class="container-xxl flex-grow-1 container-p-y">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Start a New Conversation</h5>
                    <a href="{{ path('portal_messaging_index') }}" class="btn btn-sm btn-outline-secondary">Cancel</a>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-3">
                            {{ form_label(form.conversationName) }}
                            {{ form_widget(form.conversationName) }}
                            {{ form_errors(form.conversationName) }}
                            <div class="form-text">Required only if you select more than one person.</div>
                        </div>
                        
                        <div class="mb-3">
                            {{ form_label(form.participants) }}
                            <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                {{ form_widget(form.participants) }}
                            </div>
                            {{ form_errors(form.participants) }}
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Create Conversation</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
