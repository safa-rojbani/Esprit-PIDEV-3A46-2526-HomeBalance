{# ── Sidebar Header ────────────────────────────────────────────── #}
<div class="sidebar-header">
    <h5>Messages</h5>
    <a href="{{ path('portal_messaging_create') }}"
       class="sidebar-new-btn"
       title="Nouvelle conversation"
       data-turbo="false">
        <i class="bx bx-plus"></i>
    </a>
</div>

{# ── Search ────────────────────────────────────────────────────── #}
<div class="sidebar-search-wrap">
    <div class="sidebar-search">
        <i class="bx bx-search"></i>
        <input type="text" placeholder="Rechercher une conversation…" id="chat-search">
    </div>
</div>

{# ── Filter Tabs ────────────────────────────────────────────────── #}
<div class="sidebar-filter-tabs">
    <button class="sidebar-filter-tab active" data-filter="all">Tous</button>
    <button class="sidebar-filter-tab" data-filter="unread">Non lus</button>
    <button class="sidebar-filter-tab" data-filter="group">Groupes</button>
</div>

{# ── Section label ─────────────────────────────────────────────── #}
<div class="sidebar-section-label">Conversations</div>

{# ── Conversation List ─────────────────────────────────────────── #}
<div class="messaging-list" id="messaging-list">
    {% if conversations is empty %}
        <div class="sidebar-empty-placeholder">
            <i class="bx bx-message-square-detail"></i>
            <p>Aucune conversation pour le moment.<br>Créez-en une nouvelle !</p>
        </div>
    {% else %}
        {# Avatar color palette — cycles through variants #}
        {% set avatarColors = ['blue', 'purple', 'teal', 'rose', 'amber'] %}
        {% for conversation in conversations %}
            {% set isActive = current_conversation and current_conversation.id == conversation.id %}
            {% set otherParticipants = conversation.conversationParticipants|filter(p => p.user != app.user) %}
            {% set conversationName = conversation.conversationName %}
            {% set unreadCount = unread_counts[conversation.id]|default(0) %}
            {% set partner = null %}
            {% set colorKey = avatarColors[loop.index0 % 5] %}

            {% if conversation.type.value == 'private' %}
                {% set partner = otherParticipants|first.user|default(null) %}
                {% if partner %}
                    {% set conversationName = partner.firstName ~ ' ' ~ partner.lastName %}
                {% else %}
                    {% set conversationName = 'Unknown User' %}
                {% endif %}
            {% endif %}

            <a href="{{ path('portal_messaging_show', {id: conversation.id}) }}"
               class="conversation-item {% if isActive %}active{% endif %}"
               data-conversation-name="{{ conversationName|lower }}"
               data-conversation-type="{{ conversation.type.value }}"
               data-unread="{{ unreadCount }}"
               data-turbo-frame="chat_view">

                <div class="d-flex align-items-center">
                    {# Rounded-square avatar #}
                    <div class="conv-avatar conv-avatar--{{ colorKey }}">
                        {% if conversation.type.value == 'private' and partner and partner.avatarPath %}
                            <img src="{{ asset(partner.avatarPath) }}" alt="">
                        {% elseif conversation.type.value == 'group' %}
                            <i class="bx bx-group" style="font-size:1.1rem;"></i>
                        {% else %}
                            {{ conversationName|slice(0,2)|upper }}
                        {% endif %}
                        <span class="conv-online-dot"></span>
                    </div>

                    <div class="conv-info">
                        <div class="conv-row1">
                            <span class="conv-name">{{ conversationName }}</span>
                            <span class="conv-time">
                                {% if conversation.messages is not empty %}
                                    {{ conversation.messages|last.sentAt|date('H:i') }}
                                {% endif %}
                            </span>
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="conv-preview">
                                {% if conversation.messages is not empty %}
                                    {% set lastMsg = conversation.messages|last %}
                                    {% if lastMsg.sender == app.user %}<span style="color:rgba(255,255,255,0.3);font-size:.7rem;">Vous ·</span> {% endif %}{{ lastMsg.content|slice(0,40) }}
                                {% else %}
                                    <em style="opacity:.45;">Démarrez la conversation</em>
                                {% endif %}
                            </span>
                            {% if unreadCount > 0 %}
                                <span class="conv-unread-badge">{{ unreadCount }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </a>
        {% endfor %}
    {% endif %}
</div>

{# ── Sidebar Footer (current user) ─────────────────────────────── #}
<div class="sidebar-footer">
    <div class="sidebar-me-avatar">
        {% if app.user and app.user.avatarPath %}
            <img src="{{ asset(app.user.avatarPath) }}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:11px;">
        {% else %}
            {{ app.user ? (app.user.firstName|slice(0,1)|upper ~ app.user.lastName|slice(0,1)|upper) : '?' }}
        {% endif %}
    </div>
    <span class="sidebar-me-name">
        {{ app.user ? (app.user.firstName ~ ' ' ~ app.user.lastName) : 'Moi' }}
    </span>
    <div class="sidebar-me-status">
        <span class="sidebar-status-dot"></span>
        <span class="sidebar-status-label">En ligne</span>
    </div>
</div>

<script>
(function() {
    /* ── Search ── */
    const searchInput = document.getElementById('chat-search');
    searchInput?.addEventListener('input', function(e) {
        const q = e.target.value.toLowerCase();
        document.querySelectorAll('.conversation-item').forEach(item => {
            const nameMatch = (item.dataset.conversationName || '').includes(q);
            item.style.display = nameMatch ? '' : 'none';
        });
    });

    /* ── Filter tabs ── */
    document.querySelectorAll('.sidebar-filter-tab').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.sidebar-filter-tab').forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            const filter = this.dataset.filter;
            document.querySelectorAll('.conversation-item').forEach(item => {
                let show = true;
                if (filter === 'unread')  show = parseInt(item.dataset.unread || '0') > 0;
                if (filter === 'group')   show = item.dataset.conversationType === 'group';
                item.style.display = show ? '' : 'none';
            });
        });
    });
})();
</script>
