{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Parametres du compte · Preferences de signal{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'preferences' } %}

  {% set pref = preferences.data %}
  {% set lastTuned = pref.updatedAt is defined and pref.updatedAt ? pref.updatedAt|date('d M, H:i') : 'pas encore defini' %}

  <div class="row g-6 align-items-start">
    <div class="col-lg-7">
      <form class="card" method="post" action="{{ path('portal_account_preferences') }}" novalidate>
        <input type="hidden" name="_token" value="{{ csrf_token('account_preferences') }}" />
        <input type="hidden" name="section" value="preferences" />

        <div class="card-body">
          <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
              <h5 class="mb-1">Preferences de signal</h5>
              <p class="mb-0 text-muted">Ajustez les modules visibles et vos plages de tranquillite.</p>
            </div>
            <div class="text-lg-end">
              <small class="text-muted d-block">Dernier reglage · {{ lastTuned }}</small>
            </div>
          </div>

          {% if preferences.errors %}
            <div class="alert alert-danger mt-4" role="alert">
              <ul class="mb-0 ps-3">
                {% for error in preferences.errors %}
                  <li>{{ error }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        </div>

        <div class="card-body border-top">
          <h6 class="mb-2">Modules affiches dans la barre laterale</h6>
          <p class="text-muted">Decochez les modules que vous ne souhaitez pas voir.</p>
          <div class="row g-4">
            {% for key, module in preferences.modules %}
              {% set inputId = 'module-' ~ key %}
              <div class="col-sm-6">
                <div class="border rounded p-4 h-100">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                      <div class="fw-semibold">{{ module.label }}</div>
                      <small class="text-muted">{{ module.description }}</small>
                    </div>
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input" type="checkbox" role="switch" id="{{ inputId }}" name="preferences[modules][]" value="{{ key }}" {{ key in pref.modules ? 'checked' }} />
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="card-body border-top">
          <h6 class="mb-2">Heures calmes et synthese</h6>
          <p class="text-muted">Protegez votre attention puis recevez un recapitulatif hebdomadaire.</p>
          <div class="row g-4">
            <div class="col-sm-6">
              <label for="quietStart" class="form-label">Debut des heures calmes</label>
              <input type="time" class="form-control" id="quietStart" name="preferences[quietStart]" value="{{ pref.quietStart ?? '' }}" />
            </div>
            <div class="col-sm-6">
              <label for="quietEnd" class="form-label">Fin des heures calmes</label>
              <input type="time" class="form-control" id="quietEnd" name="preferences[quietEnd]" value="{{ pref.quietEnd ?? '' }}" />
            </div>
            <div class="col-12">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="weeklySummary" name="preferences[weeklySummary]" value="1" {{ pref.weeklySummary ? 'checked' }} />
                <label class="form-check-label" for="weeklySummary">Recevoir une synthese hebdomadaire (budget, taches, climat familial).</label>
              </div>
            </div>
          </div>
        </div>

        <div class="card-body border-top d-flex flex-column flex-md-row align-items-md-center gap-3">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <button type="reset" class="btn btn-outline-secondary">Reinitialiser</button>
          <small class="text-muted">Ces reglages s'appliquent sur le web et le mobile.</small>
        </div>
      </form>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 shadow-sm bg-body-tertiary h-100">
        <div class="card-body">
          <h6 class="text-uppercase text-muted fw-semibold mb-3">Comment HomeBalance s'en sert</h6>
          <ul class="list-unstyled mb-4">
            <li class="d-flex mb-3">
              <i class="icon-base bx bx-hide text-primary me-3"></i>
              <div>
                <div class="fw-semibold">Sidebar personnalisee</div>
                <small class="text-muted">Les modules decoches disparaissent du menu lateral.</small>
              </div>
            </li>
            <li class="d-flex mb-3">
              <i class="icon-base bx bx-moon text-primary me-3"></i>
              <div>
                <div class="fw-semibold">Heures calmes</div>
                <small class="text-muted">Reduit les interruptions pendant vos plages de concentration.</small>
              </div>
            </li>
            <li class="d-flex">
              <i class="icon-base bx bx-line-chart text-primary me-3"></i>
              <div>
                <div class="fw-semibold">Synthese hebdomadaire</div>
                <small class="text-muted">Un recap de votre foyer pour suivre le rythme global.</small>
              </div>
            </li>
          </ul>
          <div class="bg-label-primary rounded p-4">
            <p class="mb-2 fw-semibold">Astuce</p>
            <p class="mb-0 text-muted">Gardez au moins un module visible pour naviguer facilement.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
