{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Tasks · HomeBalance{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Household Tasks</h4>
        <p class="text-muted mb-0">Manage and coordinate what needs to be done.</p>
    </div>
    <a href="{{ path('portal_tasks_new') }}" class="btn btn-primary">
        <i class="bx bx-plus me-1"></i> Add New Task
    </a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header border-bottom">
                <h5 class="mb-0">Active Tasks</h5>
            </div>
            <div class="card-body p-0">
                {% if tasks is empty %}
                    <div class="text-center py-5">
                        <i class="bx bx-task bx-lg text-muted mb-3"></i>
                        <h5>No tasks yet!</h5>
                        <p class="text-muted">Create your first family task to get started.</p>
                    </div>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for task in tasks %}
                            <div class="list-group-item p-4">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex gap-3">
                                        <div class="avatar flex-shrink-0">
                                            <span class="avatar-initial rounded bg-label-{{ task.difficulty.value == 'hard' ? 'danger' : (task.difficulty.value == 'medium' ? 'warning' : 'success') }}">
                                                <i class="bx bx-check-shield"></i>
                                            </span>
                                        </div>
                                        <div>
                                            <h6 class="mb-1">{{ task.title }}</h6>
                                            <p class="mb-2 text-muted small">{{ task.description }}</p>
                                            <div class="d-flex gap-2 flex-wrap">
                                                <span class="badge bg-label-{{ task.difficulty.value == 'hard' ? 'danger' : (task.difficulty.value == 'medium' ? 'warning' : 'success') }} text-capitalize">
                                                    {{ task.difficulty.value }}
                                                </span>
                                                <span class="badge bg-label-secondary text-capitalize">
                                                    <i class="bx bx-refresh ms-1"></i> {{ task.recurrence.value }}
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-column align-items-end">
                                        <form action="{{ path('portal_tasks_complete', {id: task.id}) }}" method="POST">
                                            <input type="hidden" name="_token" value="{{ csrf_token('complete' ~ task.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-pill">
                                                Mark Complete
                                            </button>
                                        </form>
                                        <small class="text-muted mt-2">Added {{ task.createdAt|date('M d') }}</small>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header border-bottom">
                <h5 class="mb-0">Assignments</h5>
            </div>
            <div class="card-body">
                {% if assignments is empty %}
                    <p class="text-muted text-center py-4">No active assignments.</p>
                {% else %}
                    <ul class="list-unstyled mb-0">
                        {% for assignment in assignments %}
                            <li class="d-flex align-items-center mb-3">
                                <div class="avatar avatar-sm me-3">
                                    {% if assignment.user.avatarPath %}
                                        <img src="{{ asset(assignment.user.avatarPath) }}" class="rounded-circle">
                                    {% else %}
                                        <span class="avatar-initial rounded-circle bg-label-primary">{{ assignment.user.firstName|slice(0, 1) }}</span>
                                    {% endif %}
                                </div>
                                <div>
                                    <div class="fw-semibold">{{ assignment.user.firstName }}</div>
                                    <small class="text-muted">{{ assignment.task.title }}</small>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
