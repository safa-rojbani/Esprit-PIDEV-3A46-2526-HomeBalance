{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Tasks · HomeBalance{% endblock %}

{% block content %}
<div class="card p-5 text-center shadow-sm">
    <div class="mb-4 text-primary">
        <i class="bx bx-group bx-lg" style="font-size: 5rem;"></i>
    </div>
    <h3 class="fw-bold">No Household Connected</h3>
    <p class="text-muted mx-auto" style="max-width: 500px;">
        Tasks are built for coordination. To start tracking what needs to be done, you first need to create or join a household.
    </p>
    <div class="mt-4 gap-3 d-flex justify-content-center">
        <a href="{{ path('portal_family_settings') }}" class="btn btn-primary btn-lg">
            <i class="bx bx-plus-circle me-1"></i> Setup My Family
        </a>
        <a href="{{ path('portal_dashboard') }}" class="btn btn-outline-secondary btn-lg">
            Later
        </a>
    </div>
</div>
{% endblock %}
