{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Account Settings · Family{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'family' } %}

  {% if family %}
    <div class="row g-4 mb-4">
      <div class="col-xl-7">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">{{ family.name }}</h5>
              <small class="text-muted">Household code keeps shared spaces organized.</small>
            </div>
            {% if can_manage %}
              <form method="post" action="{{ path('portal_family_refresh_code') }}" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('family_code') }}" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Refresh code</button>
              </form>
            {% endif %}
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-4 align-items-center">
              <div>
                <small class="text-muted text-uppercase">Active join code</small>
                <div class="display-6 fw-bold">{{ family.joinCode ?? 'Not generated' }}</div>
                {% if family.codeExpiresAt %}
                  <small class="text-muted">Expires {{ family.codeExpiresAt|date('M d, H:i') }}</small>
                {% endif %}
              </div>
              <div>
                <small class="text-muted text-uppercase">Members</small>
                <div class="display-6 fw-bold">{{ members|length }}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Family badges</h5>
            <small class="text-muted">Unlocked by every member.</small>
          </div>
          <div class="card-body">
            {% if metrics.familyBadges is empty %}
              <p class="text-muted mb-0">Invite someone and start collaborating to earn shared badges.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for badge in metrics.familyBadges %}
                  <li class="mb-3">
                    <div class="fw-semibold">{{ badge.name }}</div>
                    <small class="text-muted">
                      {{ badge.description ?? 'Shared milestone' }}
                      {% if badge.awardedAt %}· {{ badge.awardedAt|date('M d') }}{% endif %}
                    </small>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-xl-7">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Household roster</h5>
            <small class="text-muted">Live members inside this family.</small>
          </div>
          <div class="card-body">
            {% if members is empty %}
              <p class="text-muted mb-0">No members yet.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for membership in members %}
                  <li class="d-flex justify-content-between align-items-center py-3 border-bottom">
                    <div>
                      <div class="fw-semibold">{{ membership.getUser().getFirstName() }} {{ membership.getUser().getLastName() }}</div>
                      <small class="text-muted">{{ membership.getUser().getEmail() }}</small>
                    </div>
                    <div class="text-end">
                      <span class="badge bg-label-{{ membership.getRole().value == 'PARENT' ? 'primary' : 'info' }}">{{ membership.getRole().name|title }}</span>
                      <div><small class="text-muted">Joined {{ membership.getJoinedAt()|date('M d') }}</small></div>
                    </div>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="mb-0">Share an invite</h5>
            <small class="text-muted">Send a one-time code to a helper.</small>
          </div>
          <div class="card-body">
            {% if can_manage %}
              <form method="post" action="{{ path('portal_family_invite') }}" class="row g-3" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('family_invite') }}" />
                <div class="col-12">
                  <label class="form-label" for="inviteEmail">Email</label>
                  <input type="text" class="form-control" id="inviteEmail" name="inviteEmail" placeholder="helper@example.com" />
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary w-100">Send invite</button>
                </div>
              </form>
            {% else %}
              <p class="text-muted mb-0">Only household admins can send invitations.</p>
            {% endif %}
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <h6 class="mb-0">Recent invitations</h6>
          </div>
          <div class="card-body">
            {% if invitations is empty %}
              <p class="text-muted mb-0">No invitations yet.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for invitation in invitations %}
                  <li class="mb-3">
                    <div class="fw-semibold">{{ invitation.invitedEmail ?? 'Shared link' }}</div>
                    {% set statusLabel = invitation.status ? invitation.status.value|replace({'_': ' '})|title : 'Pending' %}
                    <small class="text-muted">Code {{ invitation.joinCode }} · {{ statusLabel }}</small>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Start a family</h5>
            <small class="text-muted">Create a home workspace and invite others.</small>
          </div>
          <div class="card-body">
            <form method="post" action="{{ path('portal_family_create') }}" class="row g-3" novalidate>
              <input type="hidden" name="_token" value="{{ csrf_token('family_create') }}" />
              <div class="col-12">
                <label class="form-label" for="familyName">Family name</label>
                <input type="text" class="form-control" id="familyName" name="familyName" placeholder="The Martinez Crew" />
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary w-100">Create family</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Join with a code</h5>
            <small class="text-muted">Use a code shared by someone already inside.</small>
          </div>
          <div class="card-body">
            <form method="post" action="{{ path('portal_family_join') }}" class="row g-3" novalidate>
              <input type="hidden" name="_token" value="{{ csrf_token('family_join') }}" />
              <div class="col-12">
                <label class="form-label" for="joinCode">Join code</label>
                <input type="text" class="form-control" id="joinCode" name="joinCode" placeholder="ABC123" />
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-outline-primary w-100">Join family</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}
