{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Paramètres du compte · Famille{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'family' } %}

  {% if family %}
    <div class="row g-4 mb-4">
      <div class="col-xl-7">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0">{{ family.name }}</h5>
              <small class="text-muted">Le code foyer garde l’espace partagé bien organisé.</small>
            </div>
            {% if can_manage %}
              <form method="post" action="{{ path('portal_family_refresh_code') }}" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('family_code') }}" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Rafraîchir le code</button>
              </form>
            {% endif %}
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-4 align-items-center">
              <div>
                <small class="text-muted text-uppercase">Code d’accès actif</small>
                <div class="display-6 fw-bold">{{ family.joinCode ?? 'Non généré' }}</div>
                {% if family.codeExpiresAt %}
                  <small class="text-muted">Expire le {{ family.codeExpiresAt|date('d M, H:i') }}</small>
                {% endif %}
              </div>
              <div>
                <small class="text-muted text-uppercase">Membres</small>
                <div class="display-6 fw-bold">{{ members|length }}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Badges de la famille</h5>
            <small class="text-muted">Débloqués par toute l’équipe.</small>
          </div>
          <div class="card-body">
            {% if metrics.familyBadges is empty %}
              <p class="text-muted mb-0">Invitez un proche et commencez à collaborer pour gagner des badges partagés.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for badge in metrics.familyBadges %}
                  <li class="mb-3">
                    <div class="fw-semibold">{{ badge.name }}</div>
                    <small class="text-muted">
                      {{ badge.description ?? 'Étape partagée' }}
                      {% if badge.awardedAt %}· {{ badge.awardedAt|date('d M') }}{% endif %}
                    </small>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-xl-7">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Membres du foyer</h5>
            <small class="text-muted">Personnes actives dans cette famille.</small>
          </div>
          <div class="card-body">
            {% if members is empty %}
              <p class="text-muted mb-0">Aucun membre pour l’instant.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for membership in members %}
                  <li class="d-flex justify-content-between align-items-center py-3 border-bottom">
                    <div>
                      <div class="fw-semibold">{{ membership.getUser().getFirstName() }} {{ membership.getUser().getLastName() }}</div>
                      <small class="text-muted">{{ membership.getUser().getEmail() }}</small>
                    </div>
                    <div class="text-end">
                      <span class="badge bg-label-{{ membership.getRole().value == 'PARENT' ? 'primary' : 'info' }}">{{ membership.getRole().name|title }}</span>
                      <div><small class="text-muted">Rejoint le {{ membership.getJoinedAt()|date('d M') }}</small></div>
                    </div>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="mb-0">Partager une invitation</h5>
            <small class="text-muted">Envoyez un code unique à un proche.</small>
          </div>
          <div class="card-body">
            {% if can_manage %}
              <form method="post" action="{{ path('portal_family_invite') }}" class="row g-3" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('family_invite') }}" />
                <div class="col-12">
                  <label class="form-label" for="inviteEmail">E-mail</label>
                  <input type="text" class="form-control" id="inviteEmail" name="inviteEmail" placeholder="proche@exemple.com" />
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary w-100">Envoyer l’invitation</button>
                </div>
              </form>
            {% else %}
              <p class="text-muted mb-0">Seuls les administrateurs du foyer peuvent inviter.</p>
            {% endif %}
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <h6 class="mb-0">Invitations récentes</h6>
          </div>
          <div class="card-body">
            {% if invitations is empty %}
              <p class="text-muted mb-0">Aucune invitation pour l’instant.</p>
            {% else %}
              <ul class="list-unstyled mb-0">
                {% for invitation in invitations %}
                  <li class="mb-3">
                    <div class="fw-semibold">{{ invitation.invitedEmail ?? 'Lien partagé' }}</div>
                    {% set statusLabel = invitation.status ? invitation.status.value|replace({'_': ' '})|title : 'En attente' %}
                    <small class="text-muted">Code {{ invitation.joinCode }} · {{ statusLabel }}</small>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Créer une famille</h5>
            <small class="text-muted">Créez votre espace et invitez vos proches.</small>
          </div>
          <div class="card-body">
            <form method="post" action="{{ path('portal_family_create') }}" class="row g-3" novalidate>
              <input type="hidden" name="_token" value="{{ csrf_token('family_create') }}" />
              <div class="col-12">
                <label class="form-label" for="familyName">Nom de la famille</label>
                <input type="text" class="form-control" id="familyName" name="familyName" placeholder="La famille Martin" />
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary w-100">Créer la famille</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0">Rejoindre avec un code</h5>
            <small class="text-muted">Utilisez un code partagé par un membre du foyer.</small>
          </div>
          <div class="card-body">
            <form method="post" action="{{ path('portal_family_join') }}" class="row g-3" novalidate>
              <input type="hidden" name="_token" value="{{ csrf_token('family_join') }}" />
              <div class="col-12">
                <label class="form-label" for="joinCode">Code d’accès</label>
                <input type="text" class="form-control" id="joinCode" name="joinCode" placeholder="ABC123" />
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-outline-primary w-100">Rejoindre la famille</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}
