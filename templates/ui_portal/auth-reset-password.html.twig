{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Set New Password · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Reset in a single step</p>
  <h1>Choose a new password for your household hub.</h1>
  <p class="lead">Passwords power every action. Pick something unique so chores, finances, and documents stay safe.</p>
  <div class="hero-metrics">
    <div>
      <span class="metric">1 hour</span>
      <small>Reset links expire fast for your safety.</small>
    </div>
    <div>
      <span class="metric">8+ chars</span>
      <small>Make it strong so your family stays protected.</small>
    </div>
  </div>
{% endblock %}

{% block panel_subtitle %}Create a fresh password{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Reset access</h2>
    <p class="text-muted">Paste the token from your email and set a new password below.</p>
  </div>

  <form method="post" action="{{ path('portal_auth_reset_password') }}" class="stack-lg" data-turbo="false" novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="token"
        name="token"
        placeholder="Reset token"
        value="{{ state.token }}"
        autocomplete="off" />
      <span>Reset token</span>
    </label>

    <div class="form-password-toggle" data-controller="password-visibility">
      <label class="form-floating">
        <input
          type="password"
          class="form-control"
          id="password"
          name="password"
          placeholder="New password"
          autocomplete="new-password"
          data-password-visibility-target="input" />
        <span>New password</span>
        <button
          class="password-toggle"
          type="button"
          aria-label="Toggle password visibility"
          data-action="password-visibility#toggle"
          data-password-visibility-target="toggle">
          <i class="icon-base bx bx-hide"></i>
        </button>
      </label>
    </div>

    <label class="form-floating">
      <input
        type="password"
        class="form-control"
        id="password_confirm"
        name="password_confirm"
        placeholder="Confirm password"
        autocomplete="new-password" />
      <span>Confirm password</span>
    </label>

    <button class="btn btn-primary w-100">Update password</button>
  </form>

  <p class="text-center mb-0 mt-4">
    <a href="{{ path('portal_auth_login') }}" class="link-underline">Return to sign in</a>
  </p>
{% endblock %}
