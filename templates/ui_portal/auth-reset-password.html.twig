{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Nouveau mot de passe · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Réinitialisation en une étape</p>
  <h1>Choisissez un nouveau mot de passe pour votre foyer.</h1>
  <p class="lead">Le mot de passe protège tout. Choisissez-en un unique pour sécuriser tâches, budget et documents.</p>
  <div class="hero-metrics">
    <div>
      <span class="metric">1 heure</span>
      <small>Les liens expirent vite pour votre sécurité.</small>
    </div>
    <div>
      <span class="metric">8+ caractères</span>
      <small>Choisissez un mot de passe robuste.</small>
    </div>
  </div>
{% endblock %}

{% block panel_subtitle %}Créer un nouveau mot de passe{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Réinitialiser l’accès</h2>
    <p class="text-muted">Collez le jeton reçu par e-mail puis choisissez un nouveau mot de passe.</p>
  </div>

  <form method="post" action="{{ path('portal_auth_reset_password') }}" class="stack-lg" data-turbo="false" novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="token"
        name="token"
        placeholder="Jeton de réinitialisation"
        value="{{ state.token }}"
        autocomplete="off" />
      <span>Jeton de réinitialisation</span>
    </label>

    <div class="form-password-toggle" data-controller="password-visibility">
      <label class="form-floating">
        <input
          type="password"
          class="form-control"
          id="password"
          name="password"
          placeholder="Nouveau mot de passe"
          autocomplete="new-password"
          data-password-visibility-target="input" />
        <span>Nouveau mot de passe</span>
        <button
          class="password-toggle"
          type="button"
          aria-label="Afficher ou masquer le mot de passe"
          data-action="password-visibility#toggle"
          data-password-visibility-target="toggle">
          <i class="icon-base bx bx-hide"></i>
        </button>
      </label>
    </div>

    <label class="form-floating">
      <input
        type="password"
        class="form-control"
        id="password_confirm"
        name="password_confirm"
        placeholder="Confirmer le mot de passe"
        autocomplete="new-password" />
      <span>Confirmer le mot de passe</span>
    </label>

    <button class="btn btn-primary w-100">Mettre à jour</button>
  </form>

  <p class="text-center mb-0 mt-4">
    <a href="{{ path('portal_auth_login') }}" class="link-underline">Retour à la connexion</a>
  </p>
{% endblock %}
