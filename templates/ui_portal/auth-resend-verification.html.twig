{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Renvoyer la vérification · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Accès sécurisé au foyer</p>
  <h1>Vérifiez votre e-mail pour accéder à HomeBalance.</h1>
  <p class="lead">
    Nous voulons que les invitations et notifications arrivent au bon endroit. Indiquez l’e-mail à vérifier
    et nous renverrons le lien immédiatement.
  </p>
  <ul class="hero-points">
    <li>Protège les données du foyer</li>
    <li>Garantit que les invitations arrivent aux bonnes personnes</li>
    <li>Nécessaire avant de rejoindre ou créer une famille</li>
  </ul>
{% endblock %}

{% block panel_subtitle %}Demander un nouveau lien{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Renvoyer l’e-mail de vérification</h2>
    <p class="text-muted">
      Saisissez l’e-mail ou l’identifiant du compte. Nous n’enverrons le lien que si la vérification est encore nécessaire.
    </p>
  </div>

  <form method="post" action="{{ path('portal_auth_resend_verification') }}" class="stack-lg" data-turbo="false" novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="identifier"
        name="identifier"
        placeholder="E-mail ou identifiant"
        value="{{ state.identifier }}"
        autocomplete="username" />
      <span>E-mail ou identifiant</span>
    </label>
    <small class="text-muted">Si le compte est déjà vérifié, nous resterons discrets pour votre sécurité.</small>

    <button class="btn btn-primary w-100">Envoyer le lien</button>
  </form>

  <p class="text-center mb-0 mt-4">
    <a href="{{ path('portal_auth_login') }}" class="link-underline">Retour à la connexion</a>
  </p>
{% endblock %}
