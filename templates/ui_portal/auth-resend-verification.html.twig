{% extends 'ui_portal/layouts/auth.html.twig' %}

{% block title %}Resend Verification · HomeBalance{% endblock %}

{% block hero %}
  <p class="eyebrow">Secure household access</p>
  <h1>Verify your email to unlock HomeBalance.</h1>
  <p class="lead">
    We need to make sure invitations and notifications land in the right inbox. Tell us where to send the
    verification link and we will refresh it immediately.
  </p>
  <ul class="hero-points">
    <li>Protects your household data</li>
    <li>Ensures invites reach the right people</li>
    <li>Required before joining or creating a family</li>
  </ul>
{% endblock %}

{% block panel_subtitle %}Request a fresh verification link{% endblock %}

{% block panel %}
  <div class="panel-head">
    <h2>Send the verification email again</h2>
    <p class="text-muted">
      Enter the email or username on the account. We will only send the link if the account still needs verification.
    </p>
  </div>

  <form method="post" action="{{ path('portal_auth_resend_verification') }}" class="stack-lg" data-turbo="false" novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}" />

    <label class="form-floating">
      <input
        type="text"
        class="form-control"
        id="identifier"
        name="identifier"
        placeholder="Email or username"
        value="{{ state.identifier }}"
        autocomplete="username" />
      <span>Email or username</span>
    </label>
    <small class="text-muted">If the account is already verified, we will keep it quiet for security.</small>

    <button class="btn btn-primary w-100">Send verification link</button>
  </form>

  <p class="text-center mb-0 mt-4">
    <a href="{{ path('portal_auth_login') }}" class="link-underline">Back to sign in</a>
  </p>
{% endblock %}
