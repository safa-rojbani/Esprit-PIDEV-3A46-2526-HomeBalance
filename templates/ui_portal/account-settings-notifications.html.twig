{% extends 'ui_portal/layouts/base.html.twig' %}

{% block title %}Paramètres du compte · Notifications{% endblock %}

{% block content %}
  {% include 'ui_portal/partials/account-settings-nav.html.twig' with { active_tab: 'notifications' } %}

  <form class="card" method="post" action="{{ path('portal_account_notifications') }}" novalidate>
    <input type="hidden" name="_token" value="{{ csrf_token('notifications_update') }}" />
    <div class="card-body">
      <h5 class="mb-1">Notifications du foyer</h5>
      <span class="card-subtitle">
        Choisissez comment chaque mise à jour vous parvient. L’équilibre, c’est savoir ce qui mérite attention.
      </span>
      <div class="error"></div>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th class="text-nowrap">Type</th>
            <th class="text-nowrap text-center">E-mail</th>
            <th class="text-nowrap text-center">Navigateur</th>
            <th class="text-nowrap text-center">Application</th>
          </tr>
        </thead>
        <tbody>
          {% for row in notificationRows %}
            {% set matrix = notificationMatrix[row.key]|default({}) %}
            <tr>
              <td class="text-nowrap text-heading">{{ row.label }}</td>
              {% for channel in ['email', 'browser', 'app'] %}
                <td>
                  <div class="form-check mb-0 d-flex justify-content-center align-items-center">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="{{ row.key }}-{{ channel }}"
                      name="notifications[{{ row.key }}][{{ channel }}]"
                      value="1"
                      {{ matrix[channel]|default(false) ? 'checked' }} />
                  </div>
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card-body">
      <h6 class="text-body mb-6">Quand souhaitez-vous être notifié ?</h6>
      <div class="row">
        <div class="col-sm-6">
          <select id="sendNotification" class="form-select" name="sendNotification">
            <option value="online" {{ notificationDelivery == 'online' ? 'selected' }}>Seulement lorsque je suis en ligne</option>
            <option value="anytime" {{ notificationDelivery == 'anytime' ? 'selected' }}>À tout moment</option>
          </select>
          <small class="text-muted d-block mt-2">Modifiez ce réglage quand le rythme du foyer change.</small>
        </div>
        <div class="mt-6">
          <button type="submit" class="btn btn-primary me-3">Enregistrer</button>
          <button type="reset" class="btn btn-outline-secondary">Réinitialiser</button>
        </div>
      </div>
    </div>
  </form>

  <div class="card mt-4">
    <div class="card-body pb-2">
      <h5 class="mb-1">Notifications in-app</h5>
      <span class="card-subtitle">Historique recent visible directement dans l'interface.</span>
    </div>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Type</th>
            <th>Detail</th>
            <th class="text-end">Date</th>
          </tr>
        </thead>
        <tbody>
          {% if recentInAppNotifications is empty %}
            <tr>
              <td colspan="3" class="text-center text-muted py-4">Aucune notification in-app pour le moment.</td>
            </tr>
          {% else %}
            {% for n in recentInAppNotifications %}
              {% set payload = n.payload ?? {} %}
              <tr>
                <td class="text-nowrap">
                  {% if n.key == 'task_penalty_applied' %}
                    <span class="badge bg-label-danger">Penalite membre</span>
                  {% elseif n.key == 'task_penalty_parent_alert' %}
                    <span class="badge bg-label-warning">Alerte parent</span>
                  {% else %}
                    <span class="badge bg-label-secondary">{{ n.key|replace({'_': ' '})|title }}</span>
                  {% endif %}
                </td>
                <td>
                  {% if payload.taskTitle is defined %}
                    <div class="fw-semibold">{{ payload.taskTitle }}</div>
                  {% endif %}
                  <div class="small text-muted">
                    {% if payload.reasonLabel is defined %}{{ payload.reasonLabel }}{% endif %}
                    {% if payload.points is defined %} · {{ payload.points > 0 ? '+' : '' }}{{ payload.points }} pts{% endif %}
                    {% if payload.memberName is defined and n.key == 'task_penalty_parent_alert' %} · {{ payload.memberName }}{% endif %}
                    {% if payload.dueDate is defined and payload.dueDate %} · Deadline: {{ payload.dueDate }}{% endif %}
                  </div>
                </td>
                <td class="text-end text-nowrap text-muted">
                  {{ n.createdAt ? n.createdAt|date('d/m/Y H:i') : '-' }}
                </td>
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
