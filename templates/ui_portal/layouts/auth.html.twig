<!doctype html>
<html
  lang="fr"
  class="auth-html"
  data-assets-path="{{ asset('') }}"
  data-template="vertical-menu-template-free">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />

    <title>{% block title %}Connexion · HomeBalance{% endblock %}</title>

    <meta name="description" content="Accès sécurisé au portail familial HomeBalance" />
    <meta name="robots" content="index, follow" />
    {% if app.request is defined and app.request is not null %}
      <link rel="canonical" href="{{ app.request.uri }}" />
    {% endif %}

    <link rel="icon" type="image/svg+xml" href="{{ asset('img/favicon/favicon.svg') }}" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet" />

    <link rel="stylesheet" href="{{ asset('vendor/fonts/iconify-icons.css') }}" />
    <link
      rel="preload"
      href="{{ asset('vendor/css/core.css') }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="{{ asset('vendor/css/core.css') }}" /></noscript>
    <link rel="stylesheet" href="{{ asset('css/demo.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/hb-theme.css') }}" />

    {% block extra_stylesheets %}{% endblock %}

    {{ importmap('app') }}
  </head>

  <body class="auth-body">
    <div
      class="auth-shell"
      data-controller="auth-shell"
      data-auth-shell-theme-value="{{ auth_theme|default('dawn') }}">
      <div class="auth-shell__gradient"></div>
      <div class="auth-shell__orbs">
        <div class="orb orb--one"></div>
        <div class="orb orb--two"></div>
        <div class="orb orb--three"></div>
      </div>
      <div class="auth-shell__noise"></div>

      <div class="container-xxl auth-grid">
        <section class="auth-hero">
          {% block hero %}
            <p class="eyebrow">Portail HomeBalance</p>
            <h1>Ramenez de la sérénité dans l’organisation familiale.</h1>
            <p class="lead">
              Suivez les tâches, partagez les documents et restez tous alignés depuis un même espace sécurisé.
            </p>
            <ul class="hero-points">
              <li>Des repères personnalisés mis à jour chaque jour</li>
              <li>Des notifications intelligentes et fiables</li>
              <li>Un suivi clair de chaque action importante</li>
            </ul>
          {% endblock %}
        </section>

        <section class="auth-panel card shadow-lg">
          <div class="brand-mark">
            <a href="{{ path('portal_dashboard') }}" class="app-brand-link gap-2">
              <span class="app-brand-logo demo">
                <span class="text-primary">
                  {% include 'ui_portal/partials/logo.svg.twig' %}
                </span>
              </span>
              <span class="app-brand-text demo text-heading fw-bold">HomeBalance</span>
            </a>
            <p class="brand-mark__subtitle">{% block panel_subtitle %}Accès sécurisé au portail{% endblock %}</p>
          </div>

          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : label) }}" role="alert">
                {{ message }}
              </div>
            {% endfor %}
          {% endfor %}

          {% block panel %}{% endblock %}
        </section>
      </div>
    </div>

    <script src="{{ asset('js/main.js') }}" defer></script>

    {% block extra_javascripts %}{% endblock %}
  </body>
</html>
