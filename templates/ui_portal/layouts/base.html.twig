<!doctype html>
<html
  lang="fr"
  class="{{ html_classes|default('layout-menu-fixed layout-compact') }}"
  data-assets-path="{{ asset('') }}"
  data-template="vertical-menu-template-free">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>{% block title %}Portail HomeBalance{% endblock %}</title>
    <meta name="description" content="" />

    <link rel="icon" type="image/svg+xml" href="{{ asset('img/favicon/favicon.svg') }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />
    <link rel="stylesheet" href="{{ asset('css/demo.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/hb-theme.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/page-account-settings.css') }}" />

    {% block extra_stylesheets %}{% endblock %}

    <script src="{{ asset('js/config.js') }}"></script>
  </head>

  <body{% if app.user %} data-current-user-id="{{ app.user.id }}"{% endif %}>
    <div class="layout-wrapper layout-content-navbar">
      <div class="layout-container">
        {% set route = app.request.attributes.get('_route') %}
        {% set family_role_value = (app.user and app.user.familyRole) ? app.user.familyRole.value : null %}
        {% set active_menu = active_menu|default(
          (route starts with 'admin_evenement'
            or route starts with 'admin_rappel'
            or route starts with 'admin_type_evenement'
            or route starts with 'admin_calendar') ? 'module-events'
          : (route starts with 'app_evenement'
            or route starts with 'app_rappel'
            or route starts with 'app_type_evenement'
            or route starts with 'app_calendar'
            or route starts with 'app_notifications') ? 'module-events'
          : (route starts with 'app_gallery'
            or route starts with 'app_document'
            or route starts with 'app_default_gallery') ? 'module-documents'
          : (route starts with 'app_achat'
            or route starts with 'app_revenu'
            or route starts with 'app_historique_achat'
            or route starts with 'app_categorie_achat'
            or route starts with 'app_type_revenu'
            or route starts with 'app_saving_goal'
            or route starts with 'app_credit'
            or route starts with 'app_monthly_report') ? 'module-charge'
          : (route starts with 'parent_task'
            or route starts with 'parent_self_task'
            or route starts with 'child_task'
            or route starts with 'family_task'
            or route starts with 'parent_validation'
            or route starts with 'task_score'
            or route starts with 'admin_task') ? 'module-tasks'
          : (route starts with 'portal_messaging_'
            or route starts with 'portal_messaging_message_') ? 'module-messaging'
          : (route starts with 'portal_support_'
            or route starts with 'portal_admin_support_') ? 'module-support'
          : 'dashboard'
        ) %}

        {% set default_charge_submenus = is_granted('ROLE_ADMIN')
          ? [
            {'label': 'Categories achat', 'route': 'app_categorie_achat_index'},
            {'label': 'Types revenus', 'route': 'app_type_revenu_index'}
          ]
          : [
            {'label': 'Achats', 'route': 'app_achat_index'},
            {'label': 'Historique', 'route': 'app_historique_achat_index'},
            {'label': 'Categories achat', 'route': 'app_categorie_achat_index'},
            {'label': 'Revenus', 'route': 'app_revenu_index'},
            {'label': 'Budget', 'route': 'app_revenu_budget'},
            {'label': 'Epargne auto', 'route': 'app_saving_goal_index'},
            {'label': 'Rapport IA', 'route': 'app_monthly_report_index'},
            {'label': 'Credits', 'route': 'app_credit_index'}
          ]
        %}
        {% set default_documents_submenus = is_granted('ROLE_ADMIN')
          ? [
            {'label': 'Default galleries', 'route': 'app_default_gallery_index'}
          ]
          : (
            family_role_value == 'PARENT'
              ? [
                {'label': 'Galeries', 'route': 'app_gallery_index'},
                {'label': 'Documents', 'route': 'app_document_index'},
                {'label': 'Smart Insights', 'route': 'app_document_insights'},
                {'label': 'Galeries masquees', 'route': 'app_gallery_hidden'},
                {'label': 'Corbeille', 'route': 'app_document_trash'}
              ]
              : [
                {'label': 'Galeries', 'route': 'app_gallery_index'},
                {'label': 'Documents', 'route': 'app_document_index'},
                {'label': 'Galeries masquees', 'route': 'app_gallery_hidden'},
                {'label': 'Corbeille', 'route': 'app_document_trash'}
              ]
          )
        %}
        {% set default_tasks_submenus = is_granted('ROLE_ADMIN')
          ? [
            {'label': 'Taches globales', 'route': 'admin_task_index'},
            {'label': 'Regles de points', 'route': 'task_score_rules'}
          ]
          : (
            family_role_value == 'PARENT'
              ? [
                {'label': 'Taches parent', 'route': 'parent_task_index'},
                {'label': 'Mes taches parent', 'route': 'parent_self_task_index'},
                {'label': 'Assignations parent', 'route': 'parent_task_assign'},
                {'label': 'Validations', 'route': 'parent_validation_index'},
                {'label': 'Taches famille', 'route': 'family_task_list'},
                {'label': 'Scores famille', 'route': 'task_score_index'},
                {'label': 'Regles de points', 'route': 'task_score_rules'}
              ]
              : (
                family_role_value == 'CHILD'
                  ? [
                    {'label': 'Taches famille', 'route': 'family_task_list'},
                    {'label': 'Taches enfant', 'route': 'child_task_index'},
                    {'label': 'Scores famille', 'route': 'task_score_index'}
                  ]
                  : [
                    {'label': 'Taches famille', 'route': 'family_task_list'}
                  ]
              )
          )
        %}
        {% set default_events_submenus = is_granted('ROLE_ADMIN')
          ? [
            {'label': 'Evenements', 'route': 'admin_evenement_index'},
            {'label': 'Types evenements', 'route': 'admin_type_evenement_index'},
            {'label': 'Calendrier', 'route': 'admin_calendar'}
          ]
          : [
            {'label': 'Evenements', 'route': 'app_evenement_index'},
            {'label': 'Types evenements', 'route': 'app_type_evenement_index'},
            {'label': 'Rappels', 'route': 'app_rappel_history'},
            {'label': 'Notifications', 'route': 'app_notifications'},
            {'label': 'Calendrier', 'route': 'app_calendar'}
          ]
        %}
        {% set module_submenus = module_submenus|default({
          'module-charge': default_charge_submenus,
          'module-documents': default_documents_submenus,
          'module-tasks': default_tasks_submenus,
          'module-events': default_events_submenus
        }) %}

        {% include 'ui_portal/partials/sidebar.html.twig' with { active_menu: active_menu, module_submenus: module_submenus } %}

        <div class="layout-page">
          {% include 'ui_portal/partials/navbar.html.twig' %}

          <div class="content-wrapper">
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="toast-container position-fixed top-0 end-0 p-3" id="evtToastContainer" style="z-index: 1080;">
                {% for label, messages in app.flashes %}
                  {% for message in messages %}
                    {% set toastClass = label == 'success'
                      ? 'bg-success text-white'
                      : (label == 'warning'
                        ? 'bg-warning text-dark'
                        : (label == 'error' ? 'bg-danger text-white' : 'bg-info text-white')) %}
                    <div class="toast align-items-center {{ toastClass }} border-0 mb-2"
                         role="alert"
                         aria-live="assertive"
                         aria-atomic="true"
                         data-auto-show="1">
                      <div class="d-flex">
                        <div class="toast-body">
                          {{ message }}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                      </div>
                    </div>
                  {% endfor %}
                {% endfor %}
              </div>

              {% block content %}
                {% block body %}{% endblock %}
              {% endblock %}
            </div>

            {% include 'ui_portal/partials/footer.html.twig' %}
            <div class="content-backdrop fade"></div>
          </div>
        </div>
      </div>

      <div class="layout-overlay layout-menu-toggle"></div>
    </div>
    {# ── Vendor JS (CDN) ───────────────────────────────────────────────────── #}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/perfect-scrollbar@1.5.5/dist/perfect-scrollbar.min.js"></script>
    <script src="{{ asset('js/main.js') }}"></script>
    {# ── Sneat menu / sidebar toggle (lightweight replacement for menu.js) ── #}
    <script>
      (function () {
        var MENU_CLASS   = 'layout-menu-expanded';
        var TOGGLE_SEL   = '.layout-menu-toggle';
        var OVERLAY_SEL  = '.layout-overlay';

        function toggleMenu() {
          document.documentElement.classList.toggle(MENU_CLASS);
        }
        function closeMenu() {
          document.documentElement.classList.remove(MENU_CLASS);
        }

        function bindEvents() {
          document.querySelectorAll(TOGGLE_SEL).forEach(function (el) {
            el.addEventListener('click', function (e) { e.preventDefault(); toggleMenu(); });
          });
          var overlay = document.querySelector(OVERLAY_SEL);
          if (overlay) overlay.addEventListener('click', closeMenu);
        }

        document.addEventListener('DOMContentLoaded', bindEvents);
        document.addEventListener('turbo:load', bindEvents);
      })();
    </script>

    <script>
      (function () {
        function initDropdowns() {
          if (!window.bootstrap || !window.bootstrap.Dropdown) {
            return;
          }
          document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(function (el) {
            window.bootstrap.Dropdown.getOrCreateInstance(el);
          });
        }

        document.addEventListener('DOMContentLoaded', initDropdowns);
        document.addEventListener('turbo:load', initDropdowns);
      })();
    </script>

    <script>
      (function () {
        function showToast(el, delay) {
          if (!window.bootstrap || !window.bootstrap.Toast || !el) return;
          const toast = window.bootstrap.Toast.getOrCreateInstance(el, {
            delay: delay || 6000,
            autohide: true
          });
          toast.show();
        }

        function initFlashToasts() {
          document.querySelectorAll('.toast[data-auto-show="1"]').forEach(function (el) {
            showToast(el);
          });
        }

        const seenKey = 'evt_seen_rappel_toasts';
        function getSeenIds() {
          try {
            const raw = localStorage.getItem(seenKey);
            return raw ? new Set(JSON.parse(raw)) : new Set();
          } catch (e) {
            return new Set();
          }
        }

        function saveSeenIds(set) {
          try {
            localStorage.setItem(seenKey, JSON.stringify(Array.from(set)));
          } catch (e) {}
        }

        function createToastNode(message, variant) {
          const container = document.getElementById('evtToastContainer');
          if (!container) return null;

          const toast = document.createElement('div');
          toast.className = 'toast align-items-center border-0 mb-2 ' + (variant || 'bg-info text-white');
          toast.setAttribute('role', 'alert');
          toast.setAttribute('aria-live', 'assertive');
          toast.setAttribute('aria-atomic', 'true');
          toast.innerHTML =
            '<div class="d-flex">' +
            '  <div class="toast-body">' + message + '</div>' +
            '  <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>' +
            '</div>';

          container.appendChild(toast);
          return toast;
        }

        function updateNotificationDropdown(data) {
          const listEl = document.getElementById('notifList');
          const badgeEl = document.getElementById('notifBadge');
          const countEl = document.getElementById('notifCountLabel');
          if (!listEl || !badgeEl || !countEl) return;

          const items = Array.isArray(data) ? data : [];
          const count = items.length;

          badgeEl.textContent = String(count);
          countEl.textContent = String(count);
          badgeEl.classList.toggle('d-none', count === 0);

          if (count === 0) {
            listEl.innerHTML = '<div class="dropdown-item text-muted py-3">Aucune notification pour le moment.</div>';
            return;
          }

          listEl.innerHTML = items.map((item) => {
            const title = item.eventTitle || 'Evenement';
            const message = item.message || 'Nouveau rappel';
            const time = item.scheduledAt ? new Date(item.scheduledAt).toLocaleString() : '';
            return '' +
              '<a class="dropdown-item d-flex align-items-start py-2" href="/portal/evenements/' + item.eventId + '">' +
              '  <div class="flex-grow-1">' +
              '    <div class="small text-muted">' + title + '</div>' +
              '    <div class="fw-semibold">' + message + '</div>' +
              '    <div class="small text-muted">' + time + '</div>' +
              '  </div>' +
              '</a>';
          }).join('');
        }

        async function pollRappelToasts() {
          try {
            const res = await fetch('/portal/evenements/notifications/pending', {
              headers: { 'Accept': 'application/json' }
            });
            if (!res.ok) return;

            const data = await res.json();
            updateNotificationDropdown(data);
            if (!Array.isArray(data) || data.length === 0) return;

            const seen = getSeenIds();
            for (const item of data) {
              if (!item || !item.id || seen.has(item.id)) continue;

              const toast = createToastNode(item.message || 'Nouveau rappel', 'bg-primary text-white');
              showToast(toast, 8000);
              seen.add(item.id);
            }
            saveSeenIds(seen);
          } catch (e) {}
        }

        document.addEventListener('DOMContentLoaded', function () {
          initFlashToasts();
          pollRappelToasts();
          setInterval(pollRappelToasts, 30000);
        });

        document.addEventListener('turbo:load', function () {
          initFlashToasts();
          pollRappelToasts();
        });
      })();
    </script>

    {% if app.user %}
      <div
        data-controller="account-notification-stream"
        data-account-notification-stream-endpoint-value="{{ path('portal_account_notifications_browser_feed') }}"
        data-account-notification-stream-poll-interval-value="20000"></div>
    {% endif %}

    {% block extra_javascripts %}{% endblock %}
    {{ importmap('app') }}
  </body>
</html>

