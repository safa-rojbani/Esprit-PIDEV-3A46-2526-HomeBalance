{
    order mercure after encode
}

:3000 {
    encode zstd gzip

    mercure {
        publisher_jwt 1df3be7b01dc1e0c04451d362db3659b80107fb8bf08c4182a1b2342875 HS256
        subscriber_jwt 1df3be7b01dc1e0c04451d362db3659b80107fb8bf08c4182a1b2342875 HS256
        cors_origins *
        publish_origins *
        demo
        anonymous
        subscriptions
    }

    redir / /.well-known/mercure/ui/
    respond /healthz 200
}
