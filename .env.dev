###> symfony/mercure-bundle ###
# IMPORTANT: Run Symfony WITHOUT TLS to avoid mixed-content issues:
#   symfony serve --no-tls
# This keeps both the app (http://127.0.0.1:8000) and Mercure (http://localhost:3000) on HTTP.
MERCURE_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
# Must match the secret configured in the Symfony CLI Mercure hub (or your own hub)
MERCURE_JWT_SECRET=1df3be7b01dc1e0c04451d362db3659b80107fb8bf08c4182a1b2342875
###< symfony/mercure-bundle ###

