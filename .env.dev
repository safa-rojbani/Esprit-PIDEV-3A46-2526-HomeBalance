###> symfony/mercure-bundle ###
# When using "symfony serve", the CLI injects MERCURE_URL and MERCURE_PUBLIC_URL
# automatically. These values are used as fallback when running outside the CLI.
MERCURE_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
# Must match the secret configured in the Symfony CLI Mercure hub (or your own hub)
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
###< symfony/mercure-bundle ###

###> huggingface/api ###
# Hugging Face API token for AI features
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here
###< huggingface/api ###

###> twilio/sms ###
# Twilio credentials for SMS fallback
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_from_number
###< twilio/sms ###
